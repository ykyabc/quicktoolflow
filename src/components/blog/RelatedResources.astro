const categoryToolkits: Record<string, { title: string; href: string; description: string }> = {
  'Developer Tools': {
    title: 'Developer Tools',
    href: '/tools/developer/',
    description: 'Browse developer utilities for data, code, encoding, and debugging workflows.',
  },
  'Text Tools': {
