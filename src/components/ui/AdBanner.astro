---
import { ANALYTICS } from 'astrowind:config';

export interface Props {
  slot?: string;
  placement?: 'homepage' | 'toolsDirectory' | 'toolMiddle' | 'toolBottom' | 'blogBottom';
  format?: 'auto' | 'horizontal' | 'vertical' | 'rectangle';
  className?: string;
}

const { slot, placement, format = 'auto', className = '' } = Astro.props;
const adClientId = ANALYTICS?.vendors?.googleAdsense?.clientId ? String(ANALYTICS.vendors.googleAdsense.clientId) : '';
const configuredSlot =
  slot ||
  (placement && ANALYTICS?.vendors?.googleAdsense?.slots?.[placement]
    ? String(ANALYTICS.vendors.googleAdsense.slots[placement])
    : '');
const isConfigured = /^ca-pub-\d+$/.test(adClientId) && /^\d+$/.test(configuredSlot);
---

{
  isConfigured && (
    <div class:list={['ad-container my-8 text-center', className]} aria-label="Advertisement">
      <ins
        class="adsbygoogle"
        style="display:block"
        data-ad-client={adClientId}
        data-ad-slot={configuredSlot}
        data-ad-format={format}
        data-full-width-responsive="true"
      />
    </div>
  )
}

{
  isConfigured && (
    <script
      is:inline
      set:html={`try {
        window.adsbygoogle = window.adsbygoogle || [];
        window.adsbygoogle.push({});
      } catch {
        // Ad blockers may prevent AdSense from loading.
      }`}
    />
  )
}
