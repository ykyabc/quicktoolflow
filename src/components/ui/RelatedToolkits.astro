---
interface Toolkit {
  slug: string;
  title: string;
  href: string;
  eyebrow: string;
  description: string;
  icon: string;
  tags: string[];
}

interface Props {
  current: string;
}

const { current } = Astro.props;

const toolkits: Toolkit[] = [
  {
    slug: 'structured-data',
    title: 'Structured Data Tools',
    href: '/tools/structured-data/',
    eyebrow: 'Data workflows',
    description: 'Format, validate, convert, minify, and inspect JSON, CSV, YAML, and XML.',
    icon: 'tabler:database-search',
    tags: ['JSON', 'CSV', 'YAML', 'XML'],
  },
  {
    slug: 'code-formatting',
    title: 'Code Formatting Tools',
    href: '/tools/code-formatting/',
    eyebrow: 'Formatting workflows',
    description: 'Clean code-like content, format SQL and HTML, preview Markdown, and minify payloads.',
    icon: 'tabler:code-dots',
    tags: ['Format', 'Minify', 'SQL', 'HTML'],
  },
  {
    slug: 'web-publishing',
    title: 'Web Publishing Tools',
    href: '/tools/web-publishing/',
    eyebrow: 'Publishing workflows',
    description: 'Prepare metadata, social previews, robots.txt, UTM links, QR codes, and clean slugs.',
    icon: 'tabler:world-upload',
    tags: ['SEO', 'Open Graph', 'UTM', 'Robots.txt'],
  },
  {
    slug: 'frontend-design',
    title: 'Design & Frontend Tools',
    href: '/tools/frontend-design/',
    eyebrow: 'Frontend workflows',
    description: 'Prepare colors, CSS units, placeholder assets, HTML snippets, metadata, and launch previews.',
    icon: 'tabler:layout-dashboard',
    tags: ['Colors', 'CSS Units', 'HTML', 'Previews'],
  },
  {
    slug: 'security-encoding',
    title: 'Security & Encoding Tools',
    href: '/tools/security-encoding/',
    eyebrow: 'Security workflows',
    description: 'Decode JWTs and Base64, generate hashes and passwords, and escape strings safely.',
    icon: 'tabler:shield-lock',
    tags: ['JWT', 'Base64', 'Hashes', 'Escaping'],
  },
];

const relatedToolkits = toolkits.filter((toolkit) => toolkit.slug !== current);
---

{
  relatedToolkits.length > 0 && (
    <section class="mx-auto mt-16 max-w-6xl">
      <div class="mb-6 max-w-3xl">
        <p class="text-sm font-semibold uppercase tracking-wide text-primary-600 dark:text-primary-300">
          Related toolkits
        </p>
        <h2 class="mt-2 text-2xl font-bold text-gray-900 dark:text-white">Continue with a connected workflow</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600 dark:text-gray-300">
          These collections overlap naturally, so you can move from formatting and data cleanup into publishing,
          encoding, or deeper developer workflows without starting from scratch.
        </p>
      </div>

      <div class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
        {relatedToolkits.map((toolkit) => (
          <a
            href={toolkit.href}
            class="group rounded-2xl border border-gray-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:border-primary-200 hover:shadow-md dark:border-gray-700 dark:bg-gray-800 dark:hover:border-primary-800"
          >
            <div class="flex items-start gap-4">
              <span class="inline-flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-primary-50 text-primary-700 dark:bg-primary-950/40 dark:text-primary-300">
                <astro-icon name={toolkit.icon} class="h-5 w-5" />
              </span>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-primary-600 dark:text-primary-300">
                  {toolkit.eyebrow}
                </p>
                <h3 class="mt-1 text-lg font-semibold text-gray-900 transition group-hover:text-primary-700 dark:text-white dark:group-hover:text-primary-300">
                  {toolkit.title}
                </h3>
              </div>
            </div>

            <p class="mt-4 text-sm leading-6 text-gray-600 dark:text-gray-300">{toolkit.description}</p>

            <div class="mt-5 flex flex-wrap gap-2">
              {toolkit.tags.map((tag) => (
                <span class="rounded-full bg-gray-100 px-2.5 py-1 text-xs font-semibold text-gray-700 dark:bg-gray-900 dark:text-gray-300">
                  {tag}
                </span>
              ))}
            </div>

            <span class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-primary-600 dark:text-primary-300">
              Open toolkit
              <astro-icon name="tabler:arrow-right" class="h-4 w-4 transition group-hover:translate-x-0.5" />
            </span>
          </a>
        ))}
      </div>
    </section>
  )
}
