---
export interface Props {
  guides: {
    title: string;
    href: string;
    description: string;
  }[];
}

const { guides } = Astro.props;
---

{guides.length > 0 && (
  <section class="mt-12">
    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">
      Related Guides
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {guides.map((guide) => (
        <a
          href={guide.href}
          class="rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 p-5 shadow-sm transition hover:-translate-y-1 hover:shadow-md"
        >
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
            {guide.title}
          </h3>

          <p class="mt-2 text-sm leading-6 text-gray-600 dark:text-gray-400">
            {guide.description}
          </p>

          <span class="mt-4 inline-flex text-sm font-semibold text-blue-600 dark:text-blue-400">
            Read guide →
          </span>
        </a>
      ))}
    </div>
  </section>
)}