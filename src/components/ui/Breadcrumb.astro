---
export interface Props {
  items: Array<{ name: string; href?: string }>;
}

const { items } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.name,
    ...(item.href ? { item: `https://quicktoolflow.com${item.href}` } : {}),
  })),
};
---

<nav aria-label="Breadcrumb" class="mb-6 text-sm">
  <ol class="flex items-center gap-1.5 flex-wrap text-gray-500 dark:text-gray-400">
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        {i > 0 && (
          <astro-icon name="tabler:chevron-right" class="w-3.5 h-3.5 text-gray-400" />
        )}
        {item.href ? (
          <a href={item.href} class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
            {item.name}
          </a>
        ) : (
          <span class="text-gray-800 dark:text-gray-200 font-medium">{item.name}</span>
        )}
      </li>
    ))}
  </ol>
</nav>

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
