---
import { Icon } from 'astro-icon/components';
import { SITE } from 'astrowind:config';
import { getHomePermalink } from '~/utils/permalinks';

interface Link {
  text?: string;
  href?: string;
  ariaLabel?: string;
  icon?: string;
}

interface Links {
  title?: string;
  links: Array<Link>;
}

export interface Props {
  links: Array<Links>;
  secondaryLinks: Array<Link>;
  socialLinks: Array<Link>;
  footNote?: string;
  theme?: string;
}

const { socialLinks = [], secondaryLinks = [], links = [], footNote = '', theme = 'light' } = Astro.props;
---

<footer class:list={[{ dark: theme === 'dark' }, 'relative border-t border-gray-200 dark:border-slate-800 not-prose']}>
  <div class="dark:bg-dark absolute inset-0 pointer-events-none" aria-hidden="true"></div>
  <div
    class="relative max-w-7xl mx-auto px-4 sm:px-6 dark:text-slate-300 intersect-once intersect-quarter intersect-no-queue motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
  >
    <div class="grid gap-6 py-6 md:grid-cols-[1.1fr_2fr] md:items-start md:py-8">
      <div>
        <div>
          <a class="inline-block text-base font-bold text-gray-900 dark:text-white" href={getHomePermalink()}>
            {SITE?.name}
          </a>
        </div>
        <p class="mt-2 max-w-sm text-sm leading-6 text-gray-500 dark:text-gray-400">
          Fast, browser-based tools for formatting, converting, generating, and checking everyday web data.
        </p>
        <div class="mt-3 flex flex-wrap gap-x-3 gap-y-1 text-sm">
          {
            secondaryLinks.map(({ text, href }, index) => (
              <>
                {index !== 0 ? <span class="text-gray-300 dark:text-slate-700">/</span> : ''}
                <a
                  class="text-gray-500 transition hover:text-gray-900 hover:underline dark:text-gray-400 dark:hover:text-white"
                  href={href}
                  set:html={text}
                />
              </>
            ))
          }
        </div>
      </div>

      <div class="grid grid-cols-2 gap-5 sm:grid-cols-4">
        {
          links.map(({ title, links }) => (
            <div>
              <div class="mb-2 text-sm font-semibold text-gray-900 dark:text-gray-200">{title}</div>
              {links && Array.isArray(links) && links.length > 0 && (
                <ul class="space-y-1.5 text-sm">
                  {links.map(({ text, href, ariaLabel }) => (
                    <li>
                      <a
                        class="text-gray-500 transition hover:text-gray-900 hover:underline dark:text-gray-400 dark:hover:text-white"
                        href={href}
                        aria-label={ariaLabel}
                      >
                        <Fragment set:html={text} />
                      </a>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          ))
        }
      </div>
    </div>

    <div
      class="flex flex-col gap-3 border-t border-gray-100 py-4 text-sm dark:border-slate-800 sm:flex-row sm:items-center sm:justify-between"
    >
      <div class="text-gray-500 dark:text-gray-400">
        <Fragment set:html={footNote} />
      </div>
      {
        socialLinks?.length ? (
          <ul class="flex gap-1">
            {socialLinks.map(({ ariaLabel, href, text, icon }) => (
              <li>
                <a
                  class="inline-flex items-center rounded-md p-1.5 text-gray-500 transition hover:bg-gray-100 hover:text-gray-900 dark:text-gray-400 dark:hover:bg-slate-800 dark:hover:text-white"
                  aria-label={ariaLabel}
                  href={href}
                >
                  {icon && <Icon name={icon} class="h-4 w-4" />}
                  <Fragment set:html={text} />
                </a>
              </li>
            ))}
          </ul>
        ) : (
          ''
        )
      }
    </div>
  </div>
</footer>
