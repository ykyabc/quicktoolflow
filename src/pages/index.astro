---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import AdBanner from '~/components/ui/AdBanner.astro';
import ToolCard from '~/components/ui/ToolCard.astro';
import { getFeaturedTools, categories, getToolsByCategory } from '~/utils/tools-data';

const metadata = {
  title: 'QuickToolFlow — Free Online Developer & Productivity Tools',
  description:
    'Fast, free, privacy-first online tools for developers. JSON formatter, password generator, word counter, Base64 encoder, and more. No sign-up.',
};
---

<Layout metadata={metadata}>
  {/* ===== HERO ===== */}
  <Hero
    actions={[
      { variant: 'primary', text: 'Explore All Tools', href: '/tools/', icon: 'tabler:arrow-right' },
      { variant: 'secondary', text: 'Learn More', href: '/about/' },
    ]}
  >
    <Fragment slot="title">
      Every tool you need, <span class="text-accent dark:text-white highlight"> one click away.</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="hidden sm:inline">
        Developer utilities, text processors, and productivity tools that run entirely in your browser.
      </span>
      No data leaves your device. No accounts. No limits.
    </Fragment>
  </Hero>

  {/* ===== FEATURED TOOLS ===== */}
  <section class="px-4 py-16 mx-auto max-w-7xl sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">
        Featured Tools
      </h2>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        Hand-picked essentials for developers, writers, and designers. All free, all instant.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {getFeaturedTools().map((tool) => (
        <ToolCard slug={tool.slug} name={tool.name} description={tool.description} icon={tool.icon} gradient={tool.gradient} />
      ))}
    </div>
  </section>

  {/* ===== AD BREAK ===== */}
  <div class="max-w-4xl mx-auto px-4">
    <AdBanner slot="1111111111" format="horizontal" />
  </div>

  {/* ===== CATEGORIES ===== */}
  <Features
    tagline="Categories"
    title="Browse by Category"
    subtitle="Find exactly what you need, organized by use case."
    items={categories.map((cat) => ({
      title: cat.name,
      description: cat.description + ` ${getToolsByCategory(cat.slug).length} tools available.`,
      icon: cat.slug === 'text' ? 'tabler:letter-case'
        : cat.slug === 'developer' ? 'tabler:code'
        : cat.slug === 'generator' ? 'tabler:sparkles'
        : 'tabler:arrows-exchange',
      callToAction: { text: 'View Tools', href: `/tools/#${cat.slug}` },
    }))}
  />

  {/* ===== WHY US ===== */}
  <Steps
    title="Why QuickToolFlow?"
    subtitle="We build tools differently. Here's what sets us apart."
    isReversed
    items={[
      { title: 'Lightning Fast', description: 'All tools run 100% client-side. Zero server round-trips means instant results every time.', icon: 'tabler:bolt' },
      { title: 'Privacy First', description: 'Your data never leaves your browser. No tracking, no server storage, no third-party data sharing.', icon: 'tabler:shield-lock' },
      { title: 'Zero Sign-Up', description: 'Jump straight in. No accounts, no email walls, no freemium upsells. Tools should be free.', icon: 'tabler:user-off' },
      { title: 'Fully Responsive', description: 'Every tool works flawlessly on desktop, tablet, and mobile. Use them anywhere.', icon: 'tabler:device-mobile' },
    ]}
    image={{ src: '~/assets/images/hero-image.png', alt: 'QuickToolFlow' }}
  />

  {/* ===== CTA ===== */}
  <CallToAction
    actions={[{ variant: 'primary', text: 'Get Started — It\'s Free', href: '/tools/', icon: 'tabler:arrow-right' }]}
  >
    <Fragment slot="title">Ready to be more productive?</Fragment>
    <Fragment slot="subtitle">Start using our free tools right now. No sign-up, no credit card, no limits.</Fragment>
  </CallToAction>
</Layout>
