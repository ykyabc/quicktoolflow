---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import AdBanner from '~/components/ui/AdBanner.astro';
import ToolCard from '~/components/ui/ToolCard.astro';
import { tools, getFeaturedTools, categories, getToolsByCategory, type Tool } from '~/utils/tools-data';

const quickAccessTools = [
  'json-formatter',
  'json-schema-validator',
  'base64',
  'base64-image-converter',
  'password-generator',
  'qr-code-generator',
  'timestamp-converter',
  'timestamp-batch-converter',
  'url-query-builder',
  'utm-builder',
  'open-graph-preview',
  'serp-snippet-preview',
  'csv-to-json',
  'jwt-decoder',
]
  .map((slug) => tools.find((tool) => tool.slug === slug))
  .filter((tool): tool is Tool => Boolean(tool));

const recentlyAddedSlugs = [
  'json-schema-validator',
  'html-minifier',
  'css-minifier',
  'base64-image-converter',
  'timestamp-batch-converter',
  'url-query-builder',
];
const recentlyAddedTools = recentlyAddedSlugs
  .map((slug) => tools.find((tool) => tool.slug === slug))
  .filter((tool): tool is Tool => Boolean(tool));

const featuredGuides = [
  {
    title: 'JSON vs YAML vs XML',
    href: '/blog/json-vs-yaml-vs-xml/',
    description: 'Choose the right structured data format for APIs, config files, feeds, and validation.',
  },
  {
    title: 'Why Is My JSON Invalid?',
    href: '/blog/why-is-my-json-invalid/',
    description: 'Debug common JSON syntax mistakes before formatting, validating, or converting data.',
  },
  {
    title: 'Clean API Data Before Importing',
    href: '/blog/clean-api-data-before-importing/',
    description: 'Prepare API responses for spreadsheets, dashboards, databases, and internal tools.',
  },
  {
    title: 'Common CSV Formatting Problems',
    href: '/blog/common-csv-formatting-problems/',
    description: 'Fix CSV headers, delimiters, quotes, line breaks, encodings, and blank rows.',
  },
];

const workflows = [
  {
    title: 'Clean and convert API data',
    description: 'Format, validate schemas, minify, query, and convert structured data between common formats.',
    links: [
      { text: 'Structured Data Hub', href: '/tools/structured-data/' },
      { text: 'Code Formatting Hub', href: '/tools/code-formatting/' },
      { text: 'JSON Formatter', href: '/tools/json-formatter/' },
      { text: 'JSON Schema Validator', href: '/tools/json-schema-validator/' },
      { text: 'JSON Minifier', href: '/tools/json-minifier/' },
      { text: 'JSON Path Tester', href: '/tools/json-path-tester/' },
      { text: 'JSON to CSV', href: '/tools/json-to-csv/' },
      { text: 'CSV to JSON', href: '/tools/csv-to-json/' },
      { text: 'CSV Formatter', href: '/tools/csv-formatter/' },
      { text: 'JSON to YAML', href: '/tools/json-to-yaml/' },
      { text: 'YAML Formatter', href: '/tools/yaml-formatter/' },
      { text: 'XML Formatter', href: '/tools/xml-formatter/' },
    ],
  },
  {
    title: 'Inspect tokens and encoded text',
    description: 'Decode JWT claims, inspect Base64 text or images, and generate hashes for quick checks.',
    links: [
      { text: 'Security & Encoding Hub', href: '/tools/security-encoding/' },
      { text: 'JWT Decoder', href: '/tools/jwt-decoder/' },
      { text: 'Base64 Encoder', href: '/tools/base64/' },
      { text: 'Base64 Image Converter', href: '/tools/base64-image-converter/' },
      { text: 'Hash Generator', href: '/tools/hash-generator/' },
    ],
  },
  {
    title: 'Create secure shareable assets',
    description: 'Generate strong passwords, QR codes, UUIDs, campaign links, and clean URL slugs in seconds.',
    links: [
      { text: 'Password Generator', href: '/tools/password-generator/' },
      { text: 'QR Code Generator', href: '/tools/qr-code-generator/' },
      { text: 'UUID Generator', href: '/tools/uuid-generator/' },
      { text: 'UTM Builder', href: '/tools/utm-builder/' },
      { text: 'URL Query Builder', href: '/tools/url-query-builder/' },
      { text: 'URL Parser', href: '/tools/url-parser/' },
    ],
  },
  {
    title: 'Prepare pages for publishing',
    description: 'Preview snippets, generate meta tags, create robots.txt, and build campaign-ready URLs.',
    links: [
      { text: 'SEO Tools Hub', href: '/tools/seo/' },
      { text: 'Web Publishing Toolkit', href: '/tools/web-publishing/' },
      { text: 'Design & Frontend Toolkit', href: '/tools/frontend-design/' },
      { text: 'SERP Snippet Preview', href: '/tools/serp-snippet-preview/' },
      { text: 'Meta Tag Generator', href: '/tools/meta-tag-generator/' },
      { text: 'Robots.txt Generator', href: '/tools/robots-txt-generator/' },
      { text: 'UTM Builder', href: '/tools/utm-builder/' },
      { text: 'URL Query Builder', href: '/tools/url-query-builder/' },
      { text: 'Open Graph Preview', href: '/tools/open-graph-preview/' },
    ],
  },
];

const toolkits = [
  {
    eyebrow: 'Featured',
    title: 'Structured Data',
    description: 'Format, convert, minify, and inspect JSON, CSV, YAML, XML, and JSON paths.',
    href: '/tools/structured-data/',
    icon: 'tabler:database',
    labels: ['JSON', 'CSV', 'YAML'],
  },
  {
    eyebrow: 'Frontend',
    title: 'Design & Frontend',
    description: 'Convert colors and CSS units, format HTML, and preview launch metadata.',
    href: '/tools/frontend-design/',
    icon: 'tabler:palette',
    labels: ['Colors', 'CSS', 'HTML'],
  },
  {
    eyebrow: 'Formatting',
    title: 'Code Formatting',
    description: 'Clean up JSON, CSV, YAML, XML, HTML, SQL, and Markdown before sharing.',
    href: '/tools/code-formatting/',
    icon: 'tabler:code',
    labels: ['Format', 'Minify', 'Test'],
  },
  {
    eyebrow: 'Publishing',
    title: 'Web Publishing',
    description: 'Prepare metadata, social cards, robots.txt, campaign URLs, and QR codes.',
    href: '/tools/web-publishing/',
    icon: 'tabler:world-upload',
    labels: ['SEO', 'OG', 'UTM'],
  },
  {
    eyebrow: 'Security',
    title: 'Security & Encoding',
    description: 'Decode JWTs and Base64, generate hashes, passwords, and safe strings.',
    href: '/tools/security-encoding/',
    icon: 'tabler:shield-lock',
    labels: ['JWT', 'Base64', 'Hash'],
  },
];

const trustPoints = [
  {
    title: 'Lightning Fast',
    description: 'Client-side utilities respond instantly without waiting on server round trips.',
    icon: 'tabler:bolt',
  },
  {
    title: 'Privacy First',
    description: 'Most inputs stay in your browser, which is safer for quick developer checks.',
    icon: 'tabler:shield-lock',
  },
  {
    title: 'Zero Sign-Up',
    description: 'Open a tool, finish the task, and leave without account friction.',
    icon: 'tabler:user-off',
  },
  {
    title: 'Mobile Ready',
    description: 'Core tools are tuned for desktop, tablet, and phone workflows.',
    icon: 'tabler:device-mobile',
  },
];

const metadata = {
  title: 'Free Online Developer & Productivity Tools',
  description:
    'Fast, free, privacy-first online tools for developers. JSON formatter, password generator, word counter, Base64 encoder, and more. No sign-up.',
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      { variant: 'primary', text: 'Explore All Tools', href: '/tools/', icon: 'tabler:arrow-right' },
      { variant: 'secondary', text: 'About QuickToolFlow', href: '/about/' },
    ]}
  >
    <Fragment slot="title">
      Every tool you need, <span class="text-accent dark:text-white highlight"> one click away.</span>
    </Fragment>
    <Fragment slot="subtitle">
      <span class="hidden sm:inline"
        >Developer utilities, text processors, and productivity tools that run entirely in your browser.</span
      >
      No data leaves your device. No accounts. No limits.
    </Fragment>
  </Hero>

  <section class="px-4 pb-8 mx-auto -mt-4 max-w-5xl sm:px-6 lg:px-8">
    <div class="rounded-2xl border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-700 dark:bg-gray-800 sm:p-5">
      <div class="grid gap-4 lg:grid-cols-[1fr_auto] lg:items-center">
        <div class="relative">
          <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-4">
            <astro-icon name="tabler:search" class="h-5 w-5 text-gray-400"></astro-icon>
          </div>
          <input
            id="home-tool-search"
            type="search"
            autocomplete="off"
            placeholder="Search tools: JSON, Base64, QR, timestamp..."
            class="w-full rounded-xl border border-gray-300 bg-white py-3.5 pl-12 pr-4 text-base text-gray-900 outline-none transition focus:border-blue-500 focus:ring-2 focus:ring-blue-500 dark:border-gray-600 dark:bg-gray-900 dark:text-white"
          />
          <div
            id="home-search-results"
            class="absolute left-0 right-0 top-[calc(100%+0.5rem)] z-20 hidden overflow-hidden rounded-xl border border-gray-200 bg-white shadow-xl dark:border-gray-700 dark:bg-gray-900"
          >
          </div>
        </div>
        <a
          href="/tools/"
          class="inline-flex min-h-12 items-center justify-center rounded-xl bg-blue-600 px-5 text-sm font-semibold text-white transition hover:bg-blue-700"
        >
          Browse all {tools.length} tools
        </a>
      </div>

      <div class="mt-4 flex gap-2 overflow-x-auto pb-1">
        {
          quickAccessTools.map((tool) => (
            <a
              href={`/tools/${tool.slug}/`}
              class="shrink-0 rounded-full border border-gray-200 bg-gray-50 px-3 py-1.5 text-xs font-semibold text-gray-700 transition hover:border-blue-200 hover:bg-blue-50 hover:text-blue-700 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-300"
            >
              {tool.name.replace(' & Validator', '').replace(' Encoder & Decoder', '')}
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="px-4 py-10 mx-auto max-w-7xl sm:px-6 lg:px-8">
    <div class="mb-8 flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-blue-600 dark:text-blue-400">Recently added</p>
        <h2 class="mt-2 text-3xl font-bold tracking-tight text-gray-900 dark:text-white">
          New tools for deeper workflows
        </h2>
        <p class="mt-3 max-w-2xl text-gray-600 dark:text-gray-400">
          Fresh additions for schema validation, HTML and CSS minification, image encoding, batch timestamps, and clean
          query strings.
        </p>
      </div>
      <a
        href="/tools/"
        class="inline-flex rounded-lg border border-gray-200 bg-white px-4 py-2.5 text-sm font-semibold text-gray-700 transition hover:border-blue-200 hover:text-blue-700 dark:border-gray-700 dark:bg-gray-800 dark:text-gray-200"
      >
        View all tools
      </a>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        recentlyAddedTools.map((tool) => (
          <a
            href={`/tools/${tool.slug}/`}
            class="group rounded-2xl border border-gray-200 bg-white p-5 shadow-sm transition hover:-translate-y-1 hover:shadow-md dark:border-gray-700 dark:bg-gray-800"
          >
            <div
              class:list={[
                'mb-4 inline-flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br text-white',
                tool.gradient,
              ]}
            >
              <astro-icon name={tool.icon} class="h-5 w-5" />
            </div>
            <h3 class="text-lg font-semibold text-gray-900 group-hover:text-blue-700 dark:text-white dark:group-hover:text-blue-300">
              {tool.name}
            </h3>
            <p class="mt-2 text-sm leading-6 text-gray-600 dark:text-gray-300">{tool.description}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="px-4 py-8 mx-auto max-w-7xl sm:px-6 lg:px-8">
    <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-primary-700 dark:text-primary-300">
          Featured guides
        </p>
        <h2 class="mt-1 text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
          Start with high-value workflows
        </h2>
      </div>
      <a
        href="/tools/structured-data/"
        class="inline-flex items-center gap-2 text-sm font-semibold text-primary-700 transition hover:text-primary-800 dark:text-primary-300 dark:hover:text-primary-200"
      >
        Open Structured Data Tools
        <astro-icon name="tabler:arrow-right" class="h-4 w-4"></astro-icon>
      </a>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      {
        featuredGuides.map((guide) => (
          <a
            href={guide.href}
            class="group rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:border-primary-200 hover:shadow-md dark:border-gray-700 dark:bg-gray-800"
          >
            <h3 class="text-sm font-semibold leading-6 text-gray-900 group-hover:text-primary-700 dark:text-white dark:group-hover:text-primary-300">
              {guide.title}
            </h3>
            <p class="mt-2 line-clamp-3 text-sm leading-6 text-gray-600 dark:text-gray-300">{guide.description}</p>
          </a>
        ))
      }
    </div>
  </section>

  <section class="px-4 py-16 mx-auto max-w-7xl sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl">Featured Tools</h2>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
        Hand-picked essentials for developers, writers, and designers. All free, all instant.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {
        getFeaturedTools().map((tool) => (
          <ToolCard
            slug={tool.slug}
            name={tool.name}
            description={tool.description}
            icon={tool.icon}
            gradient={tool.gradient}
          />
        ))
      }
    </div>
  </section>

  <section class="px-4 py-12 mx-auto max-w-7xl sm:px-6 lg:px-8">
    <div class="mb-8">
      <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white">Start with a common workflow</h2>
      <p class="mt-3 max-w-2xl text-gray-600 dark:text-gray-400">
        QuickToolFlow is organized around practical tasks, not just isolated utilities. Pick a workflow and jump into
        the tools that usually belong together.
      </p>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
      {
        workflows.map((workflow) => (
          <article class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">{workflow.title}</h3>
            <p class="mt-3 text-sm leading-6 text-gray-600 dark:text-gray-300">{workflow.description}</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {workflow.links.map((link) => (
                <a
                  href={link.href}
                  class="rounded-full bg-gray-100 px-3 py-1.5 text-xs font-semibold text-gray-700 transition hover:bg-primary-50 hover:text-primary-700 dark:bg-gray-900 dark:text-gray-300 dark:hover:bg-gray-700"
                >
                  {link.text}
                </a>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="px-4 py-8 mx-auto max-w-7xl sm:px-6 lg:px-8">
    <div class="mb-5 flex flex-wrap items-end justify-between gap-3">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-primary-700 dark:text-primary-300">Toolkits</p>
        <h2 class="mt-1 text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
          Jump into a focused toolkit
        </h2>
      </div>
      <a
        href="/tools/"
        class="inline-flex items-center gap-2 text-sm font-semibold text-primary-700 transition hover:text-primary-800 dark:text-primary-300 dark:hover:text-primary-200"
      >
        Browse all tools
        <astro-icon name="tabler:arrow-right" class="h-4 w-4"></astro-icon>
      </a>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5">
      {
        toolkits.map((toolkit) => (
          <a
            href={toolkit.href}
            class="group flex min-h-40 flex-col rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:border-primary-200 hover:shadow-md dark:border-gray-700 dark:bg-gray-800"
          >
            <div class="flex items-start justify-between gap-3">
              <div class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-primary-50 text-primary-700 dark:bg-primary-950/40 dark:text-primary-300">
                <astro-icon name={toolkit.icon} class="h-5 w-5" />
              </div>
              <span class="text-[11px] font-semibold uppercase tracking-wide text-primary-700 dark:text-primary-300">
                {toolkit.eyebrow}
              </span>
            </div>
            <h3 class="mt-3 text-base font-semibold leading-6 text-gray-900 group-hover:text-primary-700 dark:text-white dark:group-hover:text-primary-300">
              {toolkit.title}
            </h3>
            <p class="mt-1 line-clamp-2 text-sm leading-6 text-gray-600 dark:text-gray-300">{toolkit.description}</p>
            <div class="mt-auto flex items-center justify-between gap-3 pt-4">
              <div class="flex min-w-0 flex-wrap gap-1.5">
                {toolkit.labels.map((label) => (
                  <span class="rounded-full bg-gray-100 px-2 py-1 text-[11px] font-semibold text-gray-600 dark:bg-gray-900 dark:text-gray-300">
                    {label}
                  </span>
                ))}
              </div>
              <astro-icon
                name="tabler:arrow-up-right"
                class="h-4 w-4 shrink-0 text-gray-400 transition group-hover:text-primary-700 dark:group-hover:text-primary-300"
              />
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4">
    <AdBanner placement="homepage" format="horizontal" />
  </div>

  <Features
    tagline="Categories"
    title="Browse by Category"
    subtitle="Find exactly what you need, organized by use case."
    items={categories.map((cat) => ({
      title: cat.name,
      description: cat.description + ' ' + getToolsByCategory(cat.slug).length + ' tools available.',
      icon:
        cat.slug === 'text'
          ? 'tabler:letter-case'
          : cat.slug === 'developer'
            ? 'tabler:code'
            : cat.slug === 'generator'
              ? 'tabler:sparkles'
              : cat.slug === 'converter'
                ? 'tabler:arrows-exchange'
                : 'tabler:tags',
      callToAction: { text: 'View Tools', href: '/tools/#' + cat.slug },
    }))}
  />

  <section class="px-4 py-10 mx-auto max-w-7xl sm:px-6 lg:px-8">
    <div class="grid gap-5 lg:grid-cols-[0.9fr_2.1fr] lg:items-start">
      <div>
        <p class="text-sm font-semibold uppercase tracking-wide text-primary-700 dark:text-primary-300">
          Why QuickToolFlow?
        </p>
        <h2 class="mt-2 text-2xl font-bold tracking-tight text-gray-900 dark:text-white">
          Fast tools without extra friction
        </h2>
      </div>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {
          trustPoints.map((point) => (
            <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-700 dark:bg-gray-800">
              <div class="inline-flex h-9 w-9 items-center justify-center rounded-lg bg-primary-50 text-primary-700 dark:bg-primary-950/40 dark:text-primary-300">
                <astro-icon name={point.icon} class="h-5 w-5" />
              </div>
              <h3 class="mt-3 text-sm font-semibold text-gray-900 dark:text-white">{point.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600 dark:text-gray-300">{point.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="px-4 py-14 mx-auto max-w-6xl sm:px-6 lg:px-8">
    <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800 sm:p-8">
      <div class="grid gap-8 md:grid-cols-3">
        <div>
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Privacy at a glance</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600 dark:text-gray-300">
            Most tools process your input directly in the browser. QuickToolFlow is designed for quick utility tasks,
            not account collection.
          </p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 dark:text-white">No sign-up wall</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600 dark:text-gray-300">
            You can open a tool, run the task, and leave. No account is required for core functionality.
          </p>
        </div>
        <div>
          <h3 class="font-semibold text-gray-900 dark:text-white">Clear advertising boundary</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600 dark:text-gray-300">
            Ads, when enabled, are placed away from primary tool controls such as generate, copy, download, and format
            buttons.
          </p>
        </div>
      </div>
    </div>
  </section>

  <CallToAction
    actions={[{ variant: 'primary', text: "Get Started - It's Free", href: '/tools/', icon: 'tabler:arrow-right' }]}
  >
    <Fragment slot="title">Ready to be more productive?</Fragment>
    <Fragment slot="subtitle">Start using our free tools right now. No sign-up, no credit card, no limits.</Fragment>
  </CallToAction>

  <script define:vars={{ tools }} is:inline>
    (function () {
      const input = document.getElementById('home-tool-search');
      const results = document.getElementById('home-search-results');
      if (!input || !results) return;

      const allTools = tools;

      function renderResults(query) {
        const q = query.trim().toLowerCase();
        if (!q) {
          results.classList.add('hidden');
          results.innerHTML = '';
          return;
        }

        const matches = allTools
          .filter((tool) => {
            return (
              tool.name.toLowerCase().includes(q) ||
              tool.description.toLowerCase().includes(q) ||
              tool.slug.toLowerCase().includes(q) ||
              tool.category.toLowerCase().includes(q)
            );
          })
          .slice(0, 6);

        if (matches.length === 0) {
          results.innerHTML =
            '<div class="px-4 py-4 text-sm text-gray-500 dark:text-gray-400">No matching tools found.</div>';
          results.classList.remove('hidden');
          return;
        }

        results.innerHTML = matches
          .map(
            (tool) =>
              '<a href="/tools/' +
              tool.slug +
              '/" class="flex items-start gap-3 border-b border-gray-100 px-4 py-3 last:border-0 hover:bg-gray-50 dark:border-gray-800 dark:hover:bg-gray-800">' +
              '<span class="mt-1 inline-flex h-2.5 w-2.5 shrink-0 rounded-full bg-blue-500"></span>' +
              '<span><span class="block text-sm font-semibold text-gray-900 dark:text-white">' +
              tool.name +
              '</span><span class="mt-0.5 block text-xs leading-5 text-gray-500 dark:text-gray-400">' +
              tool.description +
              '</span></span></a>'
          )
          .join('');
        results.classList.remove('hidden');
      }

      input.addEventListener('input', () => renderResults(input.value));
      document.addEventListener('click', (event) => {
        if (!results.contains(event.target) && event.target !== input) {
          results.classList.add('hidden');
        }
      });
    })();
  </script>
</Layout>
