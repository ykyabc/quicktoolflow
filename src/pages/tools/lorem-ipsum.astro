---
import ToolLayout from '~/layouts/ToolLayout.astro';
---

<ToolLayout
  title="Lorem Ipsum Generator"
  description="Generate Lorem Ipsum placeholder text for designs and layouts. Control paragraph count, sentences, or word count."
  slug="lorem-ipsum"
  category="Generators"
>
  <div class="space-y-6">
    <div class="flex flex-wrap items-end gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Count</label>
        <input id="lg-count" type="number" min="1" max="100" value="3" class="w-24 px-4 py-2.5 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Type</label>
        <select id="lg-type" class="px-4 py-2.5 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition">
          <option value="paragraphs">Paragraphs</option>
          <option value="sentences">Sentences</option>
          <option value="words">Words</option>
        </select>
      </div>
      <label class="flex items-center gap-2 cursor-pointer pb-0.5">
        <input id="lg-lorem" type="checkbox" checked class="w-4 h-4 accent-blue-600" />
        <span class="text-sm text-gray-700 dark:text-gray-300">Start with "Lorem ipsum"</span>
      </label>
      <button id="lg-gen" class="px-5 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition">Generate</button>
      <button id="lg-copy" class="px-5 py-2.5 bg-white dark:bg-slate-700 text-gray-700 dark:text-gray-200 text-sm font-medium rounded-lg border border-gray-300 dark:border-slate-600 hover:bg-gray-50 transition">Copy</button>
    </div>
    <textarea id="lg-out" class="w-full px-4 py-3 rounded-lg border border-gray-200 dark:border-slate-700 bg-gray-50 dark:bg-slate-800 text-gray-900 dark:text-gray-100 text-sm min-h-[300px] resize-y outline-none" readonly placeholder="Generated text..." spellcheck="false"></textarea>
  </div>

  <script is:inline>
    const W='lorem ipsum dolor sit amet consectetur adipiscing elit sed do eiusmod tempor incididunt ut labore et dolore magna aliqua ut enim ad minim veniam quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur excepteur sint occaecat cupidatat non proident sunt in culpa qui officia deserunt mollit anim id est laborum'.split(' ');
    const rw=()=>W[Math.floor(Math.random()*W.length)];
    const sentence=()=>{const n=Math.floor(Math.random()*12)+8;const w=Array.from({length:n},rw);w[0]=w[0][0].toUpperCase()+w[0].slice(1);return w.join(' ')+'.';};
    const paragraph=()=>Array.from({length:Math.floor(Math.random()*5)+3},sentence).join(' ');

    document.getElementById('lg-gen').addEventListener('click',()=>{
      const n=parseInt(document.getElementById('lg-count').value)||3;
      const t=document.getElementById('lg-type').value;
      const sl=document.getElementById('lg-lorem').checked;
      let r;
      if(t==='paragraphs'){r=Array.from({length:n},paragraph);if(sl&&r.length)r[0]='Lorem ipsum dolor sit amet, '+r[0].split('. ').slice(1).join('. ');r=r.join('\n\n');}
      else if(t==='sentences'){r=Array.from({length:n},sentence).join(' ');if(sl)r='Lorem ipsum dolor sit amet. '+r.split('. ').slice(1).join('. ');}
      else{r=Array.from({length:n},rw).join(' ');if(sl)r='Lorem ipsum '+r.split(' ').slice(2).join(' ');}
      document.getElementById('lg-out').value=r;
    });
    document.getElementById('lg-copy').addEventListener('click',()=>{const v=document.getElementById('lg-out').value;if(v)navigator.clipboard.writeText(v);});
  </script>
</ToolLayout>
