---
import Layout from '~/layouts/PageLayout.astro';
import { tools } from '~/utils/tools-data';

const textTools = tools.filter((tool) => tool.categorySlug === 'text');
const workflows = [
  {
    title: 'Clean and prepare copied text',
    description: 'Remove messy spacing, count text length, and normalize case before pasting into a CMS or document.',
    links: [
      { text: 'Whitespace Remover', href: '/tools/whitespace-remover/' },
      { text: 'Word Counter', href: '/tools/word-counter/' },
      { text: 'Case Converter', href: '/tools/case-converter/' },
    ],
  },
  {
    title: 'Review content before publishing',
    description: 'Compare drafts, check repeated terms, and prepare clean URL slugs for pages and articles.',
    links: [
      { text: 'Text Diff Checker', href: '/tools/text-diff/' },
      { text: 'Word Frequency Counter', href: '/tools/word-frequency-counter/' },
      { text: 'Slug Generator', href: '/tools/text-to-slug/' },
    ],
  },
  {
    title: 'Transform text for quick tasks',
    description: 'Reverse text, convert letter case, and clean stray whitespace for small everyday text edits.',
    links: [
      { text: 'Text Reverser', href: '/tools/text-reverser/' },
      { text: 'Case Converter', href: '/tools/case-converter/' },
      { text: 'Whitespace Remover', href: '/tools/whitespace-remover/' },
    ],
  },
];

const guideLinks = [
  {
    title: 'Word Counter Guide',
    href: '/blog/word-counter-guide/',
    description: 'Understand word count, character count, sentence count, paragraph count, and reading time.',
  },
  {
    title: 'Text Diff Checker Guide',
    href: '/blog/text-diff-checker-guide/',
    description: 'Compare drafts, snippets, and copied text without missing small changes.',
  },
  {
    title: 'Case Converter Guide',
    href: '/blog/case-converter-guide/',
    description: 'Choose between title case, sentence case, camelCase, snake_case, and kebab-case.',
  },
  {
    title: 'Slug Generator Guide',
    href: '/blog/slug-generator-guide/',
    description: 'Create readable, stable, SEO-friendly URL slugs from page titles and headings.',
  },
  {
    title: 'Whitespace Remover Guide',
    href: '/blog/whitespace-remover-guide/',
    description: 'Clean extra spaces, tabs, blank lines, and pasted formatting safely.',
  },
  {
    title: 'Word Frequency Counter Guide',
    href: '/blog/word-frequency-counter-guide/',
    description: 'Find repeated terms, filler words, and content patterns before publishing.',
  },
  {
    title: 'Text Reverser Guide',
    href: '/blog/text-reverser-guide/',
    description: 'Reverse characters, words, or lines safely for plain text transformations.',
  },
  {
    title: 'Markdown Preview Guide',
    href: '/blog/markdown-preview-guide-syntax-cheatsheet/',
    description: 'Write and preview Markdown before publishing technical documentation or help content.',
  },
  {
    title: 'Lorem Ipsum Generator Guide',
    href: '/blog/lorem-ipsum-generator-guide/',
    description: 'Use placeholder text responsibly while planning layouts and content length.',
  },
];

const checklist = [
  'Clean copied text before counting, comparing, or converting it.',
  'Check both word count and character count when writing for a platform limit.',
  'Use frequency analysis to find repeated terms before final editing.',
  'Compare the original and revised text before publishing important updates.',
  'Generate stable slugs before a page goes live, not after it is indexed.',
  'Review acronyms, names, and brand terms after automatic case conversion.',
];

const textUseCases = [
  {
    title: 'Publishing cleanup',
    description:
      'Clean whitespace, check length, generate slugs, and compare drafts before updating blog posts, docs, landing pages, or CMS entries.',
  },
  {
    title: 'Editorial review',
    description:
      'Use word frequency, diff checks, and word counts to catch repetition, accidental edits, and platform-specific length issues.',
  },
  {
    title: 'Developer text tasks',
    description:
      'Convert case, normalize copied strings, reverse quick samples, and prepare readable text before using it in code or test data.',
  },
];

const textMistakes = [
  'Counting text before cleaning pasted whitespace, which can make limits and reading-time estimates less useful.',
  'Changing title case automatically without reviewing acronyms, product names, or brand capitalization.',
  'Generating a slug after a page is already live, which can create avoidable redirect and indexing work.',
  'Comparing drafts visually instead of using a diff tool when small wording changes matter.',
];

const metadata = {
  title: 'Free Online Text Tools',
  description:
    'Use free online text tools to count words, format text, convert case, clean content, and improve everyday writing workflows directly in your browser.',
};

const canonical = 'https://quicktoolflow.com/tools/text/';

const faqItems = [
  {
    question: 'What are online text tools?',
    answer:
      'Online text tools are browser-based utilities that help you count, clean, compare, convert, and format text quickly without installing extra software.',
  },
  {
    question: 'Are QuickToolFlow text tools free?',
    answer: 'Yes. QuickToolFlow text tools are free to use and do not require sign-up.',
  },
  {
    question: 'Do these tools work in the browser?',
    answer: 'Yes. QuickToolFlow tools are designed for fast browser-based workflows.',
  },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://quicktoolflow.com/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Tools',
      item: 'https://quicktoolflow.com/tools/',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: 'Text Tools',
      item: canonical,
    },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-primary-600">Text Tools</p>

      <h1 class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-5xl">
        Free Online Text Tools
      </h1>

      <p class="mt-6 text-lg leading-8 text-gray-600 dark:text-gray-300">
        QuickToolFlow text tools help you count words, clean text, convert formats, and handle everyday writing tasks
        faster. All tools run directly in your browser and are designed for quick, simple workflows.
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        textTools.map((tool) => (
          <a
            href={`/tools/${tool.slug}/`}
            class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md dark:border-gray-700 dark:bg-gray-800"
          >
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white">{tool.name}</h2>

            <p class="mt-3 text-sm leading-6 text-gray-600 dark:text-gray-300">{tool.description}</p>

            <span class="mt-5 inline-flex text-sm font-semibold text-primary-600">Open tool</span>
          </a>
        ))
      }
    </div>

    <section
      class="mt-12 rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-700 dark:bg-gray-800"
    >
      <h2 class="text-xl font-bold text-gray-900 dark:text-white">Popular Text Workflows</h2>
      <div class="mt-4 grid gap-3 lg:grid-cols-3">
        {
          workflows.map((workflow) => (
            <div class="rounded-xl border border-gray-100 bg-gray-50 p-4 dark:border-gray-700 dark:bg-gray-900">
              <h3 class="text-sm font-semibold text-gray-900 dark:text-white">{workflow.title}</h3>
              <p class="mt-1 text-xs leading-5 text-gray-600 dark:text-gray-300">{workflow.description}</p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                {workflow.links.map((link) => (
                  <a
                    href={link.href}
                    class="rounded-full bg-white px-2.5 py-1 text-[11px] font-semibold text-gray-700 transition hover:bg-primary-50 hover:text-primary-700 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700"
                  >
                    {link.text}
                  </a>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section class="mt-16 grid gap-8 lg:grid-cols-[1fr_1fr]">
      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Text cleanup checklist</h2>
        <ol class="mt-5 space-y-4 text-sm leading-6 text-gray-600 dark:text-gray-300">
          {
            checklist.map((item, index) => (
              <li class="flex gap-3">
                <span class="font-bold text-primary-600">{index + 1}.</span>
                <span>{item}</span>
              </li>
            ))
          }
        </ol>
      </div>

      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-xl font-bold text-gray-900 dark:text-white">Helpful guides</h2>
          <a href="/blog/category/text-tools/" class="text-sm font-semibold text-primary-600 hover:text-primary-700"
            >More</a
          >
        </div>
        <div class="mt-4 grid gap-2">
          {
            guideLinks.slice(0, 6).map((guide) => (
              <a
                href={guide.href}
                class="rounded-lg border border-gray-100 bg-gray-50 px-3 py-2.5 transition hover:border-primary-200 hover:bg-primary-50 dark:border-gray-700 dark:bg-gray-900 dark:hover:bg-gray-800"
              >
                <h3 class="text-sm font-semibold text-gray-900 dark:text-white">{guide.title}</h3>
                <p class="mt-1 hidden text-xs leading-5 text-gray-600 dark:text-gray-300 sm:block">
                  {guide.description}
                </p>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mt-16 grid gap-8 lg:grid-cols-[1fr_1fr]">
      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Where text tools help most</h2>
        <div class="mt-5 grid gap-4">
          {
            textUseCases.map((item) => (
              <div class="rounded-xl border border-gray-100 bg-gray-50 p-4 dark:border-gray-700 dark:bg-gray-900">
                <h3 class="text-sm font-semibold text-gray-900 dark:text-white">{item.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600 dark:text-gray-300">{item.description}</p>
              </div>
            ))
          }
        </div>
      </div>

      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Common text workflow mistakes</h2>
        <ul class="mt-5 space-y-3">
          {
            textMistakes.map((item) => (
              <li class="rounded-xl border border-gray-100 bg-gray-50 p-4 text-sm leading-6 text-gray-600 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-300">
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <div class="prose prose-lg mx-auto mt-16 dark:prose-invert">
      <h2>Why use online text tools?</h2>
      <p>
        Text tools are useful when you need fast, simple, browser-based utilities for writing, editing, formatting, and
        checking content. Instead of opening a heavy editor or installing a separate app, you can complete common text
        tasks directly online.
      </p>

      <h2>What can you do with QuickToolFlow text tools?</h2>
      <p>
        Depending on the tool, you can count words and characters, prepare content for publishing, clean copied text,
        generate writing-friendly outputs, and improve productivity when working with documents, websites, social posts,
        or code-related content.
      </p>

      <h2>Are these text tools private?</h2>
      <p>
        QuickToolFlow is designed around fast browser-based tools. For many common utilities, your input is processed
        directly in the browser, which helps keep the workflow simple and privacy-friendly.
      </p>

      <h2>How to use text tools before publishing</h2>
      <p>
        A practical publishing workflow often starts with cleanup, then measurement, then review. Remove messy spacing
        first, check word and character counts, compare the revised draft with the original, then generate or verify the
        final slug. This order helps avoid counting formatting noise or publishing a changed URL by accident.
      </p>

      <h2>Text tools for writers and developers</h2>
      <p>
        Writers use these tools to prepare drafts, compare edits, and reduce repeated wording. Developers use them to
        normalize strings, convert case styles, prepare test content, and inspect copied text before it enters a
        codebase or data file.
      </p>
    </div>
  </section>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />
</Layout>
