---
import ToolLayout from '~/layouts/ToolLayout.astro';
import ToolActionButton from '~/components/ui/ToolActionButton.astro';
---

<ToolLayout
  title="Lorem Image Placeholder"
  description="Generate placeholder image URLs with custom dimensions for your designs, mockups, and prototypes."
  slug="lorem-image-placeholder"
  category="Generators"
  features={[
    'Generate placeholder image URLs with custom width and height',
    'Choose a background color with color picker or HEX input',
    'Live preview of the generated placeholder image',
    'Outputs image URL, HTML tag, Markdown, and CSS background snippets',
    'Useful for layouts, mockups, wireframes, and prototypes',
    'Copy any generated snippet with one click',
  ]}
  useCases={[
    'Reserve image space in a website layout before final assets are ready',
    'Create mock product cards, blog thumbnails, hero images, or gallery blocks',
    'Test responsive image dimensions in prototypes',
    'Share placeholder image snippets with designers or developers',
    'Build quick Markdown or HTML demos with predictable image sizes',
  ]}
  howToSteps={[
    'Enter the placeholder width and height in pixels.',
    'Choose a background color or type a HEX color value.',
    'Click Generate to update the preview and snippets.',
    'Copy the image URL, HTML tag, Markdown, or CSS background code.',
    'Replace the placeholder with a real optimized image before publishing.',
  ]}
  examples={[
    {
      title: 'Create a blog thumbnail placeholder',
      input: 'Width: 1200\nHeight: 630\nBackground: #cccccc',
      output:
        'https://placehold.co/1200x630/cccccc/white?text=1200x630\n<img src="..." alt="Placeholder 1200x630" width="1200" height="630" />',
      note: 'A 1200x630 placeholder is useful when planning social preview or blog card image areas.',
    },
  ]}
  tips={[
    'Use real images before production when the image conveys important product, place, or article meaning.',
    'Keep placeholder dimensions close to your final asset size to avoid layout shifts later.',
    'External placeholder URLs depend on the placeholder provider being available, so avoid relying on them for final live content.',
  ]}
  faq={[
    {
      question: 'What is a placeholder image?',
      answer:
        'A placeholder image is a temporary image used to reserve layout space while a design, prototype, or page is still being built.',
    },
    {
      question: 'Can I generate HTML and Markdown snippets?',
      answer:
        'Yes. The tool creates an image URL, HTML img tag, Markdown image syntax, and CSS background-image snippet.',
    },
    {
      question: 'Should I use placeholder images on a live website?',
      answer:
        'Usually no. Placeholder images are best for drafts and prototypes. Live pages should use real, relevant, optimized images.',
    },
    {
      question: 'Why does the preview use an external URL?',
      answer:
        'The generated placeholder uses placehold.co so you can copy a usable URL immediately. The rest of the tool still runs in your browser.',
    },
  ]}
>
  <div class="space-y-6">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Width (px)</label>
        <input
          id="lip-w"
          type="number"
          min="1"
          max="4000"
          value="800"
          class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Height (px)</label>
        <input
          id="lip-h"
          type="number"
          min="1"
          max="4000"
          value="400"
          class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
        />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Background Color</label>
        <div class="flex gap-2">
          <input
            id="lip-color"
            type="color"
            value="#cccccc"
            class="w-12 h-12 rounded-lg border border-gray-300 dark:border-slate-600 cursor-pointer"
          />
          <input
            id="lip-color-text"
            type="text"
            value="#cccccc"
            class="flex-1 px-4 py-3 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 font-mono text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
          />
        </div>
      </div>
    </div>

    <ToolActionButton id="lip-gen" variant="primary" icon="tabler:photo" class="w-full">Generate</ToolActionButton>
    <div id="lip-status" class="hidden rounded-lg px-4 py-3 text-sm font-medium"></div>

    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Preview</label>
      <div class="rounded-lg border border-gray-200 dark:border-slate-700 overflow-hidden">
        <img id="lip-preview" alt="Placeholder preview" class="w-full" style="max-height:400px; object-fit:contain;" />
      </div>
    </div>

    <div class="space-y-3">
      {
        [
          { id: 'lip-url-img', label: 'Image URL' },
          { id: 'lip-url-html', label: 'HTML Tag' },
          { id: 'lip-url-md', label: 'Markdown' },
          { id: 'lip-url-css', label: 'CSS Background' },
        ].map((item) => (
          <div>
            <div class="flex items-center justify-between mb-1">
              <label class="text-xs font-medium text-gray-500 uppercase">{item.label}</label>
              <ToolActionButton class="lip-copy min-h-0 px-3 py-1.5 text-xs" data-src={item.id} icon="tabler:copy">
                Copy
              </ToolActionButton>
            </div>
            <input
              id={item.id}
              type="text"
              class="w-full px-4 py-2 rounded-lg border border-gray-200 dark:border-slate-700 bg-gray-50 dark:bg-slate-800 text-gray-900 dark:text-gray-100 font-mono text-xs outline-none"
              readonly
            />
          </div>
        ))
      }
    </div>
  </div>
</ToolLayout>

<script>
  function initLoremImage() {
    const wEl = document.getElementById('lip-w') as HTMLInputElement;
    const hEl = document.getElementById('lip-h') as HTMLInputElement;
    const colorEl = document.getElementById('lip-color') as HTMLInputElement;
    const colorTextEl = document.getElementById('lip-color-text') as HTMLInputElement;
    const preview = document.getElementById('lip-preview') as HTMLImageElement;
    const btn = document.getElementById('lip-gen');
    const status = document.getElementById('lip-status');

    if (!wEl || !btn) return;

    function showStatus(message: string, error = false) {
      if (!status) return;
      status.textContent = message;
      status.className =
        'rounded-lg px-4 py-3 text-sm font-medium ' + (error ? 'bg-red-50 text-red-700' : 'bg-green-50 text-green-700');
      status.classList.remove('hidden');
    }

    colorEl?.addEventListener('input', () => {
      if (colorTextEl) colorTextEl.value = colorEl.value;
    });
    colorTextEl?.addEventListener('input', () => {
      if (colorEl) colorEl.value = colorTextEl.value;
    });

    function generate() {
      const w = parseInt(wEl.value) || 800;
      const h = parseInt(hEl.value) || 400;
      const bg = (colorTextEl?.value || '#cccccc').replace('#', '');
      if (w < 1 || w > 4000 || h < 1 || h > 4000) {
        showStatus('Width and height must be between 1 and 4000 pixels.', true);
        return;
      }
      if (!/^[0-9a-fA-F]{6}$/.test(bg)) {
        showStatus('Enter a valid 6-digit HEX color.', true);
        return;
      }
      const url = 'https://placehold.co/' + w + 'x' + h + '/' + bg + '/white?text=' + w + 'x' + h;

      if (preview) preview.src = url;

      const urlImg = document.getElementById('lip-url-img') as HTMLInputElement;
      const urlHtml = document.getElementById('lip-url-html') as HTMLInputElement;
      const urlMd = document.getElementById('lip-url-md') as HTMLInputElement;
      const urlCss = document.getElementById('lip-url-css') as HTMLInputElement;

      if (urlImg) urlImg.value = url;
      if (urlHtml)
        urlHtml.value =
          '<img src="' + url + '" alt="Placeholder ' + w + 'x' + h + '" width="' + w + '" height="' + h + '" />';
      if (urlMd) urlMd.value = '![Placeholder ' + w + 'x' + h + '](' + url + ')';
      if (urlCss) urlCss.value = "background-image: url('" + url + "');";
      showStatus('Placeholder image snippets generated.', false);
    }

    btn.addEventListener('click', generate);
    document.querySelectorAll('.lip-copy').forEach((b) => {
      b.addEventListener('click', () => {
        const src = (b as HTMLElement).dataset.src;
        const el = src ? (document.getElementById(src) as HTMLInputElement) : null;
        if (!el?.value) {
          showStatus('Generate snippets before copying.', true);
          return;
        }
        navigator.clipboard.writeText(el.value);
        showStatus('Snippet copied to clipboard.', false);
      });
    });

    generate();
  }

  initLoremImage();
  document.addEventListener('astro:page-load', initLoremImage);
  document.addEventListener('swup:contentReplaced', initLoremImage);
</script>
