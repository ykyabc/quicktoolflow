---
import ToolLayout from '~/layouts/ToolLayout.astro';
import ToolActionButton from '~/components/ui/ToolActionButton.astro';
---

<ToolLayout
  title="Password Generator"
  description="Generate strong, random, secure passwords with customizable length, uppercase, numbers, and symbols. Runs entirely in your browser."
  slug="password-generator"
  category="Generators"
  features={[
    'Uses the browser crypto API instead of Math.random',
    'Lets you control length from 4 to 128 characters',
    'Supports uppercase letters, lowercase letters, numbers, and symbols',
    'Guarantees at least one character from each selected character group',
    'Shows a simple entropy-based strength estimate',
    'Generates passwords locally without sending them to QuickToolFlow',
  ]}
  useCases={[
    'Creating unique passwords for new online accounts',
    'Generating temporary secrets for test environments',
    'Building random credentials for demos or documentation',
    'Replacing reused passwords with longer random ones',
  ]}
  howToSteps={[
    'Choose the password length with the slider.',
    'Select the character groups required by the website or system you are using.',
    'Click Generate Secure Password to create a new random value.',
    'Copy the password and save it in a trusted password manager.',
  ]}
  examples={[
    {
      title: 'Recommended everyday account password',
      input: 'Length: 20\nCharacter groups: uppercase, lowercase, numbers, symbols',
      output: 'A different random password is generated each time.',
      note: 'Long random passwords are usually easier to secure than short passwords with forced substitutions.',
    },
  ]}
  tips={[
    'A password generator helps most when every account gets a different password.',
    'Longer passwords usually matter more than visually complex but short passwords.',
    'QuickToolFlow does not store generated passwords. Save important passwords in a dedicated password manager before leaving the page.',
  ]}
  faq={[
    {
      question: 'Are generated passwords sent to a server?',
      answer:
        'No. Passwords are generated locally in your browser using the Web Crypto API. QuickToolFlow does not receive or store the generated value.',
    },
    {
      question: 'Why should I use a long random password?',
      answer:
        'Length increases the number of possible combinations. A long random password is typically stronger than a short password with predictable substitutions.',
    },
    {
      question: 'Should I memorize generated passwords?',
      answer:
        'For most accounts, it is better to store unique generated passwords in a trusted password manager instead of memorizing or reusing them.',
    },
    {
      question: 'What if a website does not allow symbols?',
      answer:
        'Turn off the symbols option and increase the password length if possible. A longer password using letters and numbers can still be strong.',
    },
  ]}
>
  <div class="space-y-6">
    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Generated Password</label>
      <div class="flex gap-2">
        <input
          id="pg-output"
          type="text"
          class="flex-1 px-4 py-3 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 font-mono text-lg tracking-wide focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
          readonly
          placeholder="Click Generate..."
        />
        <ToolActionButton id="pg-copy" icon="tabler:copy" title="Copy generated password">Copy</ToolActionButton>
      </div>
    </div>

    <div>
      <div class="flex justify-between mb-2">
        <span class="text-sm font-medium text-gray-700 dark:text-gray-300">Strength</span>
        <span id="pg-strength" class="text-sm font-medium text-gray-500">-</span>
      </div>
      <div class="h-2 bg-gray-200 dark:bg-slate-700 rounded-full overflow-hidden">
        <div id="pg-bar" class="h-full rounded-full transition-all duration-300 bg-gray-300" style="width:0%"></div>
      </div>
    </div>

    <div>
      <div class="flex justify-between mb-2">
        <label class="text-sm font-medium text-gray-700 dark:text-gray-300">Password Length</label>
        <span id="pg-len" class="text-sm font-mono font-bold text-blue-600">16</span>
      </div>
      <input id="pg-slider" type="range" min="4" max="128" value="16" class="w-full accent-blue-600" />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {
        [
          { id: 'pg-upper', label: 'Uppercase', sub: 'A-Z', checked: true },
          { id: 'pg-lower', label: 'Lowercase', sub: 'a-z', checked: true },
          { id: 'pg-digits', label: 'Numbers', sub: '0-9', checked: true },
          { id: 'pg-symbols', label: 'Symbols', sub: '!@#$%^&*', checked: true },
        ].map((opt) => (
          <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 dark:border-slate-700 hover:border-gray-300 dark:hover:border-slate-600 cursor-pointer transition">
            <input id={opt.id} type="checkbox" checked={opt.checked} class="w-4 h-4 accent-blue-600 rounded" />
            <div>
              <span class="text-sm font-medium text-gray-800 dark:text-gray-200">{opt.label}</span>
              <span class="block text-xs text-gray-500">{opt.sub}</span>
            </div>
          </label>
        ))
      }
    </div>

    <ToolActionButton id="pg-gen" variant="primary" icon="tabler:refresh" class="w-full py-3.5">
      Generate Secure Password
    </ToolActionButton>
  </div>

  <script is:inline>
    const out = document.getElementById('pg-output');
    const slider = document.getElementById('pg-slider');
    const lenLabel = document.getElementById('pg-len');
    const bar = document.getElementById('pg-bar');
    const strengthLabel = document.getElementById('pg-strength');

    const POOL = {
      upper: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
      lower: 'abcdefghijklmnopqrstuvwxyz',
      digits: '0123456789',
      symbols: '!@#$%^&*()_+-=[]{}|;:,.<>?',
    };

    function generate() {
      let pool = '';
      const required = [];
      ['upper', 'lower', 'digits', 'symbols'].forEach((key) => {
        if (document.getElementById('pg-' + (key === 'digits' ? 'digits' : key)).checked) {
          pool += POOL[key];
          required.push(POOL[key][Math.floor(Math.random() * POOL[key].length)]);
        }
      });
      if (!pool.length) {
        out.value = '';
        return;
      }

      const len = parseInt(slider.value);
      const arr = new Uint32Array(len);
      crypto.getRandomValues(arr);
      const pw = Array.from(arr, (v) => pool[v % pool.length]);
      required.forEach((c, i) => {
        if (i < pw.length) pw[i] = c;
      });
      for (let i = pw.length - 1; i > 0; i--) {
        const j = arr[i] % (i + 1);
        [pw[i], pw[j]] = [pw[j], pw[i]];
      }
      out.value = pw.join('');

      // Strength
      const entropy = len * Math.log2(pool.length);
      let lbl, color, width;
      if (entropy < 28) {
        lbl = 'Weak';
        color = '#ef4444';
        width = '25%';
      } else if (entropy < 36) {
        lbl = 'Fair';
        color = '#f97316';
        width = '50%';
      } else if (entropy < 60) {
        lbl = 'Strong';
        color = '#22c55e';
        width = '75%';
      } else {
        lbl = 'Very Strong';
        color = '#059669';
        width = '100%';
      }
      strengthLabel.textContent = lbl;
      bar.style.width = width;
      bar.style.background = color;
    }

    slider.addEventListener('input', () => {
      lenLabel.textContent = slider.value;
    });
    document.getElementById('pg-gen').addEventListener('click', generate);
    document.getElementById('pg-copy').addEventListener('click', () => {
      if (out.value) navigator.clipboard.writeText(out.value);
    });
    generate();
  </script>
</ToolLayout>
