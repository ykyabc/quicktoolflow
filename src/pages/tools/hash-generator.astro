---
import ToolLayout from '~/layouts/ToolLayout.astro';
import ToolActionBar from '~/components/ui/ToolActionBar.astro';
import ToolActionButton from '~/components/ui/ToolActionButton.astro';
---

<ToolLayout
  title="Hash Generator"
  description="Generate SHA-256, SHA-512, and SHA-1 hashes from any text using the Web Crypto API. Free online hash tool."
  slug="hash-generator"
  category="Developer Tools"
  features={[
    'Generates SHA-256, SHA-512, and SHA-1 hashes from text input',
    'Uses the browser Web Crypto API for fast local hashing',
    'Outputs lowercase hexadecimal hash strings',
    'One-click copy for each generated hash',
    'Useful for checksums, examples, fixtures, and debugging',
    'No text is uploaded to a server',
  ]}
  useCases={[
    'Create a SHA-256 hash for documentation or test data',
    'Compare whether two text inputs produce the same digest',
    'Generate sample hashes for tutorials, demos, and fixtures',
    'Inspect how small text changes produce very different hashes',
    'Create non-secret fingerprints for plain text snippets',
  ]}
  howToSteps={[
    'Enter the text you want to hash.',
    'Click Generate Hashes.',
    'Review the SHA-256, SHA-512, and SHA-1 outputs.',
    'Copy the hash value you need.',
  ]}
  examples={[
    {
      title: 'Hash a short string',
      input: 'hello',
      output: 'SHA-256: 2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824',
      note: 'The same input always produces the same hash for the same algorithm.',
    },
  ]}
  tips={[
    'SHA-1 is included for legacy comparison only. Prefer SHA-256 or SHA-512 for modern use cases.',
    'A hash is not encryption. You cannot decrypt a hash back into the original text.',
    'Do not use plain fast hashes for password storage. Real password storage needs a slow password hashing function with salt.',
  ]}
  faq={[
    {
      question: 'What is a hash generator?',
      answer:
        'A hash generator converts input text into a fixed-length digest using a hashing algorithm such as SHA-256 or SHA-512.',
    },
    {
      question: 'Can I decrypt a SHA hash?',
      answer:
        'No. Cryptographic hashes are one-way digests. You can compare hashes, but you cannot directly reverse a hash to recover the original input.',
    },
    {
      question: 'Which hash should I use?',
      answer:
        'For modern general-purpose checksums and fingerprints, SHA-256 is usually a good default. SHA-512 is also strong, while SHA-1 should be avoided for security-sensitive work.',
    },
    {
      question: 'Is hashing done privately?',
      answer:
        'Yes. Hashes are generated with the browser Web Crypto API and your input is not uploaded to QuickToolFlow servers.',
    },
  ]}
>
  <div class="space-y-6">
    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Input Text</label>
      <textarea
        id="hg-in"
        class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[120px] resize-y focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
        placeholder="Enter text to hash..."></textarea>
    </div>

    <ToolActionBar>
      <ToolActionButton id="hg-gen" variant="primary" icon="tabler:fingerprint">Generate Hashes</ToolActionButton>
    </ToolActionBar>

    <div class="space-y-4">
      {
        ['SHA-256', 'SHA-512', 'SHA-1'].map((algo) => (
          <div>
            <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1">
              {algo}
            </label>
            <div class="flex gap-2">
              <input
                id={`hg-${algo.toLowerCase().replace('-', '')}`}
                type="text"
                class="flex-1 px-4 py-2.5 rounded-lg border border-gray-200 dark:border-slate-700 bg-gray-50 dark:bg-slate-800 text-gray-900 dark:text-gray-100 font-mono text-sm outline-none"
                readonly
              />
              <ToolActionButton
                class="hg-copy"
                data-tgt={`hg-${algo.toLowerCase().replace('-', '')}`}
                icon="tabler:copy"
                title={`Copy ${algo} hash`}
              >
                Copy
              </ToolActionButton>
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <script is:inline>
    async function hash(alg, text) {
      const buf = await crypto.subtle.digest(alg, new TextEncoder().encode(text));
      return Array.from(new Uint8Array(buf))
        .map((b) => b.toString(16).padStart(2, '0'))
        .join('');
    }
    document.getElementById('hg-gen').addEventListener('click', async () => {
      const t = document.getElementById('hg-in').value;
      if (!t) return;
      document.getElementById('hg-sha256').value = await hash('SHA-256', t);
      document.getElementById('hg-sha512').value = await hash('SHA-512', t);
      document.getElementById('hg-sha1').value = await hash('SHA-1', t);
    });
    document.querySelectorAll('.hg-copy').forEach((b) =>
      b.addEventListener('click', () => {
        const el = document.getElementById(b.dataset.tgt);
        if (el.value) navigator.clipboard.writeText(el.value);
      })
    );
  </script>
</ToolLayout>
