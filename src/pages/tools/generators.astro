---
import Layout from '~/layouts/PageLayout.astro';
import { tools } from '~/utils/tools-data';

const categoryTools = tools.filter((tool) => tool.categorySlug === 'generator');
const workflows = [
  {
    title: 'Create secure account data',
    description: 'Generate strong passwords and UUIDs for accounts, tests, demos, and internal tools.',
    links: [
      { text: 'Password Generator', href: '/tools/password-generator/' },
      { text: 'UUID Generator', href: '/tools/uuid-generator/' },
      { text: 'Random Number Generator', href: '/tools/random-number-generator/' },
    ],
  },
  {
    title: 'Share links and contact details',
    description: 'Create QR codes for URLs, phone numbers, email addresses, WiFi credentials, and short text.',
    links: [
      { text: 'QR Code Generator', href: '/tools/qr-code-generator/' },
      { text: 'Slug Generator', href: '/tools/text-to-slug/' },
    ],
  },
  {
    title: 'Prepare design placeholders',
    description: 'Generate lorem ipsum text and placeholder image URLs for mockups, wireframes, and demos.',
    links: [
      { text: 'Lorem Ipsum', href: '/tools/lorem-ipsum/' },
      { text: 'Lorem Image Placeholder', href: '/tools/lorem-image-placeholder/' },
    ],
  },
];

const guideLinks = [
  {
    title: 'Random Number Generator Guide',
    href: '/blog/random-number-generator-guide/',
    description: 'Understand ranges, integer vs decimal output, testing use cases, and security boundaries.',
  },
  {
    title: 'Lorem Ipsum Generator Guide',
    href: '/blog/lorem-ipsum-generator-guide/',
    description: 'Use placeholder text well in wireframes, layouts, mockups, and content drafts.',
  },
  {
    title: 'Lorem Image Placeholder Guide',
    href: '/blog/lorem-image-placeholder-guide/',
    description: 'Generate image placeholder URLs with realistic dimensions and aspect ratios.',
  },
  {
    title: 'How to Create QR Codes',
    href: '/blog/how-to-create-qr-codes-guide/',
    description: 'Create QR codes for URLs, WiFi, contact details, and common sharing workflows.',
  },
  {
    title: 'QR Code Use Cases',
    href: '/blog/qr-code-use-cases-for-marketing-and-operations/',
    description: 'Plan QR codes for campaigns, print materials, asset labels, and field operations.',
  },
  {
    title: 'Password Entropy Explained',
    href: '/blog/password-entropy-explained/',
    description: 'Learn how length, randomness, and character pools affect password strength.',
  },
  {
    title: 'UUID Generator Guide',
    href: '/blog/uuid-generator-guide-for-developers/',
    description: 'Understand when UUIDs are useful for identifiers, databases, tests, and public IDs.',
  },
  {
    title: 'Random Test Data Guide',
    href: '/blog/random-test-data-generation-guide/',
    description: 'Generate realistic values for QA, demos, screenshots, and edge-case testing.',
  },
  {
    title: 'UUID vs Random String',
    href: '/blog/uuid-vs-random-string-guide/',
    description: 'Choose the right generated value for identifiers, secrets, public IDs, and tokens.',
  },
];

const checklist = [
  'Use password-specific generators for secrets, not casual random numbers.',
  'Generate UUIDs for public unique IDs when secrecy is not required.',
  'Choose placeholder text length based on the final layout, not arbitrary filler.',
  'Match placeholder image dimensions to the expected final asset ratio.',
  'Test QR code destinations before using them in print or public campaigns.',
  'Keep generated demo data clearly separate from production data.',
];

const generatorTypes = [
  {
    title: 'Security-sensitive output',
    description:
      'Use password tools for account credentials and review length, randomness, and storage. Do not use casual random numbers as secrets.',
  },
  {
    title: 'Identifiers and test data',
    description:
      'Use UUIDs, random values, and placeholders when you need stable examples for tests, demos, prototypes, or documentation.',
  },
  {
    title: 'Publishing and sharing assets',
    description:
      'Use QR codes, slugs, lorem text, and image placeholders when preparing pages, mockups, or printable materials.',
  },
];

const generatorRisks = [
  'A generated password is only useful if it is stored in a password manager and not shared in chat or screenshots.',
  'A UUID is unique enough for identifiers, but it should not be treated as a secret access token.',
  'A QR code should always be scanned and tested before it is printed or sent to customers.',
  'Placeholder text and images should be clearly replaced before publishing a final page.',
];

const metadata = {
  title: 'Free Online Generators',
  description:
    'Use free online generators to create passwords, UUIDs, QR codes, lorem ipsum text, random numbers, placeholder images, and more.',
};

const canonical = 'https://quicktoolflow.com/tools/generators/';

const faqItems = [
  {
    question: 'What are online generators?',
    answer:
      'Online generators are browser-based tools that create useful outputs such as passwords, UUIDs, QR codes, random numbers, placeholder text, and test data.',
  },
  {
    question: 'Are QuickToolFlow generators free?',
    answer: 'Yes. QuickToolFlow generators are free to use and do not require sign-up.',
  },
  {
    question: 'Can I use these generators for development and design?',
    answer:
      'Yes. These generators are useful for developers, designers, writers, testers, and anyone who needs quick reusable outputs.',
  },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://quicktoolflow.com/' },
    { '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://quicktoolflow.com/tools/' },
    { '@type': 'ListItem', position: 3, name: 'Generators', item: canonical },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-primary-600">Generators</p>

      <h1 class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-5xl">
        Free Online Generators
      </h1>

      <p class="mt-6 text-lg leading-8 text-gray-600 dark:text-gray-300">
        QuickToolFlow generators help you create passwords, UUIDs, QR codes, placeholder text, random numbers, and other
        useful outputs instantly in your browser.
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        categoryTools.map((tool) => (
          <a
            href={`/tools/${tool.slug}/`}
            class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md dark:border-gray-700 dark:bg-gray-800"
          >
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white">{tool.name}</h2>

            <p class="mt-3 text-sm leading-6 text-gray-600 dark:text-gray-300">{tool.description}</p>

            <span class="mt-5 inline-flex text-sm font-semibold text-primary-600">Open tool</span>
          </a>
        ))
      }
    </div>

    <section
      class="mt-12 rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-700 dark:bg-gray-800"
    >
      <h2 class="text-xl font-bold text-gray-900 dark:text-white">Popular Generator Workflows</h2>
      <div class="mt-4 grid gap-3 lg:grid-cols-3">
        {
          workflows.map((workflow) => (
            <div class="rounded-xl border border-gray-100 bg-gray-50 p-4 dark:border-gray-700 dark:bg-gray-900">
              <h3 class="text-sm font-semibold text-gray-900 dark:text-white">{workflow.title}</h3>
              <p class="mt-1 text-xs leading-5 text-gray-600 dark:text-gray-300">{workflow.description}</p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                {workflow.links.map((link) => (
                  <a
                    href={link.href}
                    class="rounded-full bg-white px-2.5 py-1 text-[11px] font-semibold text-gray-700 transition hover:bg-primary-50 hover:text-primary-700 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700"
                  >
                    {link.text}
                  </a>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section class="mt-16 grid gap-8 lg:grid-cols-[1fr_1fr]">
      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Generator checklist</h2>
        <ol class="mt-5 space-y-4 text-sm leading-6 text-gray-600 dark:text-gray-300">
          {
            checklist.map((item, index) => (
              <li class="flex gap-3">
                <span class="font-bold text-primary-600">{index + 1}.</span>
                <span>{item}</span>
              </li>
            ))
          }
        </ol>
      </div>

      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-xl font-bold text-gray-900 dark:text-white">Helpful guides</h2>
          <a href="/blog/category/generators/" class="text-sm font-semibold text-primary-600 hover:text-primary-700"
            >More</a
          >
        </div>
        <div class="mt-4 grid gap-2">
          {
            guideLinks.slice(0, 6).map((guide) => (
              <a
                href={guide.href}
                class="rounded-lg border border-gray-100 bg-gray-50 px-3 py-2.5 transition hover:border-primary-200 hover:bg-primary-50 dark:border-gray-700 dark:bg-gray-900 dark:hover:bg-gray-800"
              >
                <h3 class="text-sm font-semibold text-gray-900 dark:text-white">{guide.title}</h3>
                <p class="mt-1 hidden text-xs leading-5 text-gray-600 dark:text-gray-300 sm:block">
                  {guide.description}
                </p>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mt-16 grid gap-8 lg:grid-cols-[1fr_1fr]">
      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Pick the right generator</h2>
        <div class="mt-5 grid gap-4">
          {
            generatorTypes.map((item) => (
              <div class="rounded-xl border border-gray-100 bg-gray-50 p-4 dark:border-gray-700 dark:bg-gray-900">
                <h3 class="text-sm font-semibold text-gray-900 dark:text-white">{item.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600 dark:text-gray-300">{item.description}</p>
              </div>
            ))
          }
        </div>
      </div>

      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Review before using generated output</h2>
        <ul class="mt-5 space-y-3">
          {
            generatorRisks.map((item) => (
              <li class="rounded-xl border border-gray-100 bg-gray-50 p-4 text-sm leading-6 text-gray-600 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-300">
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <div class="prose prose-lg mx-auto mt-16 dark:prose-invert">
      <h2>Why use online generators?</h2>
      <p>
        Online generators are useful when you need quick, repeatable outputs for development, design, writing, testing,
        or everyday productivity. They help reduce manual work and make common tasks faster.
      </p>

      <h2>What can you generate with QuickToolFlow?</h2>
      <p>
        You can generate secure passwords, UUIDs, QR codes, lorem ipsum text, random numbers, placeholder image URLs,
        and other practical outputs for websites, apps, documents, and testing workflows.
      </p>

      <h2>Are these generators easy to use?</h2>
      <p>
        Yes. Each generator is designed to be simple, fast, and browser-based. You can adjust the options you need,
        generate the result, then copy or use it immediately.
      </p>

      <h2>When generated output needs extra review</h2>
      <p>
        Generated values are fast, but they are not automatically appropriate for every context. Passwords need secure
        storage, QR codes need device testing, IDs need collision and privacy considerations, and placeholder content
        needs to be replaced before a real launch. Treat generators as a starting point, then review the output against
        the workflow where it will be used.
      </p>

      <h2>Generators for prototypes, tests, and operations</h2>
      <p>
        Developers can use generated IDs, random numbers, and sample content for repeatable tests. Designers can use
        placeholder text and images for layout exploration. Operations and marketing teams can use QR codes and slugs
        for campaigns, print materials, and internal documentation.
      </p>
    </div>
  </section>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />
</Layout>
