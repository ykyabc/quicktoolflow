---
import ToolLayout from '~/layouts/ToolLayout.astro';
import ToolActionBar from '~/components/ui/ToolActionBar.astro';
import ToolActionButton from '~/components/ui/ToolActionButton.astro';
---

<ToolLayout
  title="URL Encoder & Decoder"
  description="Encode or decode URL strings using standard percent-encoding. Free online URL tool."
  slug="url-encoder"
  category="Developer Tools"
  features={[
    'Encodes text with standard URL percent-encoding',
    'Decodes percent-encoded URL strings back to readable text',
    'Shows clear errors for invalid encoded input',
    'Supports swap and copy actions for fast workflows',
    'Useful for query strings, redirect URLs, API parameters, and debugging',
    'Runs locally in your browser',
  ]}
  useCases={[
    'Encoding query parameter values that contain spaces or special characters',
    'Decoding copied URLs from logs, analytics, or browser redirects',
    'Preparing redirect URLs for OAuth, tracking, or testing flows',
    'Checking whether an API parameter has been encoded correctly',
  ]}
  howToSteps={[
    'Paste a URL or text value into the input field.',
    'Click Encode to percent-encode special characters.',
    'Click Decode to turn encoded text back into readable text.',
    'Use Swap or Copy Output to continue working with the result.',
  ]}
  examples={[
    {
      title: 'Encode a query value',
      input: 'hello world & tools',
      output: 'hello%20world%20%26%20tools',
      note: 'Spaces, ampersands, and other special characters must be encoded when used inside query values.',
    },
  ]}
  tips={[
    'encodeURIComponent is best for individual query parameter values.',
    'A full URL should not always be encoded as one string unless it is being nested inside another URL.',
    'If decoding fails, the input may contain an incomplete percent escape such as % without two hex digits.',
  ]}
  faq={[
    {
      question: 'What is URL encoding?',
      answer:
        'URL encoding replaces unsafe or reserved characters with percent-encoded sequences so they can safely appear in URLs.',
    },
    {
      question: 'Should I encode an entire URL?',
      answer:
        'Usually you encode individual parts such as query parameter values. Encode a full URL only when it is being passed as a value inside another URL.',
    },
    {
      question: 'Why does a space become %20?',
      answer: 'A raw space is not safe in URLs, so percent-encoding represents it as %20.',
    },
    {
      question: 'Is my URL sent anywhere?',
      answer: 'No. Encoding and decoding run locally in your browser.',
    },
  ]}
>
  <div class="space-y-6">
    <ToolActionBar>
      <ToolActionButton id="ue-enc" variant="primary" icon="tabler:link">Encode</ToolActionButton>
      <ToolActionButton id="ue-dec" icon="tabler:unlink">Decode</ToolActionButton>
      <ToolActionButton id="ue-swap" icon="tabler:arrows-exchange" title="Swap input and output">Swap</ToolActionButton>
      <ToolActionButton id="ue-copy" icon="tabler:copy">Copy Output</ToolActionButton>
    </ToolActionBar>

    <div id="ue-status" class="hidden rounded-lg px-4 py-3 text-sm font-medium"></div>

    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Input</label>
      <textarea
        id="ue-in"
        class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[150px] resize-y focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
        placeholder="https://example.com/path?name=hello world"
        spellcheck="false"></textarea>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Output</label>
      <textarea
        id="ue-out"
        class="w-full px-4 py-3 rounded-lg border border-gray-200 dark:border-slate-700 bg-gray-50 dark:bg-slate-800 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[150px] resize-y outline-none"
        readonly
        placeholder="Result will appear here..."
        spellcheck="false"></textarea>
    </div>
  </div>
</ToolLayout>

<script>
  function initUrlEncoder() {
    const input = document.getElementById('ue-in') as HTMLTextAreaElement;
    const output = document.getElementById('ue-out') as HTMLTextAreaElement;
    const status = document.getElementById('ue-status') as HTMLDivElement;
    const btnEnc = document.getElementById('ue-enc');
    const btnDec = document.getElementById('ue-dec');
    const btnSwap = document.getElementById('ue-swap');
    const btnCopy = document.getElementById('ue-copy');

    if (!input || !output || !btnEnc || !btnDec) return;

    function showStatus(msg: string, isError: boolean) {
      status.textContent = msg;
      status.className =
        'rounded-lg px-4 py-3 text-sm font-medium ' +
        (isError ? 'bg-red-50 text-red-700' : 'bg-green-50 text-green-700');
      status.classList.remove('hidden');
    }

    btnEnc.addEventListener('click', () => {
      if (!input.value.trim()) {
        showStatus('Please enter a URL or text to encode.', true);
        return;
      }
      try {
        output.value = encodeURIComponent(input.value);
        showStatus('Encoded successfully.', false);
      } catch (e) {
        showStatus('Encoding failed: ' + (e as Error).message, true);
      }
    });

    btnDec.addEventListener('click', () => {
      if (!input.value.trim()) {
        showStatus('Please enter an encoded string to decode.', true);
        return;
      }
      try {
        output.value = decodeURIComponent(input.value);
        showStatus('Decoded successfully.', false);
      } catch {
        showStatus('Decoding failed: invalid encoded string.', true);
      }
    });

    btnSwap?.addEventListener('click', () => {
      const temp = input.value;
      input.value = output.value;
      output.value = temp;
      status.classList.add('hidden');
    });

    btnCopy?.addEventListener('click', () => {
      if (output.value) {
        navigator.clipboard.writeText(output.value);
        showStatus('Copied to clipboard.', false);
      }
    });
  }

  initUrlEncoder();
  document.addEventListener('astro:page-load', initUrlEncoder);
  document.addEventListener('swup:contentReplaced', initUrlEncoder);
</script>
