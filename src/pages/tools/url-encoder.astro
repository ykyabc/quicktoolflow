---
import ToolLayout from '~/layouts/ToolLayout.astro';
---

<ToolLayout
  title="URL Encoder & Decoder"
  description="Encode or decode URL strings using standard percent-encoding. Free online URL tool."
  slug="url-encoder"
  category="Developer Tools"
>
  <div class="space-y-6">
    <div class="flex gap-2 flex-wrap">
      <button id="ue-enc" class="px-5 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition">Encode</button>
      <button id="ue-dec" class="px-5 py-2.5 bg-white dark:bg-slate-700 text-gray-700 dark:text-gray-200 text-sm font-medium rounded-lg border border-gray-300 dark:border-slate-600 hover:bg-gray-50 transition">Decode</button>
      <button id="ue-swap" class="px-4 py-2.5 bg-white dark:bg-slate-700 text-gray-700 dark:text-gray-200 text-sm font-medium rounded-lg border border-gray-300 dark:border-slate-600 hover:bg-gray-50 transition ml-auto" title="Swap">
        <astro-icon name="tabler:arrows-exchange" class="w-4 h-4" />
      </button>
      <button id="ue-copy" class="px-4 py-2.5 bg-white dark:bg-slate-700 text-gray-700 dark:text-gray-200 text-sm font-medium rounded-lg border border-gray-300 dark:border-slate-600 hover:bg-gray-50 transition">Copy Output</button>
    </div>

    <div id="ue-status" class="hidden rounded-lg px-4 py-3 text-sm font-medium"></div>

    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Input</label>
      <textarea id="ue-in" class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[150px] resize-y focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition" placeholder="https://example.com/path?name=hello world" spellcheck="false"></textarea>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Output</label>
      <textarea id="ue-out" class="w-full px-4 py-3 rounded-lg border border-gray-200 dark:border-slate-700 bg-gray-50 dark:bg-slate-800 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[150px] resize-y outline-none" readonly placeholder="Result will appear here..." spellcheck="false"></textarea>
    </div>
  </div>
</ToolLayout>

<script>
  function initUrlEncoder() {
    const input = document.getElementById('ue-in') as HTMLTextAreaElement;
    const output = document.getElementById('ue-out') as HTMLTextAreaElement;
    const status = document.getElementById('ue-status') as HTMLDivElement;
    const btnEnc = document.getElementById('ue-enc');
    const btnDec = document.getElementById('ue-dec');
    const btnSwap = document.getElementById('ue-swap');
    const btnCopy = document.getElementById('ue-copy');

    if (!input || !output || !btnEnc || !btnDec) return;

    function showStatus(msg: string, isError: boolean) {
      status.textContent = msg;
      status.className = 'rounded-lg px-4 py-3 text-sm font-medium ' + (isError ? 'bg-red-50 text-red-700' : 'bg-green-50 text-green-700');
      status.classList.remove('hidden');
    }

    btnEnc.addEventListener('click', () => {
      if (!input.value.trim()) {
        showStatus('Please enter a URL or text to encode.', true);
        return;
      }
      try {
        output.value = encodeURIComponent(input.value);
        showStatus('Encoded successfully.', false);
      } catch (e) {
        showStatus('Encoding failed: ' + (e as Error).message, true);
      }
    });

    btnDec.addEventListener('click', () => {
      if (!input.value.trim()) {
        showStatus('Please enter an encoded string to decode.', true);
        return;
      }
      try {
        output.value = decodeURIComponent(input.value);
        showStatus('Decoded successfully.', false);
      } catch (e) {
        showStatus('Decoding failed: invalid encoded string.', true);
      }
    });

    btnSwap?.addEventListener('click', () => {
      const temp = input.value;
      input.value = output.value;
      output.value = temp;
      status.classList.add('hidden');
    });

    btnCopy?.addEventListener('click', () => {
      if (output.value) {
        navigator.clipboard.writeText(output.value);
        showStatus('Copied to clipboard.', false);
      }
    });
  }

  initUrlEncoder();
  document.addEventListener('astro:page-load', initUrlEncoder);
  document.addEventListener('swup:contentReplaced', initUrlEncoder);
</script>
