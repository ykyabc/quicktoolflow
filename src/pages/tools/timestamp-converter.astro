---
import ToolLayout from '~/layouts/ToolLayout.astro';
import ToolActionButton from '~/components/ui/ToolActionButton.astro';
---

<ToolLayout
  title="Timestamp Converter"
  description="Convert between Unix timestamps and human-readable dates. Shows the current timestamp live."
  slug="timestamp-converter"
  category="Converters"
  features={[
    'Shows the current Unix timestamp live',
    'Converts Unix timestamps to UTC, local time, and relative time',
    'Converts local date and time values back to seconds and milliseconds',
    'Auto-detects common seconds vs milliseconds timestamp lengths',
    'Useful for API debugging, logs, cookies, databases, and scheduled jobs',
    'Runs locally in your browser',
  ]}
  useCases={[
    'Reading timestamp fields in API responses or database records',
    'Checking whether an event time is in seconds or milliseconds',
    'Converting log entries into readable local and UTC times',
    'Preparing Unix timestamp values for tests, docs, and scripts',
  ]}
  howToSteps={[
    'Use the live timestamp panel to see the current Unix time.',
    'Paste a seconds or milliseconds timestamp into the timestamp input.',
    'Convert it to view UTC, local, and relative time.',
    'Pick a local date and time to generate seconds and milliseconds values.',
  ]}
  examples={[
    {
      title: 'Seconds vs milliseconds',
      input: '1700000000\n1700000000000',
      output: '1700000000 is interpreted as seconds.\n1700000000000 is interpreted as milliseconds.',
      note: 'A 10-digit value is usually seconds. A 13-digit value is usually milliseconds.',
    },
  ]}
  tips={[
    'Unix timestamps represent a moment in UTC, not a timezone-specific calendar date.',
    'JavaScript Date.now() returns milliseconds, while many APIs and databases store seconds.',
    'When debugging time bugs, always confirm whether the source value is seconds or milliseconds.',
  ]}
  faq={[
    {
      question: 'What is a Unix timestamp?',
      answer: 'A Unix timestamp is the number of seconds since January 1, 1970 at 00:00:00 UTC.',
    },
    {
      question: 'Why are some timestamps 13 digits?',
      answer: 'Thirteen-digit timestamps are usually milliseconds. Ten-digit timestamps are usually seconds.',
    },
    {
      question: 'Does local time affect the timestamp?',
      answer:
        'The timestamp represents the same moment everywhere. Local time only changes how that moment is displayed.',
    },
    {
      question: 'Is conversion done online?',
      answer: 'The conversion runs locally in your browser.',
    },
  ]}
>
  <div class="space-y-6">
    <div class="p-4 bg-blue-50 dark:bg-blue-900/20 rounded-xl border border-blue-200 dark:border-blue-800">
      <div class="flex flex-wrap items-center justify-between gap-2">
        <div>
          <span class="text-xs font-medium text-blue-600 dark:text-blue-400 uppercase tracking-wider"
            >Current Unix Timestamp</span
          >
          <div id="ts-current" class="text-2xl font-bold text-blue-900 dark:text-blue-100 font-mono mt-1">-</div>
        </div>
        <div class="text-right">
          <span class="text-xs font-medium text-blue-600 dark:text-blue-400 uppercase tracking-wider">Current Date</span
          >
          <div id="ts-current-date" class="text-sm text-blue-800 dark:text-blue-200 mt-1">-</div>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div class="space-y-4">
        <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wider">
          Timestamp to Date
        </h3>
        <div>
          <label class="block text-sm text-gray-600 dark:text-gray-400 mb-1">Unix Timestamp</label>
          <input
            id="ts-input"
            type="text"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 font-mono text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
            placeholder="1700000000"
            value="1700000000"
          />
        </div>
        <ToolActionButton id="ts-to-date" variant="primary" icon="tabler:calendar-time" class="w-full">
          Convert to Date
        </ToolActionButton>
        <div class="space-y-2">
          <div class="p-3 bg-gray-50 dark:bg-slate-700 rounded-lg">
            <span class="text-xs text-gray-500 uppercase">UTC</span>
            <div id="ts-utc" class="text-sm font-mono text-gray-900 dark:text-white mt-1">-</div>
          </div>
          <div class="p-3 bg-gray-50 dark:bg-slate-700 rounded-lg">
            <span class="text-xs text-gray-500 uppercase">Local</span>
            <div id="ts-local" class="text-sm font-mono text-gray-900 dark:text-white mt-1">-</div>
          </div>
          <div class="p-3 bg-gray-50 dark:bg-slate-700 rounded-lg">
            <span class="text-xs text-gray-500 uppercase">Relative</span>
            <div id="ts-relative" class="text-sm font-mono text-gray-900 dark:text-white mt-1">-</div>
          </div>
        </div>
      </div>

      <div class="space-y-4">
        <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 uppercase tracking-wider">
          Date to Timestamp
        </h3>
        <div>
          <label class="block text-sm text-gray-600 dark:text-gray-400 mb-1">Date & Time</label>
          <input
            id="dt-input"
            type="datetime-local"
            class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 text-sm focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
          />
        </div>
        <ToolActionButton id="dt-to-ts" variant="primary" icon="tabler:clock-code" class="w-full">
          Convert to Timestamp
        </ToolActionButton>
        <div class="space-y-2">
          <div class="p-3 bg-gray-50 dark:bg-slate-700 rounded-lg">
            <span class="text-xs text-gray-500 uppercase">Seconds</span>
            <div id="dt-seconds" class="text-sm font-mono text-gray-900 dark:text-white mt-1">-</div>
          </div>
          <div class="p-3 bg-gray-50 dark:bg-slate-700 rounded-lg">
            <span class="text-xs text-gray-500 uppercase">Milliseconds</span>
            <div id="dt-millis" class="text-sm font-mono text-gray-900 dark:text-white mt-1">-</div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <script>
    function initTimestampConverter() {
      const currentEl = document.getElementById('ts-current');
      const currentDateEl = document.getElementById('ts-current-date');

      function updateCurrent() {
        const now = Math.floor(Date.now() / 1000);
        if (currentEl) currentEl.textContent = now.toString();
        if (currentDateEl) currentDateEl.textContent = new Date().toUTCString();
      }

      updateCurrent();
      setInterval(updateCurrent, 1000);

      const tsInput = document.getElementById('ts-input') as HTMLInputElement;
      const btnToDate = document.getElementById('ts-to-date');
      btnToDate?.addEventListener('click', () => {
        const val = parseInt(tsInput.value);
        if (isNaN(val)) return;
        const ms = val > 1e12 ? val : val * 1000;
        const d = new Date(ms);
        const utcEl = document.getElementById('ts-utc');
        const localEl = document.getElementById('ts-local');
        const relEl = document.getElementById('ts-relative');
        if (utcEl) utcEl.textContent = d.toUTCString();
        if (localEl) localEl.textContent = d.toLocaleString();
        if (relEl) {
          const diff = Date.now() - ms;
          const abs = Math.abs(diff);
          let rel: string;
          if (abs < 60000) rel = Math.floor(abs / 1000) + ' seconds ago';
          else if (abs < 3600000) rel = Math.floor(abs / 60000) + ' minutes ago';
          else if (abs < 86400000) rel = Math.floor(abs / 3600000) + ' hours ago';
          else rel = Math.floor(abs / 86400000) + ' days ago';
          if (diff < 0) rel = 'in ' + rel.replace(' ago', '');
          relEl.textContent = rel;
        }
      });

      const dtInput = document.getElementById('dt-input') as HTMLInputElement;
      if (dtInput) {
        const now = new Date();
        now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
        dtInput.value = now.toISOString().slice(0, 16);
      }

      const btnToTs = document.getElementById('dt-to-ts');
      btnToTs?.addEventListener('click', () => {
        const d = new Date(dtInput.value);
        if (isNaN(d.getTime())) return;
        const secsEl = document.getElementById('dt-seconds');
        const millisEl = document.getElementById('dt-millis');
        if (secsEl) secsEl.textContent = Math.floor(d.getTime() / 1000).toString();
        if (millisEl) millisEl.textContent = d.getTime().toString();
      });
    }

    initTimestampConverter();
    document.addEventListener('astro:page-load', initTimestampConverter);
    document.addEventListener('swup:contentReplaced', initTimestampConverter);
  </script>
</ToolLayout>
