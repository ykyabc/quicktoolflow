---
import Layout from '~/layouts/PageLayout.astro';
import { tools } from '~/utils/tools-data';

const categoryTools = tools.filter((tool) => tool.categorySlug === 'converter');

const metadata = {
  title: 'Free Online Converters | QuickToolFlow',
  description:
    'Use free online converters to convert timestamps, colors, CSS units, number bases, and other common formats directly in your browser.',
};
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-primary-600">
        Converters
      </p>

      <h1 class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-5xl">
        Free Online Converters
      </h1>

      <p class="mt-6 text-lg leading-8 text-gray-600 dark:text-gray-300">
        QuickToolFlow converters help you convert timestamps, color values, CSS
        units, number bases, and other common formats directly in your browser.
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {categoryTools.map((tool) => (
        <a
          href={`/tools/${tool.slug}/`}
          class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md dark:border-gray-700 dark:bg-gray-800"
        >
          <h2 class="text-xl font-semibold text-gray-900 dark:text-white">
            {tool.name}
          </h2>

          <p class="mt-3 text-sm leading-6 text-gray-600 dark:text-gray-300">
            {tool.description}
          </p>

          <span class="mt-5 inline-flex text-sm font-semibold text-primary-600">
            Open tool →
          </span>
        </a>
      ))}
    </div>

    <div class="prose prose-lg mx-auto mt-16 dark:prose-invert">
      <h2>Why use online converters?</h2>
      <p>
        Online converters help you quickly change values from one format to another
        without manual calculations or extra software. They are especially useful
        for development, design, debugging, and technical documentation.
      </p>

      <h2>What formats can you convert?</h2>
      <p>
        QuickToolFlow includes converters for timestamps, colors, CSS units, number
        bases, and other practical formats used in websites, applications, design
        systems, and everyday technical tasks.
      </p>

      <h2>When should you use these converters?</h2>
      <p>
        Use these tools when you need an accurate result quickly, such as converting
        a Unix timestamp to a readable date, switching between HEX and RGB colors,
        or converting binary, decimal, and hexadecimal numbers.
      </p>
    </div>
  </section>
</Layout>