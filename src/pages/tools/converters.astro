---
import Layout from '~/layouts/PageLayout.astro';
import { tools } from '~/utils/tools-data';

const categoryTools = tools.filter((tool) => tool.categorySlug === 'converter');
const workflows = [
  {
    title: 'Work with web design values',
    description: 'Convert colors and CSS units while building layouts, themes, and responsive interfaces.',
    links: [
      { text: 'Design & Frontend Toolkit', href: '/tools/frontend-design/' },
      { text: 'Color Converter', href: '/tools/color-converter/' },
      { text: 'CSS Unit Converter', href: '/tools/css-unit-converter/' },
    ],
  },
  {
    title: 'Translate technical values',
    description: 'Convert Unix timestamps and number bases while debugging APIs, logs, and low-level data.',
    links: [
      { text: 'Timestamp Converter', href: '/tools/timestamp-converter/' },
      { text: 'Timestamp Batch Converter', href: '/tools/timestamp-batch-converter/' },
      { text: 'Number Base Converter', href: '/tools/number-base-converter/' },
    ],
  },
  {
    title: 'Move structured data between formats',
    description: 'Format JSON first, then convert it to spreadsheet-friendly CSV or configuration-friendly YAML.',
    links: [
      { text: 'JSON Formatter', href: '/tools/json-formatter/' },
      { text: 'JSON to CSV', href: '/tools/json-to-csv/' },
      { text: 'JSON to YAML', href: '/tools/json-to-yaml/' },
    ],
  },
];

const guideLinks = [
  {
    title: 'Number Base Converter Guide',
    href: '/blog/number-base-converter-guide/',
    description: 'Learn how binary, decimal, hexadecimal, and octal work in technical workflows.',
  },
  {
    title: 'Unix Timestamp Explained',
    href: '/blog/unix-timestamp-explained-guide/',
    description: 'Understand epoch time and convert Unix timestamps into readable dates.',
  },
  {
    title: 'Timestamp Batch Converter Guide',
    href: '/blog/timestamp-batch-converter-guide/',
    description: 'Convert many timestamps at once and detect seconds, milliseconds, and date strings.',
  },
  {
    title: 'Color Conversion Guide',
    href: '/blog/color-conversion-guide-for-web-designers/',
    description: 'Compare HEX, RGB, HSL, and practical color conversion use cases for web design.',
  },
  {
    title: 'CSS Units Guide',
    href: '/blog/css-units-guide-px-em-rem-vw-vh/',
    description: 'Understand px, em, rem, vw, vh, and when to use each CSS unit.',
  },
  {
    title: 'JSON to CSV Conversion Guide',
    href: '/blog/json-to-csv-conversion-guide/',
    description: 'Move structured API data into spreadsheet-friendly CSV output.',
  },
  {
    title: 'JSON to YAML Conversion Guide',
    href: '/blog/json-to-yaml-conversion-guide/',
    description: 'Convert JSON into YAML for configuration and documentation workflows.',
  },
];

const checklist = [
  'Confirm the source format before converting a value.',
  'Keep labels or prefixes such as hex, decimal, seconds, and milliseconds visible.',
  'Use design-specific converters for colors and CSS units.',
  'Validate structured data before converting it to CSV or YAML.',
  'Document converted values when sharing examples or technical notes.',
  'Double-check time zones when converting human-readable dates and timestamps.',
];

const decisionCards = [
  {
    title: 'Human-readable values',
    description:
      'Use timestamp, color, and CSS unit converters when you need to translate technical values into something easier to review or share.',
  },
  {
    title: 'Machine-readable formats',
    description:
      'Use JSON, CSV, and YAML conversion workflows when data needs to move between APIs, spreadsheets, configuration files, or documentation.',
  },
  {
    title: 'Debugging numeric data',
    description:
      'Use number base conversion when logs, identifiers, permissions, colors, or low-level values appear in binary, decimal, or hexadecimal form.',
  },
];

const conversionRisks = [
  'A converted timestamp can be technically correct but still shown in the wrong time zone for the reader.',
  'A color conversion can lose context if opacity, contrast, or design-token naming is not reviewed.',
  'A CSV conversion can flatten nested data in a way that is useful for spreadsheets but incomplete for APIs.',
  'A number base conversion can be misleading if the original value includes prefixes, padding, or signed integer rules.',
];

const metadata = {
  title: 'Free Online Converters',
  description:
    'Use free online converters to convert timestamps, colors, CSS units, number bases, and other common formats directly in your browser.',
};

const canonical = 'https://quicktoolflow.com/tools/converters/';

const faqItems = [
  {
    question: 'What are online converters?',
    answer:
      'Online converters are browser-based tools that help you convert values, formats, units, timestamps, colors, and number bases quickly.',
  },
  {
    question: 'Are QuickToolFlow converters free?',
    answer: 'Yes. QuickToolFlow converters are free to use and do not require sign-up.',
  },
  {
    question: 'When should I use an online converter?',
    answer:
      'Use an online converter when you need a fast and accurate conversion without installing extra software or doing manual calculations.',
  },
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://quicktoolflow.com/' },
    { '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://quicktoolflow.com/tools/' },
    { '@type': 'ListItem', position: 3, name: 'Converters', item: canonical },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-primary-600">Converters</p>

      <h1 class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-5xl">
        Free Online Converters
      </h1>

      <p class="mt-6 text-lg leading-8 text-gray-600 dark:text-gray-300">
        QuickToolFlow converters help you convert timestamps, color values, CSS units, number bases, and other common
        formats directly in your browser.
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        categoryTools.map((tool) => (
          <a
            href={`/tools/${tool.slug}/`}
            class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md dark:border-gray-700 dark:bg-gray-800"
          >
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white">{tool.name}</h2>

            <p class="mt-3 text-sm leading-6 text-gray-600 dark:text-gray-300">{tool.description}</p>

            <span class="mt-5 inline-flex text-sm font-semibold text-primary-600">Open tool</span>
          </a>
        ))
      }
    </div>

    <section
      class="mt-12 rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-700 dark:bg-gray-800"
    >
      <h2 class="text-xl font-bold text-gray-900 dark:text-white">Popular Conversion Workflows</h2>
      <div class="mt-4 grid gap-3 lg:grid-cols-3">
        {
          workflows.map((workflow) => (
            <div class="rounded-xl border border-gray-100 bg-gray-50 p-4 dark:border-gray-700 dark:bg-gray-900">
              <h3 class="text-sm font-semibold text-gray-900 dark:text-white">{workflow.title}</h3>
              <p class="mt-1 text-xs leading-5 text-gray-600 dark:text-gray-300">{workflow.description}</p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                {workflow.links.map((link) => (
                  <a
                    href={link.href}
                    class="rounded-full bg-white px-2.5 py-1 text-[11px] font-semibold text-gray-700 transition hover:bg-primary-50 hover:text-primary-700 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700"
                  >
                    {link.text}
                  </a>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section class="mt-16 grid gap-8 lg:grid-cols-[1fr_1fr]">
      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Conversion checklist</h2>
        <ol class="mt-5 space-y-4 text-sm leading-6 text-gray-600 dark:text-gray-300">
          {
            checklist.map((item, index) => (
              <li class="flex gap-3">
                <span class="font-bold text-primary-600">{index + 1}.</span>
                <span>{item}</span>
              </li>
            ))
          }
        </ol>
      </div>

      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
        <div class="flex items-center justify-between gap-3">
          <h2 class="text-xl font-bold text-gray-900 dark:text-white">Helpful guides</h2>
          <a href="/blog/category/converters/" class="text-sm font-semibold text-primary-600 hover:text-primary-700"
            >More</a
          >
        </div>
        <div class="mt-4 grid gap-2">
          {
            guideLinks.slice(0, 6).map((guide) => (
              <a
                href={guide.href}
                class="rounded-lg border border-gray-100 bg-gray-50 px-3 py-2.5 transition hover:border-primary-200 hover:bg-primary-50 dark:border-gray-700 dark:bg-gray-900 dark:hover:bg-gray-800"
              >
                <h3 class="text-sm font-semibold text-gray-900 dark:text-white">{guide.title}</h3>
                <p class="mt-1 hidden text-xs leading-5 text-gray-600 dark:text-gray-300 sm:block">
                  {guide.description}
                </p>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="mt-16 grid gap-8 lg:grid-cols-[0.95fr_1.05fr]">
      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Choose the right converter</h2>
        <div class="mt-5 grid gap-4">
          {
            decisionCards.map((card) => (
              <div class="rounded-xl border border-gray-100 bg-gray-50 p-4 dark:border-gray-700 dark:bg-gray-900">
                <h3 class="text-sm font-semibold text-gray-900 dark:text-white">{card.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600 dark:text-gray-300">{card.description}</p>
              </div>
            ))
          }
        </div>
      </div>

      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Conversion risks to check</h2>
        <ul class="mt-5 grid gap-3 sm:grid-cols-2">
          {
            conversionRisks.map((item) => (
              <li class="rounded-xl border border-gray-100 bg-gray-50 p-4 text-sm leading-6 text-gray-600 dark:border-gray-700 dark:bg-gray-900 dark:text-gray-300">
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <div class="prose prose-lg mx-auto mt-16 dark:prose-invert">
      <h2>Why use online converters?</h2>
      <p>
        Online converters help you quickly change values from one format to another without manual calculations or extra
        software. They are especially useful for development, design, debugging, and technical documentation.
      </p>

      <h2>What formats can you convert?</h2>
      <p>
        QuickToolFlow includes converters for timestamps, batch timestamp values, colors, CSS units, number bases, and
        other practical formats used in websites, applications, design systems, and everyday technical tasks.
      </p>

      <h2>When should you use these converters?</h2>
      <p>
        Use these tools when you need an accurate result quickly, such as converting a Unix timestamp to a readable
        date, switching between HEX and RGB colors, or converting binary, decimal, and hexadecimal numbers.
      </p>

      <h2>What to check after converting a value</h2>
      <p>
        A converter gives you a transformed value, but the surrounding context still matters. Before pasting the result
        into code, documentation, a spreadsheet, or a design system, check the expected unit, time zone, color model,
        delimiter, and data shape. Small context mismatches are the most common reason a correct conversion becomes an
        incorrect implementation.
      </p>

      <h2>Converters for developers and content teams</h2>
      <p>
        Developers often use converters while debugging APIs, logs, identifiers, and configuration values. Content and
        design teams use them to prepare readable dates, colors, CSS units, and spreadsheet-friendly data. Keeping these
        workflows together makes it easier to move from inspection to cleanup without switching tools.
      </p>
    </div>
  </section>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />
</Layout>
