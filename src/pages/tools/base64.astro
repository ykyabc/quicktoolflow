---
import ToolLayout from '~/layouts/ToolLayout.astro';
import ToolActionBar from '~/components/ui/ToolActionBar.astro';
import ToolActionButton from '~/components/ui/ToolActionButton.astro';
---

<ToolLayout
  title="Base64 Encoder & Decoder"
  description="Encode text to Base64 or decode Base64 strings back to readable text. Free, instant, and private."
  slug="base64"
  category="Developer Tools"
  features={[
    'Encodes Unicode text to Base64 safely',
    'Decodes Base64 strings back to readable text',
    'Uses modern TextEncoder and TextDecoder APIs',
    'Shows clear errors for invalid Base64 input',
    'Supports quick swap between input and output',
    'Processes data locally in your browser',
  ]}
  useCases={[
    'Encoding small text snippets for API examples or configuration values',
    'Decoding Base64 text found in logs, tokens, or data URLs',
    'Checking whether copied Base64 content decodes to readable text',
    'Preparing simple examples for documentation and tests',
    'Inspecting the encoded header or payload section of JWT-like tokens',
    'Testing whether a value is Base64 text or another encoded representation',
  ]}
  howToSteps={[
    'Paste plain text or a Base64 string into the input field.',
    'Click Encode to convert text to Base64, or Decode to convert Base64 back to text.',
    'Use Swap when you want to run the opposite conversion on the result.',
    'Copy the output when the result looks correct.',
  ]}
  examples={[
    {
      title: 'Encode a short text value',
      input: 'QuickToolFlow',
      output: 'UXVpY2tUb29sRmxvdw==',
      note: 'Base64 is often used when text needs to travel through systems that expect plain ASCII characters.',
    },
    {
      title: 'Decode an encoded message',
      input: 'SGVsbG8sIFF1aWNrVG9vbEZsb3ch',
      output: 'Hello, QuickToolFlow!',
      note: 'Decoding is useful when logs, examples, or configuration values contain Base64 text that should be human-readable.',
    },
    {
      title: 'Recognize a data URL prefix',
      input: 'data:text/plain;base64,SGVsbG8=',
      output: 'Decode only the Base64 part: SGVsbG8=',
      note: 'If a value starts with a data URL prefix, remove the metadata prefix before decoding the Base64 payload.',
    },
  ]}
  tips={[
    'Base64 is encoding, not encryption. Anyone can decode it without a password or secret key.',
    'Base64 output is usually larger than the original text because it represents binary-safe data as text.',
    'If decoding fails, check for missing padding characters, copied whitespace, or characters that are not part of the Base64 alphabet.',
    'JWTs use Base64Url, which replaces some characters and often omits padding. Decode JWTs with a JWT-specific tool when possible.',
    'Do not store passwords, API keys, or private tokens in Base64 and treat them as protected. Base64 can be reversed immediately.',
  ]}
  faq={[
    {
      question: 'Is Base64 secure?',
      answer:
        'No. Base64 is not encryption and should not be used to hide secrets. It only changes how data is represented.',
    },
    {
      question: 'Why does Base64 sometimes end with equals signs?',
      answer:
        'The equals signs are padding characters. They help align the encoded output to the correct byte boundary.',
    },
    {
      question: 'Can this encode non-English text?',
      answer:
        'Yes. This tool uses UTF-8 encoding through TextEncoder and TextDecoder, so Unicode text is handled correctly.',
    },
    {
      question: 'Is my input uploaded when I encode or decode?',
      answer:
        'No. The conversion runs locally in your browser. QuickToolFlow does not receive the text you paste into this tool.',
    },
    {
      question: 'What is the difference between Base64 and Base64Url?',
      answer:
        'Base64Url is a URL-safe variant often used in JWTs and web tokens. It replaces plus and slash characters with URL-safe alternatives and may omit padding.',
    },
    {
      question: 'Why does decoded output look unreadable?',
      answer:
        'The original data may be binary, compressed, encrypted, or not actually Base64 text. Base64 decoding only reverses the representation; it does not decrypt or decompress content.',
    },
  ]}
>
  <div class="space-y-6">
    <ToolActionBar>
      <ToolActionButton id="b64-enc" variant="primary" icon="tabler:lock-open">Encode</ToolActionButton>
      <ToolActionButton id="b64-dec" icon="tabler:lock-open-2">Decode</ToolActionButton>
      <ToolActionButton id="b64-swap" icon="tabler:arrows-exchange" title="Swap input and output">Swap</ToolActionButton
      >
      <ToolActionButton id="b64-sample" icon="tabler:file-code">Load Sample</ToolActionButton>
      <ToolActionButton id="b64-copy" icon="tabler:copy">Copy Output</ToolActionButton>
    </ToolActionBar>
    <div id="b64-status" class="hidden rounded-lg px-4 py-3 text-sm font-medium"></div>

    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Input</label>
      <textarea
        id="b64-in"
        class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[180px] resize-y focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
        placeholder="Enter text or Base64..."
        spellcheck="false"></textarea>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Output</label>
      <textarea
        id="b64-out"
        class="w-full px-4 py-3 rounded-lg border border-gray-200 dark:border-slate-700 bg-gray-50 dark:bg-slate-800 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[180px] resize-y outline-none"
        readonly
        placeholder="Result..."
        spellcheck="false"></textarea>
    </div>
  </div>

  <script is:inline>
    const i = document.getElementById('b64-in'),
      o = document.getElementById('b64-out'),
      s = document.getElementById('b64-status');

    function bytesToBase64(bytes) {
      let binary = '';
      const chunkSize = 0x8000;
      for (let index = 0; index < bytes.length; index += chunkSize) {
        const chunk = bytes.subarray(index, index + chunkSize);
        binary += String.fromCharCode.apply(null, chunk);
      }
      return btoa(binary);
    }

    function base64ToBytes(value) {
      const binary = atob(value.replace(/\s+/g, ''));
      const bytes = new Uint8Array(binary.length);
      for (let index = 0; index < binary.length; index++) {
        bytes[index] = binary.charCodeAt(index);
      }
      return bytes;
    }

    function show(m, e) {
      s.textContent = m;
      s.className = `rounded-lg px-4 py-3 text-sm font-medium ${e ? 'bg-red-50 text-red-700' : 'bg-green-50 text-green-700'}`;
      s.classList.remove('hidden');
    }
    document.getElementById('b64-enc').addEventListener('click', () => {
      try {
        if (!i.value.trim()) {
          show('Enter text to encode first.', true);
          return;
        }
        o.value = bytesToBase64(new TextEncoder().encode(i.value));
        show('Encoded successfully.', false);
      } catch (e) {
        show('Encoding failed: ' + e.message, true);
      }
    });
    document.getElementById('b64-dec').addEventListener('click', () => {
      try {
        if (!i.value.trim()) {
          show('Enter Base64 text to decode first.', true);
          return;
        }
        o.value = new TextDecoder('utf-8', { fatal: true }).decode(base64ToBytes(i.value));
        show('Decoded successfully.', false);
      } catch {
        show('Invalid Base64 or invalid UTF-8 text.', true);
      }
    });
    document.getElementById('b64-swap').addEventListener('click', () => {
      [i.value, o.value] = [o.value, i.value];
      s.classList.add('hidden');
    });
    document.getElementById('b64-sample').addEventListener('click', () => {
      i.value = 'QuickToolFlow';
      o.value = '';
      show('Sample text loaded. Click Encode to convert it to Base64.', false);
    });
    document.getElementById('b64-copy').addEventListener('click', () => {
      if (!o.value) {
        show('There is no output to copy yet.', true);
        return;
      }
      navigator.clipboard.writeText(o.value);
      show('Output copied to clipboard.', false);
    });
  </script>
</ToolLayout>
