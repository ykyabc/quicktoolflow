---
import ToolLayout from '~/layouts/ToolLayout.astro';
---

<ToolLayout
  title="Base64 Encoder & Decoder"
  description="Encode text to Base64 or decode Base64 strings back to readable text. Free, instant, and private."
  slug="base64"
  category="Developer Tools"
>
  <div class="space-y-6">
    <div class="flex gap-2 flex-wrap">
      <button id="b64-enc" class="px-5 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition">Encode →</button>
      <button id="b64-dec" class="px-5 py-2.5 bg-white dark:bg-slate-700 text-gray-700 dark:text-gray-200 text-sm font-medium rounded-lg border border-gray-300 dark:border-slate-600 hover:bg-gray-50 transition">← Decode</button>
      <button id="b64-swap" class="px-4 py-2.5 bg-white dark:bg-slate-700 text-gray-700 dark:text-gray-200 text-sm font-medium rounded-lg border border-gray-300 dark:border-slate-600 hover:bg-gray-50 transition ml-auto" title="Swap">
        <astro-icon name="tabler:arrows-exchange" class="w-4 h-4" />
      </button>
      <button id="b64-copy" class="px-4 py-2.5 bg-white dark:bg-slate-700 text-gray-700 dark:text-gray-200 text-sm font-medium rounded-lg border border-gray-300 dark:border-slate-600 hover:bg-gray-50 transition">Copy Output</button>
    </div>

    <div id="b64-status" class="hidden rounded-lg px-4 py-3 text-sm font-medium"></div>

    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Input</label>
      <textarea id="b64-in" class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[180px] resize-y focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition" placeholder="Enter text or Base64..." spellcheck="false"></textarea>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Output</label>
      <textarea id="b64-out" class="w-full px-4 py-3 rounded-lg border border-gray-200 dark:border-slate-700 bg-gray-50 dark:bg-slate-800 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[180px] resize-y outline-none" readonly placeholder="Result..." spellcheck="false"></textarea>
    </div>
  </div>

  <script is:inline>
    const i = document.getElementById('b64-in'), o = document.getElementById('b64-out'), s = document.getElementById('b64-status');
    function show(m, e) { s.textContent = m; s.className = `rounded-lg px-4 py-3 text-sm font-medium ${e ? 'bg-red-50 text-red-700' : 'bg-green-50 text-green-700'}`; s.classList.remove('hidden'); }
    document.getElementById('b64-enc').addEventListener('click', () => { try { o.value = btoa(unescape(encodeURIComponent(i.value))); show('✓ Encoded.', false); } catch(e) { show('✗ '+e.message, true); } });
    document.getElementById('b64-dec').addEventListener('click', () => { try { o.value = decodeURIComponent(escape(atob(i.value))); show('✓ Decoded.', false); } catch(e) { show('✗ Invalid Base64.', true); } });
    document.getElementById('b64-swap').addEventListener('click', () => { [i.value, o.value] = [o.value, i.value]; s.classList.add('hidden'); });
    document.getElementById('b64-copy').addEventListener('click', () => { if (o.value) navigator.clipboard.writeText(o.value); });
  </script>
</ToolLayout>
