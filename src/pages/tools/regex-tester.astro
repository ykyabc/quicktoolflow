---
import ToolLayout from '~/layouts/ToolLayout.astro';
---

<ToolLayout
  title="Regex Tester"
  description="Test and debug regular expressions with real-time matching, highlighting, and capture group details."
  slug="regex-tester"
  category="Developer Tools"
>
  <div class="space-y-6">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
      <div class="sm:col-span-2">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Regular Expression</label>
        <div class="flex items-center gap-0 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 focus-within:ring-2 focus-within:ring-blue-500 transition overflow-hidden">
          <span class="px-3 text-gray-400 font-mono text-sm select-none">/</span>
          <input id="rx-pattern" type="text" class="flex-1 py-3 bg-transparent text-gray-900 dark:text-gray-100 font-mono text-sm outline-none" placeholder="[a-z]+@[a-z]+\.[a-z]+" value="[a-z]+@[a-z]+\.[a-z]+" />
          <span class="pr-3 text-gray-400 font-mono text-sm select-none">/</span>
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Flags</label>
        <input id="rx-flags" type="text" class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 font-mono text-sm outline-none focus:ring-2 focus:ring-blue-500 transition" value="gi" placeholder="gi" />
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Test String</label>
      <textarea id="rx-text" class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[150px] resize-y focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition" placeholder="Enter text to test against...">Contact us at hello@quicktoolflow.com or support@example.org for help.</textarea>
    </div>

    <div id="rx-error" class="hidden rounded-lg px-4 py-3 text-sm font-medium bg-red-50 text-red-700 border border-red-200"></div>

    <div>
      <div class="flex items-center justify-between mb-2">
        <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300">Highlighted Matches</h3>
        <span id="rx-count" class="text-xs text-gray-500 dark:text-gray-400">0 matches</span>
      </div>
      <div id="rx-highlighted" class="w-full px-4 py-3 rounded-lg border border-gray-200 dark:border-slate-700 bg-gray-50 dark:bg-slate-800 font-mono text-sm min-h-[80px] leading-relaxed break-all"></div>
    </div>

    <div>
      <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Match Details</h3>
      <div id="rx-matches" class="space-y-2 max-h-[300px] overflow-y-auto"></div>
    </div>
  </div>
</ToolLayout>

<script>
  function initRegexTester() {
    const patternEl = document.getElementById('rx-pattern') as HTMLInputElement;
    const flagsEl = document.getElementById('rx-flags') as HTMLInputElement;
    const textEl = document.getElementById('rx-text') as HTMLTextAreaElement;
    const errorEl = document.getElementById('rx-error') as HTMLDivElement;
    const highlightedEl = document.getElementById('rx-highlighted') as HTMLDivElement;
    const countEl = document.getElementById('rx-count') as HTMLSpanElement;
    const matchesEl = document.getElementById('rx-matches') as HTMLDivElement;

    if (!patternEl || !flagsEl || !textEl) return;

    function escapeHtml(str: string): string {
      return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function runTest() {
      const pattern = patternEl.value;
      const flags = flagsEl.value;
      const text = textEl.value;

      errorEl.classList.add('hidden');
      highlightedEl.innerHTML = '';
      matchesEl.innerHTML = '';

      if (!pattern) {
        highlightedEl.innerHTML = escapeHtml(text);
        countEl.textContent = '0 matches';
        return;
      }

      let regex: RegExp;
      try {
        regex = new RegExp(pattern, flags);
      } catch (e) {
        errorEl.textContent = 'Invalid regex: ' + (e as Error).message;
        errorEl.classList.remove('hidden');
        highlightedEl.innerHTML = escapeHtml(text);
        countEl.textContent = '0 matches';
        return;
      }

      const matches: { index: number; length: number; value: string; groups: string[] }[] = [];
      let match: RegExpExecArray | null;

      if (flags.includes('g')) {
        while ((match = regex.exec(text)) !== null) {
          matches.push({ index: match.index, length: match[0].length, value: match[0], groups: match.slice(1) });
          if (match[0].length === 0) regex.lastIndex++;
        }
      } else {
        match = regex.exec(text);
        if (match) {
          matches.push({ index: match.index, length: match[0].length, value: match[0], groups: match.slice(1) });
        }
      }

      countEl.textContent = matches.length + ' match' + (matches.length !== 1 ? 'es' : '');

      // Build highlighted HTML
      let html = '';
      let lastIndex = 0;
      matches.forEach((m) => {
        html += escapeHtml(text.slice(lastIndex, m.index));
        html += '<mark class="bg-yellow-200 dark:bg-yellow-800 text-gray-900 dark:text-yellow-100 rounded px-0.5">' + escapeHtml(m.value) + '</mark>';
        lastIndex = m.index + m.length;
      });
      html += escapeHtml(text.slice(lastIndex));
      highlightedEl.innerHTML = html || escapeHtml(text);

      // Match details
      let detailsHtml = '';
      matches.forEach((m, i) => {
        detailsHtml += '<div class="rounded-lg border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 p-3 text-sm">';
        detailsHtml += '<div class="flex items-center gap-3 mb-1"><span class="font-semibold text-blue-600 dark:text-blue-400">Match ' + (i + 1) + '</span>';
        detailsHtml += '<span class="text-gray-500 text-xs">Index ' + m.index + '-' + (m.index + m.length) + '</span></div>';
        detailsHtml += '<code class="text-gray-900 dark:text-gray-100 font-mono text-xs">' + escapeHtml(m.value) + '</code>';
        if (m.groups.length > 0) {
          m.groups.forEach((g, gi) => {
            detailsHtml += '<div class="mt-1 text-xs text-gray-500">Group ' + (gi + 1) + ': <code class="text-gray-800 dark:text-gray-200">' + escapeHtml(g || '') + '</code></div>';
          });
        }
        detailsHtml += '</div>';
      });
      matchesEl.innerHTML = detailsHtml || '<div class="text-sm text-gray-500">No matches found.</div>';
    }

    patternEl.addEventListener('input', runTest);
    flagsEl.addEventListener('input', runTest);
    textEl.addEventListener('input', runTest);

    runTest();
  }

  initRegexTester();
  document.addEventListener('astro:page-load', initRegexTester);
  document.addEventListener('swup:contentReplaced', initRegexTester);
</script>
