---
import ToolLayout from '~/layouts/ToolLayout.astro';
---

<ToolLayout
  title="Text Reverser"
  description="Reverse text character by character, word by word, or line by line. Fun and useful text transformation tool."
  slug="text-reverser"
  category="Text Tools"
>
  <div class="space-y-6">
    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Input Text</label>
      <textarea id="tr-input" class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[120px] resize-y focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition" placeholder="Enter text to reverse...">Hello World from QuickToolFlow</textarea>
    </div>

    <div class="flex flex-wrap gap-2">
      <button id="tr-char" class="px-5 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition">Reverse Characters</button>
      <button id="tr-word" class="px-5 py-2.5 bg-white dark:bg-slate-700 text-gray-700 dark:text-gray-200 text-sm font-medium rounded-lg border border-gray-300 dark:border-slate-600 hover:bg-gray-50 transition">Reverse Words</button>
      <button id="tr-line" class="px-5 py-2.5 bg-white dark:bg-slate-700 text-gray-700 dark:text-gray-200 text-sm font-medium rounded-lg border border-gray-300 dark:border-slate-600 hover:bg-gray-50 transition">Reverse Lines</button>
      <button id="tr-copy" class="px-4 py-2.5 bg-white dark:bg-slate-700 text-gray-700 dark:text-gray-200 text-sm font-medium rounded-lg border border-gray-300 dark:border-slate-600 hover:bg-gray-50 transition ml-auto">Copy</button>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Result</label>
      <textarea id="tr-output" class="w-full px-4 py-3 rounded-lg border border-gray-200 dark:border-slate-700 bg-gray-50 dark:bg-slate-800 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[120px] resize-y outline-none" readonly placeholder="Reversed text..." spellcheck="false"></textarea>
    </div>
  </div>
</ToolLayout>

<script>
  function initTextReverser() {
    const input = document.getElementById('tr-input') as HTMLTextAreaElement;
    const output = document.getElementById('tr-output') as HTMLTextAreaElement;
    if (!input || !output) return;

    document.getElementById('tr-char')?.addEventListener('click', () => {
      output.value = input.value.split('').reverse().join('');
    });
    document.getElementById('tr-word')?.addEventListener('click', () => {
      output.value = input.value.split(/\s+/).reverse().join(' ');
    });
    document.getElementById('tr-line')?.addEventListener('click', () => {
      output.value = input.value.split('\n').reverse().join('\n');
    });
    document.getElementById('tr-copy')?.addEventListener('click', () => {
      if (output.value) navigator.clipboard.writeText(output.value);
    });
  }

  initTextReverser();
  document.addEventListener('astro:page-load', initTextReverser);
  document.addEventListener('swup:contentReplaced', initTextReverser);
</script>
