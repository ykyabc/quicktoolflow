---
import ToolLayout from '~/layouts/ToolLayout.astro';
import ToolActionBar from '~/components/ui/ToolActionBar.astro';
import ToolActionButton from '~/components/ui/ToolActionButton.astro';
---

<ToolLayout
  title="Text Reverser"
  description="Reverse text character by character, word by word, or line by line. Fun and useful text transformation tool."
  slug="text-reverser"
  category="Text Tools"
  features={[
    'Reverse text by characters, words, or full lines',
    'Keeps the original input visible while showing the transformed result',
    'One-click copy for reversed output',
    'Works with short phrases, multi-line lists, and longer text blocks',
    'Runs locally in the browser for quick private transformations',
    'Useful for testing, puzzles, formatting tasks, and text experiments',
  ]}
  useCases={[
    'Reverse a list order without opening a spreadsheet',
    'Create mirrored text effects for usernames, puzzles, or examples',
    'Flip word order in a sentence while keeping words readable',
    'Reverse log lines, notes, or bullet lists from newest to oldest',
    'Test how software handles unusual or reversed strings',
  ]}
  howToSteps={[
    'Enter or paste the text you want to reverse.',
    'Choose Reverse Characters, Reverse Words, or Reverse Lines.',
    'Review the transformed text in the Result box.',
    'Click Copy when you want to reuse the output elsewhere.',
  ]}
  examples={[
    {
      title: 'Reverse by different modes',
      input: 'Hello World\nQuickToolFlow',
      output:
        'Characters: wolFloT kciuQ\ndlroW olleH\nWords: QuickToolFlow World Hello\nLines: QuickToolFlow\nHello World',
      note: 'Character, word, and line reversal are different operations, so choose the mode that matches the structure of your text.',
    },
  ]}
  tips={[
    'Character reversal can change the appearance of emoji or combined Unicode characters in some browsers.',
    'Word reversal treats whitespace-separated chunks as words and normalizes them with single spaces.',
    'Line reversal is often the best option for reordering lists, logs, or rows of text.',
  ]}
  faq={[
    {
      question: 'What is a text reverser?',
      answer:
        'A text reverser transforms text in reverse order. This tool can reverse by character, by word, or by line depending on the result you need.',
    },
    {
      question: 'What is the difference between reversing words and characters?',
      answer:
        'Character reversal flips every character in the text, while word reversal keeps each word readable and changes the order of the words.',
    },
    {
      question: 'Can I reverse multiple lines at once?',
      answer:
        'Yes. Paste multi-line text and use Reverse Lines to place the last line first, the second-to-last line second, and so on.',
    },
    {
      question: 'Is the reversed text stored anywhere?',
      answer: 'No. The transformation happens locally in your browser and the text is not uploaded to a server.',
    },
  ]}
>
  <div class="space-y-6">
    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Input Text</label>
      <textarea
        id="tr-input"
        class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[120px] resize-y focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
        placeholder="Enter text to reverse...">Hello World from QuickToolFlow</textarea
      >
    </div>

    <ToolActionBar>
      <ToolActionButton id="tr-char" variant="primary" icon="tabler:arrows-sort">Reverse Characters</ToolActionButton>
      <ToolActionButton id="tr-word" icon="tabler:sort-descending-letters">Reverse Words</ToolActionButton>
      <ToolActionButton id="tr-line" icon="tabler:list">Reverse Lines</ToolActionButton>
      <ToolActionButton id="tr-sample" icon="tabler:file-code">Load Sample</ToolActionButton>
      <ToolActionButton id="tr-copy" icon="tabler:copy">Copy</ToolActionButton>
    </ToolActionBar>

    <div id="tr-status" class="hidden rounded-lg px-4 py-3 text-sm font-medium"></div>

    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Result</label>
      <textarea
        id="tr-output"
        class="w-full px-4 py-3 rounded-lg border border-gray-200 dark:border-slate-700 bg-gray-50 dark:bg-slate-800 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[120px] resize-y outline-none"
        readonly
        placeholder="Reversed text..."
        spellcheck="false"></textarea>
    </div>
  </div>
</ToolLayout>

<script>
  function initTextReverser() {
    const input = document.getElementById('tr-input') as HTMLTextAreaElement;
    const output = document.getElementById('tr-output') as HTMLTextAreaElement;
    if (!input || !output) return;

    const status = document.getElementById('tr-status');
    function showStatus(message: string, error = false) {
      if (!status) return;
      status.textContent = message;
      status.className =
        'rounded-lg px-4 py-3 text-sm font-medium ' + (error ? 'bg-red-50 text-red-700' : 'bg-green-50 text-green-700');
      status.classList.remove('hidden');
    }

    function hasInput() {
      if (input.value.trim()) return true;
      output.value = '';
      showStatus('Enter text to reverse first.', true);
      return false;
    }

    document.getElementById('tr-char')?.addEventListener('click', () => {
      if (!hasInput()) return;
      output.value = input.value.split('').reverse().join('');
      showStatus('Characters reversed.', false);
    });
    document.getElementById('tr-word')?.addEventListener('click', () => {
      if (!hasInput()) return;
      output.value = input.value.split(/\s+/).reverse().join(' ');
      showStatus('Words reversed.', false);
    });
    document.getElementById('tr-line')?.addEventListener('click', () => {
      if (!hasInput()) return;
      output.value = input.value.split('\n').reverse().join('\n');
      showStatus('Lines reversed.', false);
    });
    document.getElementById('tr-sample')?.addEventListener('click', () => {
      input.value = 'First line\nSecond line\nThird line';
      output.value = '';
      showStatus('Sample text loaded. Choose a reverse mode.', false);
    });
    document.getElementById('tr-copy')?.addEventListener('click', () => {
      if (!output.value) {
        showStatus('Reverse text before copying.', true);
        return;
      }
      navigator.clipboard.writeText(output.value);
      showStatus('Reversed text copied to clipboard.', false);
    });
  }

  initTextReverser();
  document.addEventListener('astro:page-load', initTextReverser);
  document.addEventListener('swup:contentReplaced', initTextReverser);
</script>
