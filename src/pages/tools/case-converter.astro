---
import ToolLayout from '~/layouts/ToolLayout.astro';
---

<ToolLayout
  title="Case Converter"
  description="Convert text between uppercase, lowercase, title case, sentence case, camelCase, snake_case, kebab-case, and more."
  slug="case-converter"
  category="Text Tools"
>
  <div class="space-y-6">
    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Input Text</label>
      <textarea id="cc-input" class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[120px] resize-y focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition" placeholder="Enter text to convert...">hello world from quick tool flow</textarea>
    </div>

    <div class="flex flex-wrap gap-2">
      {[
        { id: 'cc-upper', label: 'UPPER CASE' },
        { id: 'cc-lower', label: 'lower case' },
        { id: 'cc-title', label: 'Title Case' },
        { id: 'cc-sentence', label: 'Sentence case' },
        { id: 'cc-camel', label: 'camelCase' },
        { id: 'cc-pascal', label: 'PascalCase' },
        { id: 'cc-snake', label: 'snake_case' },
        { id: 'cc-kebab', label: 'kebab-case' },
        { id: 'cc-constant', label: 'CONSTANT_CASE' },
      ].map((btn) => (
        <button id={btn.id} class="cc-btn px-4 py-2 bg-white dark:bg-slate-700 text-gray-700 dark:text-gray-200 text-sm font-medium rounded-lg border border-gray-300 dark:border-slate-600 hover:bg-gray-50 dark:hover:bg-slate-600 hover:border-blue-400 transition">
          {btn.label}
        </button>
      ))}
    </div>

    <div>
      <div class="flex items-center justify-between mb-2">
        <label class="text-sm font-medium text-gray-700 dark:text-gray-300">Result</label>
        <button id="cc-copy" class="text-xs text-blue-600 hover:text-blue-700 font-medium">Copy</button>
      </div>
      <textarea id="cc-output" class="w-full px-4 py-3 rounded-lg border border-gray-200 dark:border-slate-700 bg-gray-50 dark:bg-slate-800 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[120px] resize-y outline-none" readonly placeholder="Select a case style above..." spellcheck="false"></textarea>
    </div>
  </div>
</ToolLayout>

<script>
  function initCaseConverter() {
    const input = document.getElementById('cc-input') as HTMLTextAreaElement;
    const output = document.getElementById('cc-output') as HTMLTextAreaElement;
    const btnCopy = document.getElementById('cc-copy');
    const buttons = document.querySelectorAll('.cc-btn') as NodeListOf<HTMLButtonElement>;

    if (!input || !output || !buttons.length) return;

    const words = () => input.value.trim().split(/[\s_\-]+/).filter(w => w.length > 0);

    const converters: Record<string, () => string> = {
      'cc-upper': () => input.value.toUpperCase(),
      'cc-lower': () => input.value.toLowerCase(),
      'cc-title': () => words().map(w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()).join(' '),
      'cc-sentence': () => {
        const s = input.value.toLowerCase();
        return s.charAt(0).toUpperCase() + s.slice(1);
      },
      'cc-camel': () => words().map((w, i) => i === 0 ? w.toLowerCase() : w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()).join(''),
      'cc-pascal': () => words().map(w => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()).join(''),
      'cc-snake': () => words().map(w => w.toLowerCase()).join('_'),
      'cc-kebab': () => words().map(w => w.toLowerCase()).join('-'),
      'cc-constant': () => words().map(w => w.toUpperCase()).join('_'),
    };

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const fn = converters[btn.id];
        if (fn) output.value = fn();
      });
    });

    btnCopy?.addEventListener('click', () => {
      if (output.value) navigator.clipboard.writeText(output.value);
    });
  }

  initCaseConverter();
  document.addEventListener('astro:page-load', initCaseConverter);
  document.addEventListener('swup:contentReplaced', initCaseConverter);
</script>
