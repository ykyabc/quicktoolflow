---
import ToolLayout from '~/layouts/ToolLayout.astro';
import ToolActionBar from '~/components/ui/ToolActionBar.astro';
import ToolActionButton from '~/components/ui/ToolActionButton.astro';
---

<ToolLayout
  title="Case Converter"
  description="Convert text between uppercase, lowercase, title case, sentence case, camelCase, snake_case, kebab-case, and more."
  slug="case-converter"
  category="Text Tools"
  features={[
    'Converts text to uppercase, lowercase, title case, and sentence case',
    'Creates developer-friendly formats such as camelCase, PascalCase, snake_case, kebab-case, and CONSTANT_CASE',
    'Works instantly with pasted titles, labels, variables, headings, and filenames',
    'Keeps conversion local in your browser',
    'Includes one-click copy for the converted output',
    'Useful for both writing and coding workflows',
  ]}
  useCases={[
    'Converting article titles into title case or sentence case',
    'Creating variable names from plain English phrases',
    'Turning headings into kebab-case file names or URL segments',
    'Normalizing copied text before using it in a CMS, spreadsheet, or codebase',
  ]}
  howToSteps={[
    'Enter or paste text into the input field.',
    'Choose the target case style from the buttons.',
    'Review the converted output.',
    'Copy the result if you want to paste it into code, content, or a document.',
  ]}
  examples={[
    {
      title: 'Convert a phrase into code-friendly names',
      input: 'quick tool flow',
      output:
        'camelCase: quickToolFlow\nPascalCase: QuickToolFlow\nsnake_case: quick_tool_flow\nkebab-case: quick-tool-flow',
      note: 'Different projects use different naming conventions. This tool helps switch between them quickly.',
    },
  ]}
  tips={[
    'camelCase is common for JavaScript variables and object properties.',
    'kebab-case is often used for URLs, filenames, and CSS class names.',
    'Title case rules vary by style guide, so review important headlines manually before publishing.',
  ]}
  faq={[
    {
      question: 'What is camelCase used for?',
      answer:
        'camelCase is commonly used for variable names and object properties in JavaScript and many other programming workflows.',
    },
    {
      question: 'What is the difference between kebab-case and snake_case?',
      answer:
        'kebab-case uses hyphens between words, while snake_case uses underscores. URLs usually prefer kebab-case.',
    },
    {
      question: 'Does title case follow a specific style guide?',
      answer:
        'The converter capitalizes each word in a simple way. For editorial work, compare the result with your required style guide.',
    },
    {
      question: 'Is the conversion processed on a server?',
      answer: 'No. Case conversion runs locally in your browser.',
    },
  ]}
>
  <div class="space-y-6">
    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Input Text</label>
      <textarea
        id="cc-input"
        class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[120px] resize-y focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
        placeholder="Enter text to convert...">hello world from quick tool flow</textarea
      >
    </div>

    <ToolActionBar>
      {
        [
          { id: 'cc-upper', label: 'UPPER CASE' },
          { id: 'cc-lower', label: 'lower case' },
          { id: 'cc-title', label: 'Title Case' },
          { id: 'cc-sentence', label: 'Sentence case' },
          { id: 'cc-camel', label: 'camelCase' },
          { id: 'cc-pascal', label: 'PascalCase' },
          { id: 'cc-snake', label: 'snake_case' },
          { id: 'cc-kebab', label: 'kebab-case' },
          { id: 'cc-constant', label: 'CONSTANT_CASE' },
        ].map((btn) => (
          <ToolActionButton id={btn.id} class="cc-btn" icon="tabler:letter-case">
            {btn.label}
          </ToolActionButton>
        ))
      }
      <ToolActionButton id="cc-sample" icon="tabler:file-code">Load Sample</ToolActionButton>
    </ToolActionBar>

    <div id="cc-status" class="hidden rounded-lg px-4 py-3 text-sm font-medium"></div>

    <div>
      <div class="flex items-center justify-between mb-2">
        <label class="text-sm font-medium text-gray-700 dark:text-gray-300">Result</label>
        <ToolActionButton id="cc-copy" icon="tabler:copy" class="min-h-0 px-3 py-1.5 text-xs">Copy</ToolActionButton>
      </div>
      <textarea
        id="cc-output"
        class="w-full px-4 py-3 rounded-lg border border-gray-200 dark:border-slate-700 bg-gray-50 dark:bg-slate-800 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[120px] resize-y outline-none"
        readonly
        placeholder="Select a case style above..."
        spellcheck="false"></textarea>
    </div>
  </div>
</ToolLayout>

<script>
  function initCaseConverter() {
    const input = document.getElementById('cc-input') as HTMLTextAreaElement;
    const output = document.getElementById('cc-output') as HTMLTextAreaElement;
    const btnCopy = document.getElementById('cc-copy');
    const btnSample = document.getElementById('cc-sample');
    const status = document.getElementById('cc-status');
    const buttons = document.querySelectorAll('.cc-btn') as NodeListOf<HTMLButtonElement>;

    if (!input || !output || !buttons.length) return;

    function showStatus(message: string, error = false) {
      if (!status) return;
      status.textContent = message;
      status.className =
        'rounded-lg px-4 py-3 text-sm font-medium ' + (error ? 'bg-red-50 text-red-700' : 'bg-green-50 text-green-700');
      status.classList.remove('hidden');
    }

    function hasInput() {
      if (input.value.trim()) return true;
      output.value = '';
      showStatus('Enter text to convert first.', true);
      return false;
    }

    const words = () =>
      input.value
        .trim()
        .split(/[\s_-]+/)
        .filter((w) => w.length > 0);

    const converters: Record<string, () => string> = {
      'cc-upper': () => input.value.toUpperCase(),
      'cc-lower': () => input.value.toLowerCase(),
      'cc-title': () =>
        words()
          .map((w) => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase())
          .join(' '),
      'cc-sentence': () => {
        const s = input.value.toLowerCase();
        return s.charAt(0).toUpperCase() + s.slice(1);
      },
      'cc-camel': () =>
        words()
          .map((w, i) => (i === 0 ? w.toLowerCase() : w.charAt(0).toUpperCase() + w.slice(1).toLowerCase()))
          .join(''),
      'cc-pascal': () =>
        words()
          .map((w) => w.charAt(0).toUpperCase() + w.slice(1).toLowerCase())
          .join(''),
      'cc-snake': () =>
        words()
          .map((w) => w.toLowerCase())
          .join('_'),
      'cc-kebab': () =>
        words()
          .map((w) => w.toLowerCase())
          .join('-'),
      'cc-constant': () =>
        words()
          .map((w) => w.toUpperCase())
          .join('_'),
    };

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        if (!hasInput()) return;
        const fn = converters[btn.id];
        if (fn) {
          output.value = fn();
          showStatus('Text converted.', false);
        }
      });
    });

    btnSample?.addEventListener('click', () => {
      input.value = 'quick tool flow developer tools';
      output.value = '';
      showStatus('Sample text loaded. Choose a case style.', false);
    });

    btnCopy?.addEventListener('click', () => {
      if (!output.value) {
        showStatus('Convert text before copying.', true);
        return;
      }
      navigator.clipboard.writeText(output.value);
      showStatus('Converted text copied to clipboard.', false);
    });
  }

  initCaseConverter();
  document.addEventListener('astro:page-load', initCaseConverter);
  document.addEventListener('swup:contentReplaced', initCaseConverter);
</script>
