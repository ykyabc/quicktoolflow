---
import ToolLayout from '~/layouts/ToolLayout.astro';
---

<ToolLayout
  title="JSON Formatter & Validator"
  description="Format, validate, minify, and beautify JSON data instantly with error detection. Free online JSON tool."
  slug="json-formatter"
  category="Developer Tools"
>
  <div class="space-y-6">
    <div class="flex flex-wrap gap-2">
      <button id="jf-format" class="inline-flex items-center gap-2 px-5 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition">Format / Beautify</button>
      <button id="jf-minify" class="inline-flex items-center gap-2 px-5 py-2.5 bg-white dark:bg-slate-700 text-gray-700 dark:text-gray-200 text-sm font-medium rounded-lg border border-gray-300 dark:border-slate-600 hover:bg-gray-50 dark:hover:bg-slate-600 transition">Minify</button>
      <button id="jf-validate" class="inline-flex items-center gap-2 px-5 py-2.5 bg-white dark:bg-slate-700 text-gray-700 dark:text-gray-200 text-sm font-medium rounded-lg border border-gray-300 dark:border-slate-600 hover:bg-gray-50 dark:hover:bg-slate-600 transition">Validate</button>
      <button id="jf-copy" class="inline-flex items-center gap-2 px-5 py-2.5 bg-white dark:bg-slate-700 text-gray-700 dark:text-gray-200 text-sm font-medium rounded-lg border border-gray-300 dark:border-slate-600 hover:bg-gray-50 dark:hover:bg-slate-600 transition">Copy</button>
      <button id="jf-clear" class="inline-flex items-center gap-2 px-5 py-2.5 text-red-600 text-sm font-medium rounded-lg border border-red-200 hover:bg-red-50 dark:hover:bg-red-900/20 transition">Clear</button>
    </div>

    <div id="jf-status" class="hidden rounded-lg px-4 py-3 text-sm font-medium"></div>

    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Input JSON</label>
      <textarea id="jf-input" class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[200px] resize-y focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition" placeholder='{"name": "QuickToolFlow", "version": 1}' spellcheck="false"></textarea>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Output</label>
      <textarea id="jf-output" class="w-full px-4 py-3 rounded-lg border border-gray-200 dark:border-slate-700 bg-gray-50 dark:bg-slate-800 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[200px] resize-y outline-none" readonly placeholder="Formatted output will appear here..." spellcheck="false"></textarea>
    </div>
  </div>

  <script is:inline>
    const input = document.getElementById('jf-input');
    const output = document.getElementById('jf-output');
    const status = document.getElementById('jf-status');

    function showStatus(msg, isError) {
      status.textContent = msg;
      status.className = `rounded-lg px-4 py-3 text-sm font-medium ${isError ? 'bg-red-50 text-red-700 border border-red-200' : 'bg-green-50 text-green-700 border border-green-200'}`;
      status.classList.remove('hidden');
    }

    document.getElementById('jf-format').addEventListener('click', () => {
      try {
        output.value = JSON.stringify(JSON.parse(input.value), null, 2);
        showStatus('✓ Valid JSON — formatted successfully.', false);
      } catch (e) { showStatus('✗ ' + e.message, true); }
    });

    document.getElementById('jf-minify').addEventListener('click', () => {
      try {
        output.value = JSON.stringify(JSON.parse(input.value));
        showStatus('✓ Minified successfully.', false);
      } catch (e) { showStatus('✗ ' + e.message, true); }
    });

    document.getElementById('jf-validate').addEventListener('click', () => {
      try { JSON.parse(input.value); showStatus('✓ Valid JSON.', false); }
      catch (e) { showStatus('✗ ' + e.message, true); }
    });

    document.getElementById('jf-copy').addEventListener('click', () => {
      if (output.value) navigator.clipboard.writeText(output.value);
    });

    document.getElementById('jf-clear').addEventListener('click', () => {
      input.value = ''; output.value = ''; status.classList.add('hidden');
    });
  </script>
</ToolLayout>
