---
import ToolLayout from '~/layouts/ToolLayout.astro';
import ToolActionBar from '~/components/ui/ToolActionBar.astro';
import ToolActionButton from '~/components/ui/ToolActionButton.astro';
---

<ToolLayout
  title="Whitespace Remover"
  description="Remove extra spaces, tabs, line breaks, and leading/trailing whitespace from text. Clean up messy text instantly."
  slug="whitespace-remover"
  category="Text Tools"
  features={[
    'Remove repeated spaces and normalize text into clean single spacing',
    'Trim leading and trailing whitespace on each line',
    'Remove blank lines from pasted text',
    'Convert tabs into spaces for cleaner plain-text formatting',
    'Shows before, after, and removed character counts',
    'Processes everything locally in your browser',
  ]}
  useCases={[
    'Clean copied text from PDFs, emails, documents, or web pages',
    'Normalize AI-generated drafts before publishing or sending',
    'Prepare plain text for forms, CMS fields, spreadsheets, or scripts',
    'Remove accidental blank lines from lists and notes',
    'Convert tab-heavy snippets into space-based plain text',
  ]}
  howToSteps={[
    'Paste messy text into the input box.',
    'Choose whether to remove extra spaces, trim lines, remove blank lines, or convert tabs.',
    'Check the result and character savings in the stats row.',
    'Copy the cleaned text when it looks right.',
  ]}
  examples={[
    {
      title: 'Clean copied text spacing',
      input: 'Hello     world\n\n\n  This line has extra spaces.  ',
      output: 'Hello world This line has extra spaces.',
      note: 'Remove All Extra Spaces collapses repeated whitespace into single spaces and trims the result.',
    },
  ]}
  tips={[
    'Use Trim Lines when you want to preserve line breaks but remove stray spaces at the beginning or end of each line.',
    'Use Remove Blank Lines for lists, CSV-like text, or copied paragraphs where empty rows are not meaningful.',
    'Use Remove All Extra Spaces carefully with poetry, code, tables, or formatted text where spacing may carry meaning.',
  ]}
  faq={[
    {
      question: 'What counts as whitespace?',
      answer:
        'Whitespace includes spaces, tabs, new lines, and other invisible characters that separate text. This tool focuses on common spaces, tabs, and line breaks.',
    },
    {
      question: 'Will this tool remove all line breaks?',
      answer:
        'Remove All Extra Spaces collapses whitespace into single spaces. Trim Lines and Remove Blank Lines preserve useful line structure depending on the option you choose.',
    },
    {
      question: 'Can I use this for code?',
      answer:
        'You can, but be careful. Some programming languages and formats depend on whitespace. For code, Trim Lines or Tabs to Spaces is usually safer than removing all extra spacing.',
    },
    {
      question: 'Is the text processed privately?',
      answer:
        'Yes. The cleanup happens in your browser, and your pasted text is not uploaded to QuickToolFlow servers.',
    },
  ]}
>
  <div class="space-y-6">
    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Input Text</label>
      <textarea
        id="ws-input"
        class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[150px] resize-y focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
        placeholder="Paste messy text here..."
      >
        Hello World . This is a test with extra spaces. And extra blank lines.
      </textarea>
    </div>

    <ToolActionBar>
      <ToolActionButton id="ws-all" variant="primary" icon="tabler:space">Remove All Extra Spaces</ToolActionButton>
      <ToolActionButton id="ws-trim" icon="tabler:align-left">Trim Lines</ToolActionButton>
      <ToolActionButton id="ws-blank" icon="tabler:line-dashed">Remove Blank Lines</ToolActionButton>
      <ToolActionButton id="ws-tabs" icon="tabler:indent-increase">Tabs to Spaces</ToolActionButton>
      <ToolActionButton id="ws-sample" icon="tabler:file-code">Load Sample</ToolActionButton>
      <ToolActionButton id="ws-copy" icon="tabler:copy">Copy</ToolActionButton>
    </ToolActionBar>

    <div id="ws-status" class="hidden rounded-lg px-4 py-3 text-sm font-medium"></div>

    <div id="ws-stats" class="hidden flex gap-4 p-3 bg-green-50 dark:bg-green-900/20 rounded-lg text-sm">
      <span class="text-green-700 dark:text-green-400" id="ws-before">Before: 0 chars</span>
      <span class="text-green-700 dark:text-green-400" id="ws-after">After: 0 chars</span>
      <span class="text-green-700 dark:text-green-400" id="ws-removed">Removed: 0 chars</span>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Result</label>
      <textarea
        id="ws-output"
        class="w-full px-4 py-3 rounded-lg border border-gray-200 dark:border-slate-700 bg-gray-50 dark:bg-slate-800 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[150px] resize-y outline-none"
        readonly
        placeholder="Cleaned text..."
        spellcheck="false"></textarea>
    </div>
  </div>
</ToolLayout>

<script>
  function initWhitespaceRemover() {
    const input = document.getElementById('ws-input') as HTMLTextAreaElement;
    const output = document.getElementById('ws-output') as HTMLTextAreaElement;
    const statsEl = document.getElementById('ws-stats');
    const beforeEl = document.getElementById('ws-before');
    const afterEl = document.getElementById('ws-after');
    const removedEl = document.getElementById('ws-removed');
    const status = document.getElementById('ws-status');

    if (!input || !output) return;

    function showStatus(message: string, error = false) {
      if (!status) return;
      status.textContent = message;
      status.className =
        'rounded-lg px-4 py-3 text-sm font-medium ' + (error ? 'bg-red-50 text-red-700' : 'bg-green-50 text-green-700');
      status.classList.remove('hidden');
    }

    function hasInput() {
      if (input.value.trim()) return true;
      output.value = '';
      showStatus('Paste text to clean first.', true);
      return false;
    }

    function showStats(result: string) {
      if (statsEl) statsEl.classList.remove('hidden');
      if (beforeEl) beforeEl.textContent = 'Before: ' + input.value.length + ' chars';
      if (afterEl) afterEl.textContent = 'After: ' + result.length + ' chars';
      if (removedEl) removedEl.textContent = 'Removed: ' + (input.value.length - result.length) + ' chars';
      showStatus('Whitespace cleanup complete.', false);
    }

    document.getElementById('ws-all')?.addEventListener('click', () => {
      if (!hasInput()) return;
      const r = input.value.replace(/\s+/g, ' ').trim();
      output.value = r;
      showStats(r);
    });
    document.getElementById('ws-trim')?.addEventListener('click', () => {
      if (!hasInput()) return;
      const r = input.value
        .split('\n')
        .map((l) => l.trim())
        .join('\n');
      output.value = r;
      showStats(r);
    });
    document.getElementById('ws-blank')?.addEventListener('click', () => {
      if (!hasInput()) return;
      const r = input.value.replace(/^\s*[\n]/gm, '').replace(/\n{3,}/g, '\n\n');
      output.value = r;
      showStats(r);
    });
    document.getElementById('ws-tabs')?.addEventListener('click', () => {
      if (!hasInput()) return;
      const r = input.value.replace(/\t/g, '  ');
      output.value = r;
      showStats(r);
    });
    document.getElementById('ws-sample')?.addEventListener('click', () => {
      input.value = '  Hello     world\\n\\n\\n\\tThis line has tabs and extra spaces.  ';
      output.value = '';
      statsEl?.classList.add('hidden');
      showStatus('Sample messy text loaded. Choose a cleanup mode.', false);
    });
    document.getElementById('ws-copy')?.addEventListener('click', () => {
      if (!output.value) {
        showStatus('Clean text before copying.', true);
        return;
      }
      navigator.clipboard.writeText(output.value);
      showStatus('Cleaned text copied to clipboard.', false);
    });
  }

  initWhitespaceRemover();
  document.addEventListener('astro:page-load', initWhitespaceRemover);
  document.addEventListener('swup:contentReplaced', initWhitespaceRemover);
</script>
