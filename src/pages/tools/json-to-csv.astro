---
import RelatedGuides from '~/components/ui/RelatedGuides.astro';
import Layout from '~/layouts/PageLayout.astro';
import Breadcrumb from '~/components/ui/Breadcrumb.astro';
import AdBanner from '~/components/ui/AdBanner.astro';
import ToolActionButton from '~/components/ui/ToolActionButton.astro';
import ToolCard from '~/components/ui/ToolCard.astro';
import { tools } from '~/utils/tools-data';

const metadata = {
  title: 'JSON to CSV Converter - Free Online Tool',
  description:
    'Convert JSON data to CSV format instantly. Paste your JSON array and download a CSV file. Free, fast, and runs entirely in your browser.',
};

const related = ['json-formatter', 'json-to-yaml', 'string-escape', 'markdown-preview'];
const relatedTools = tools.filter((t) => related.includes(t.slug));
---

<Layout metadata={metadata}>
  <section class="px-4 py-12 mx-auto max-w-7xl sm:px-6 lg:px-8">
    <Breadcrumb
      items={[{ name: 'Home', href: '/' }, { name: 'Tools', href: '/tools/' }, { name: 'JSON to CSV Converter' }]}
    />

    <header class="mb-8">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-5xl">JSON to CSV Converter</h1>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400 max-w-3xl">
        Paste a JSON array of objects and instantly convert it to CSV. Download the result as a file or copy to
        clipboard. Runs entirely in your browser.
      </p>
    </header>

    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-6 shadow-sm">
          <div class="flex items-center justify-between mb-3">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white">JSON Input</h2>
            <ToolActionButton id="json-sample" icon="tabler:file-code" class="min-h-0 px-3 py-1.5 text-xs">
              Load Sample
            </ToolActionButton>
          </div>
          <textarea
            id="json-input"
            rows="18"
            placeholder="Paste JSON array here..."
            class="w-full p-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-900 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none resize-none font-mono text-sm"
          ></textarea>
          <div id="json-error" class="hidden mt-2 text-sm text-red-600 dark:text-red-400"></div>
          <ToolActionButton id="convert-btn" variant="primary" icon="tabler:table-export" class="mt-4 w-full py-3">
            Convert to CSV
          </ToolActionButton>
        </div>

        <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-6 shadow-sm">
          <div class="flex items-center justify-between mb-3">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white">CSV Output</h2>
            <div class="flex gap-2">
              <ToolActionButton id="csv-copy" icon="tabler:copy" class="min-h-0 px-3 py-1.5 text-xs"
                >Copy</ToolActionButton
              >
              <ToolActionButton id="csv-download" icon="tabler:download" class="min-h-0 px-3 py-1.5 text-xs">
                Download
              </ToolActionButton>
            </div>
          </div>
          <textarea
            id="csv-output"
            rows="18"
            readonly
            class="w-full p-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-white outline-none resize-none font-mono text-sm"
            placeholder="CSV output will appear here..."></textarea>
        </div>
      </div>
    </div>

    <div class="max-w-4xl mx-auto mt-8"><AdBanner placement="toolMiddle" format="horizontal" /></div>

    <div class="max-w-4xl mx-auto mt-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">How to Use</h2>
      <ol class="list-decimal list-inside space-y-2 text-gray-600 dark:text-gray-400">
        <li>Paste a JSON array of objects into the left panel.</li>
        <li>Click <strong>Convert to CSV</strong>.</li>
        <li>The CSV result appears on the right.</li>
        <li>Click <strong>Copy</strong> to copy to clipboard or <strong>Download</strong> to save as a file.</li>
      </ol>
    </div>

    <div class="max-w-4xl mx-auto mt-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Example Conversion</h2>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-3">JSON input</h3>
          <pre
            class="overflow-x-auto rounded-lg bg-gray-50 dark:bg-gray-900 p-4 text-xs leading-5 text-gray-800 dark:text-gray-200"><code>{`[{
  "name": "Alice",
  "profile": { "city": "New York" },
  "skills": ["JSON", "CSV"]
}]`}</code></pre>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-3">CSV output</h3>
          <pre
            class="overflow-x-auto rounded-lg bg-gray-50 dark:bg-gray-900 p-4 text-xs leading-5 text-gray-800 dark:text-gray-200"><code>{`name,profile.city,skills
Alice,New York,JSON; CSV`}</code></pre>
        </div>
      </div>
    </div>

    <div class="max-w-4xl mx-auto mt-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Conversion Rules</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Objects become rows</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            The input should be a JSON array. Each object in the array becomes one CSV row, and object keys become
            column headers.
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Nested keys use dot notation</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Nested objects are flattened into headers such as <code>user.name</code> or <code>profile.city</code>.
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Arrays are joined</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Array values are joined with semicolons so the result remains a simple CSV cell.
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">CSV values are escaped</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Values containing commas, quotes, or line breaks are wrapped and escaped using standard CSV quoting rules.
          </p>
        </div>
      </div>
    </div>

    <div class="max-w-4xl mx-auto mt-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Features</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Flattens Nested Objects</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Nested JSON objects are flattened with dot notation into column headers automatically.
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Handles Arrays</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Array values within objects are joined with semicolons for clean CSV output.
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Download as CSV</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Export the result as a .csv file ready for Excel, Google Sheets, or any spreadsheet app.
          </p>
        </div>
      </div>
    </div>

    <div class="max-w-4xl mx-auto mt-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">What JSON format is supported?</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            The tool expects a JSON array of objects. Each object becomes a row in the CSV. Keys become column headers.
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Is my data sent to a server?</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            No. The conversion happens entirely in your browser. Your data is never uploaded anywhere.
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Can I open the CSV in Excel?</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Yes. Download the result as a <code>.csv</code> file, then open it in Excel, Google Sheets, Numbers, or any spreadsheet
            application.
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">What happens if objects have different keys?</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            The converter builds a combined header list from every row. Missing values are left blank in rows where a
            key does not exist.
          </p>
        </div>
      </div>
    </div>

    <div class="max-w-4xl mx-auto mt-12"><AdBanner placement="toolBottom" format="horizontal" /></div>

    <div class="max-w-4xl mx-auto">
      <RelatedGuides
        guides={[
          {
            title: 'JSON to CSV Conversion Guide',
            href: '/blog/json-to-csv-conversion-guide/',
            description:
              'Learn how JSON to CSV conversion works, how nested objects are handled, and when to use CSV output.',
          },
        ]}
      />
    </div>

    {
      relatedTools.length > 0 && (
        <div class="max-w-4xl mx-auto mt-12">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Related Tools</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            {relatedTools.map((tool) => (
              <ToolCard
                slug={tool.slug}
                name={tool.name}
                description={tool.description}
                icon={tool.icon}
                gradient={tool.gradient}
              />
            ))}
          </div>
        </div>
      )
    }

    <div
      class="max-w-3xl mx-auto mt-16 text-center bg-gradient-to-r from-blue-600 to-indigo-600 rounded-2xl p-8 text-white"
    >
      <h2 class="text-2xl font-bold mb-3">Convert JSON to CSV for Free</h2>
      <p class="mb-5 opacity-90">Paste JSON, get CSV. No sign-up, no limits, no data collection.</p>
      <a
        href="/tools/"
        class="inline-block px-6 py-3 bg-white text-blue-600 font-semibold rounded-lg hover:bg-gray-100 transition"
        >Explore All Tools</a
      >
    </div>
  </section>

  <script is:inline>
    (function () {
      const jsonInput = document.getElementById('json-input');
      const csvOutput = document.getElementById('csv-output');
      const jsonError = document.getElementById('json-error');
      const convertBtn = document.getElementById('convert-btn');
      const copyBtn = document.getElementById('csv-copy');
      const dlBtn = document.getElementById('csv-download');
      const sampleBtn = document.getElementById('json-sample');

      const sample = [
        { name: 'Alice', age: 30, city: 'New York' },
        { name: 'Bob', age: 25, city: 'London' },
        { name: 'Charlie', age: 35, city: 'Tokyo' },
      ];

      sampleBtn.addEventListener('click', function () {
        jsonInput.value = JSON.stringify(sample, null, 2);
        jsonError.classList.add('hidden');
      });

      function flatten(obj, prefix) {
        prefix = prefix || '';
        const result = {};
        for (const key in obj) {
          if (!Object.prototype.hasOwnProperty.call(obj, key)) continue;
          const newKey = prefix ? prefix + '.' + key : key;
          const val = obj[key];
          if (val && typeof val === 'object' && !Array.isArray(val) && !(val instanceof Date)) {
            const nested = flatten(val, newKey);
            for (const k in nested) result[k] = nested[k];
          } else if (Array.isArray(val)) {
            result[newKey] = val.join('; ');
          } else {
            result[newKey] = val === null || val === undefined ? '' : String(val);
          }
        }
        return result;
      }

      function escapeCSV(val) {
        if (typeof val !== 'string') val = String(val);
        if (val.indexOf(',') !== -1 || val.indexOf('"') !== -1 || val.indexOf('\n') !== -1) {
          return '"' + val.replace(/"/g, '""') + '"';
        }
        return val;
      }

      convertBtn.addEventListener('click', function () {
        jsonError.classList.add('hidden');
        try {
          const data = JSON.parse(jsonInput.value.trim());
          if (!Array.isArray(data)) throw new Error('Input must be a JSON array of objects.');
          if (data.length === 0) {
            csvOutput.value = '';
            return;
          }
          const flat = data.map(function (row) {
            return flatten(row);
          });
          const headers = [];
          const headerSet = {};
          flat.forEach(function (row) {
            for (const k in row) {
              if (!headerSet[k]) {
                headerSet[k] = true;
                headers.push(k);
              }
            }
          });
          const lines = [headers.map(escapeCSV).join(',')];
          flat.forEach(function (row) {
            lines.push(
              headers
                .map(function (h) {
                  return escapeCSV(row[h] !== undefined ? row[h] : '');
                })
                .join(',')
            );
          });
          csvOutput.value = lines.join('\n');
        } catch (e) {
          jsonError.textContent = 'Error: ' + e.message;
          jsonError.classList.remove('hidden');
          csvOutput.value = '';
        }
      });

      copyBtn.addEventListener('click', function () {
        if (!csvOutput.value) return;
        navigator.clipboard.writeText(csvOutput.value).then(function () {
          copyBtn.textContent = 'Copied!';
          setTimeout(function () {
            copyBtn.textContent = 'Copy';
          }, 2000);
        });
      });

      dlBtn.addEventListener('click', function () {
        if (!csvOutput.value) return;
        const blob = new Blob([csvOutput.value], { type: 'text/csv;charset=utf-8;' });
        const link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = 'data.csv';
        link.click();
        URL.revokeObjectURL(link.href);
      });
    })();
  </script>
</Layout>
