---
import Layout from '~/layouts/PageLayout.astro';
import { tools } from '~/utils/tools-data';

const categoryTools = tools.filter((tool) => tool.categorySlug === 'seo');
const workflows = [
  {
    title: 'Prepare a new page for search',
    description: 'Create meta tags, check the page title length, and turn the headline into a clean URL slug.',
    links: [
      { text: 'SERP Snippet Preview', href: '/tools/serp-snippet-preview/' },
      { text: 'Web Publishing Toolkit', href: '/tools/web-publishing/' },
      { text: 'Design & Frontend Toolkit', href: '/tools/frontend-design/' },
      { text: 'Meta Tag Generator', href: '/tools/meta-tag-generator/' },
      { text: 'Open Graph Preview', href: '/tools/open-graph-preview/' },
      { text: 'Robots.txt Generator', href: '/tools/robots-txt-generator/' },
      { text: 'Word Counter', href: '/tools/word-counter/' },
      { text: 'Slug Generator', href: '/tools/text-to-slug/' },
    ],
  },
  {
    title: 'Build social preview assets',
    description: 'Generate Open Graph tags, create placeholder image dimensions, and convert colors for branded cards.',
    links: [
      { text: 'Meta Tag Generator', href: '/tools/meta-tag-generator/' },
      { text: 'Web Publishing Toolkit', href: '/tools/web-publishing/' },
      { text: 'Design & Frontend Toolkit', href: '/tools/frontend-design/' },
      { text: 'Open Graph Preview', href: '/tools/open-graph-preview/' },
      { text: 'UTM Builder', href: '/tools/utm-builder/' },
      { text: 'URL Query Builder', href: '/tools/url-query-builder/' },
      { text: 'URL Parser', href: '/tools/url-parser/' },
      { text: 'Lorem Image Placeholder', href: '/tools/lorem-image-placeholder/' },
      { text: 'Color Converter', href: '/tools/color-converter/' },
    ],
  },
  {
    title: 'Polish content before publishing',
    description: 'Clean extra whitespace, review repeated terms, and compare draft changes before updating a page.',
    links: [
      { text: 'Whitespace Remover', href: '/tools/whitespace-remover/' },
      { text: 'Word Frequency Counter', href: '/tools/word-frequency-counter/' },
      { text: 'Text Diff Checker', href: '/tools/text-diff/' },
    ],
  },
];

const guideLinks = [
  {
    title: 'SERP Snippet Preview Guide',
    href: '/blog/serp-snippet-preview-guide/',
    description: 'Write clearer page titles and meta descriptions before publishing or requesting indexing.',
  },
  {
    title: 'Open Graph Preview Guide',
    href: '/blog/open-graph-preview-guide/',
    description: 'Prepare social sharing cards with the right title, description, image, and URL.',
  },
  {
    title: 'Robots.txt Generator Guide',
    href: '/blog/robots-txt-generator-guide/',
    description: 'Understand crawler rules, disallow paths, sitemap lines, and indexing mistakes.',
  },
  {
    title: 'UTM Builder Guide',
    href: '/blog/utm-builder-guide/',
    description: 'Create consistent campaign URLs without overwriting important analytics signals.',
  },
  {
    title: 'UTM Parameters vs Query Parameters',
    href: '/blog/utm-parameters-vs-query-parameters/',
    description: 'Separate tracking parameters from functional URL parameters before sharing links.',
  },
  {
    title: 'URL Query Builder Guide',
    href: '/blog/url-query-builder-guide/',
    description: 'Build clean encoded URLs for landing pages, forms, and campaign destinations.',
  },
];

const metadata = {
  title: 'Free Online SEO Tools',
  description:
    'Use free online SEO tools to generate meta tags, improve page snippets, prepare Open Graph tags, and optimize websites for search engines.',
};

const canonical = 'https://quicktoolflow.com/tools/seo/';

const faqItems = [
  {
    question: 'What are online SEO tools?',
    answer:
      'Online SEO tools are browser-based utilities that help website owners create metadata, improve snippets, prepare social tags, and support basic search optimization tasks.',
  },
  {
    question: 'Are QuickToolFlow SEO tools free?',
    answer: 'Yes. QuickToolFlow SEO tools are free to use and do not require sign-up.',
  },
  {
    question: 'Who should use SEO tools?',
    answer:
      'SEO tools are useful for bloggers, developers, marketers, website owners, and anyone who wants to improve how pages appear in search results and social previews.',
  },
];

const auditSteps = [
  {
    title: 'Snippet readiness',
    description:
      'Check that the title, meta description, URL slug, and primary heading describe the page clearly without stuffing keywords.',
  },
  {
    title: 'Social sharing metadata',
    description:
      'Prepare Open Graph and Twitter Card tags so links look intentional when shared in Slack, LinkedIn, X, or messaging apps.',
  },
  {
    title: 'Crawl signals',
    description:
      'Review robots.txt, sitemap references, canonical URLs, and noindex rules before assuming a page is eligible for indexing.',
  },
  {
    title: 'Content review',
    description:
      'Use word count, frequency checks, and text comparison to catch thin copy, repeated phrasing, and accidental draft changes.',
  },
];

const seoMistakes = [
  'Writing a title for search engines but a description for humans. Both should be clear to a real reader.',
  'Using UTMs on internal links, which can overwrite the original traffic source in analytics reports.',
  'Changing slugs after a page is indexed without planning redirects and internal link updates.',
  'Forgetting that Open Graph previews need their own title, description, and image quality checks.',
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://quicktoolflow.com/' },
    { '@type': 'ListItem', position: 2, name: 'Tools', item: 'https://quicktoolflow.com/tools/' },
    { '@type': 'ListItem', position: 3, name: 'SEO Tools', item: canonical },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<Layout metadata={metadata}>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="mb-3 text-sm font-semibold uppercase tracking-wide text-primary-600">SEO Tools</p>

      <h1 class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-5xl">Free Online SEO Tools</h1>

      <p class="mt-6 text-lg leading-8 text-gray-600 dark:text-gray-300">
        QuickToolFlow SEO tools help you generate meta tags, prepare social sharing tags, improve page snippets, and
        build search-friendly website metadata.
      </p>
    </div>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        categoryTools.map((tool) => (
          <a
            href={`/tools/${tool.slug}/`}
            class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md dark:border-gray-700 dark:bg-gray-800"
          >
            <h2 class="text-xl font-semibold text-gray-900 dark:text-white">{tool.name}</h2>

            <p class="mt-3 text-sm leading-6 text-gray-600 dark:text-gray-300">{tool.description}</p>

            <span class="mt-5 inline-flex text-sm font-semibold text-primary-600">Open tool</span>
          </a>
        ))
      }
    </div>

    <section
      class="mt-12 rounded-2xl border border-gray-200 bg-white p-5 shadow-sm dark:border-gray-700 dark:bg-gray-800"
    >
      <h2 class="text-xl font-bold text-gray-900 dark:text-white">Popular SEO Workflows</h2>
      <div class="mt-4 grid gap-3 lg:grid-cols-3">
        {
          workflows.map((workflow) => (
            <div class="rounded-xl border border-gray-100 bg-gray-50 p-4 dark:border-gray-700 dark:bg-gray-900">
              <h3 class="text-sm font-semibold text-gray-900 dark:text-white">{workflow.title}</h3>
              <p class="mt-1 text-xs leading-5 text-gray-600 dark:text-gray-300">{workflow.description}</p>
              <div class="mt-3 flex flex-wrap gap-1.5">
                {workflow.links.map((link) => (
                  <a
                    href={link.href}
                    class="rounded-full bg-white px-2.5 py-1 text-[11px] font-semibold text-gray-700 transition hover:bg-primary-50 hover:text-primary-700 dark:bg-gray-800 dark:text-gray-300 dark:hover:bg-gray-700"
                  >
                    {link.text}
                  </a>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </section>

    <section
      class="mt-10 rounded-xl border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-700 dark:bg-gray-800"
    >
      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div class="max-w-3xl">
          <p class="text-sm font-semibold uppercase tracking-wide text-primary-600">SEO guides</p>
          <h2 class="mt-1 text-xl font-bold text-gray-900 dark:text-white">Helpful guides</h2>
          <p class="mt-1 hidden text-sm leading-6 text-gray-600 dark:text-gray-300 sm:block">
            Quick reads for snippets, social previews, crawl signals, and campaign URLs.
          </p>
        </div>
        <a href="/blog/category/seo/" class="text-sm font-semibold text-primary-600 hover:text-primary-700"
          >More SEO guides</a
        >
      </div>

      <div class="mt-4 grid gap-2 sm:grid-cols-2 lg:grid-cols-3">
        {
          guideLinks.map((guide) => (
            <a
              href={guide.href}
              class="rounded-lg border border-gray-100 bg-gray-50 px-3 py-2.5 transition hover:border-primary-200 hover:bg-primary-50 dark:border-gray-700 dark:bg-gray-900 dark:hover:bg-gray-800"
            >
              <h3 class="text-sm font-semibold text-gray-900 dark:text-white">{guide.title}</h3>
              <p class="mt-1 hidden text-xs leading-5 text-gray-600 dark:text-gray-300 sm:block">{guide.description}</p>
            </a>
          ))
        }
      </div>
    </section>

    <section class="mt-16 grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">SEO publishing checklist</h2>
        <div class="mt-5 grid gap-4 sm:grid-cols-2">
          {
            auditSteps.map((step) => (
              <div class="rounded-xl border border-gray-100 bg-gray-50 p-4 dark:border-gray-700 dark:bg-gray-900">
                <h3 class="text-sm font-semibold text-gray-900 dark:text-white">{step.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600 dark:text-gray-300">{step.description}</p>
              </div>
            ))
          }
        </div>
      </div>

      <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white">Common SEO workflow mistakes</h2>
        <ul class="mt-5 space-y-4 text-sm leading-6 text-gray-600 dark:text-gray-300">
          {
            seoMistakes.map((item) => (
              <li class="rounded-xl border border-gray-100 bg-gray-50 p-4 dark:border-gray-700 dark:bg-gray-900">
                {item}
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <div class="prose prose-lg mx-auto mt-16 dark:prose-invert">
      <h2>Why use online SEO tools?</h2>
      <p>
        SEO tools help website owners prepare better metadata, improve how pages appear in search results, and create
        cleaner snippets for social sharing. They are useful when publishing new pages, updating content, or improving
        technical SEO basics.
      </p>

      <h2>What can QuickToolFlow SEO tools help with?</h2>
      <p>
        You can generate meta titles, descriptions, Open Graph tags, Twitter Card tags, and other metadata that helps
        search engines and social platforms understand your page content. You can also preview how a page title, URL,
        and meta description may appear in a search result before publishing.
      </p>

      <h2>Who should use these SEO tools?</h2>
      <p>
        These tools are useful for bloggers, website owners, developers, marketers, and anyone who wants to prepare
        better search snippets and social previews without manually writing every tag from scratch.
      </p>

      <h2>How these tools fit into an SEO workflow</h2>
      <p>
        The tools on this page cover the practical checks that happen around publishing: preparing metadata, previewing
        snippets, shaping URLs, reviewing text quality, and verifying crawl-related files. They do not replace keyword
        research, analytics, or Search Console, but they help reduce the small publishing mistakes that often keep a
        good page from looking polished in search results.
      </p>

      <h2>When to revisit a published page</h2>
      <p>
        Recheck a page when its title changes, its target search intent changes, a social image is replaced, or Search
        Console reports indexing or snippet issues. A quick metadata and text review is often faster than waiting for a
        crawler to reveal a simple avoidable mistake.
      </p>
    </div>
  </section>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />
</Layout>
