---
import ToolLayout from '~/layouts/ToolLayout.astro';
---

<ToolLayout
  title="HTML Entity Encoder / Decoder"
  description="Encode special characters to HTML entities or decode HTML entities back to readable text."
  slug="html-entity-encoder"
  category="Developer Tools"
>
  <div class="space-y-6">
    <div class="flex gap-2 flex-wrap">
      <button id="he-encode" class="px-5 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition">Encode</button>
      <button id="he-decode" class="px-5 py-2.5 bg-white dark:bg-slate-700 text-gray-700 dark:text-gray-200 text-sm font-medium rounded-lg border border-gray-300 dark:border-slate-600 hover:bg-gray-50 transition">Decode</button>
      <button id="he-swap" class="px-4 py-2.5 bg-white dark:bg-slate-700 text-gray-700 dark:text-gray-200 text-sm font-medium rounded-lg border border-gray-300 dark:border-slate-600 hover:bg-gray-50 transition ml-auto" title="Swap">
        <astro-icon name="tabler:arrows-exchange" class="w-4 h-4" />
      </button>
      <button id="he-copy" class="px-4 py-2.5 bg-white dark:bg-slate-700 text-gray-700 dark:text-gray-200 text-sm font-medium rounded-lg border border-gray-300 dark:border-slate-600 hover:bg-gray-50 transition">Copy Output</button>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Input</label>
      <textarea id="he-input" class="w-full px-4 py-3 rounded-lg border border-gray-300 dark:border-slate-600 bg-white dark:bg-slate-900 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[150px] resize-y focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition" placeholder='Enter text: <div class="hello">Hello & World</div>' spellcheck="false"><div class="hello">Hello & "World" > 5 < 10</div></textarea>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Output</label>
      <textarea id="he-output" class="w-full px-4 py-3 rounded-lg border border-gray-200 dark:border-slate-700 bg-gray-50 dark:bg-slate-800 text-gray-900 dark:text-gray-100 font-mono text-sm min-h-[150px] resize-y outline-none" readonly placeholder="Result will appear here..." spellcheck="false"></textarea>
    </div>

    <div>
      <h3 class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Common HTML Entities Reference</h3>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-2 text-xs">
        {[
          ['&amp;', '&amp;amp;', '&'],
          ['&lt;', '&amp;lt;', '<'],
          ['&gt;', '&amp;gt;', '>'],
          ['&quot;', '&amp;quot;', '"'],
          ['&#39;', '&amp;#39;', "'"],
          ['&nbsp;', '&amp;nbsp;', 'space'],
          ['&copy;', '&amp;copy;', '©'],
          ['&reg;', '&amp;reg;', '®'],
        ].map(([entity, code, char]) => (
          <div class="p-2 bg-gray-50 dark:bg-slate-700 rounded-lg text-center">
            <div class="font-mono text-gray-900 dark:text-white">{code}</div>
            <div class="text-gray-500 mt-0.5">{char}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</ToolLayout>

<script>
  function initHtmlEntityEncoder() {
    const input = document.getElementById('he-input') as HTMLTextAreaElement;
    const output = document.getElementById('he-output') as HTMLTextAreaElement;
    const btnEnc = document.getElementById('he-encode');
    const btnDec = document.getElementById('he-decode');
    const btnSwap = document.getElementById('he-swap');
    const btnCopy = document.getElementById('he-copy');

    if (!input || !output || !btnEnc || !btnDec) return;

    btnEnc.addEventListener('click', () => {
      output.value = input.value
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    });

    btnDec.addEventListener('click', () => {
      output.value = input.value
        .replace(/&amp;/g, '&')
        .replace(/&lt;/g, '<')
        .replace(/&gt;/g, '>')
        .replace(/&quot;/g, '"')
        .replace(/&#39;/g, "'")
        .replace(/&nbsp;/g, ' ')
        .replace(/&copy;/g, '©')
        .replace(/&reg;/g, '®');
    });

    btnSwap?.addEventListener('click', () => {
      const temp = input.value;
      input.value = output.value;
      output.value = temp;
    });

    btnCopy?.addEventListener('click', () => {
      if (output.value) navigator.clipboard.writeText(output.value);
    });
  }

  initHtmlEntityEncoder();
  document.addEventListener('astro:page-load', initHtmlEntityEncoder);
  document.addEventListener('swup:contentReplaced', initHtmlEntityEncoder);
</script>
