---
import RelatedGuides from '~/components/ui/RelatedGuides.astro';
import Layout from '~/layouts/PageLayout.astro';
import Breadcrumb from '~/components/ui/Breadcrumb.astro';
import AdBanner from '~/components/ui/AdBanner.astro';
import ToolActionButton from '~/components/ui/ToolActionButton.astro';
import ToolCard from '~/components/ui/ToolCard.astro';
import { tools } from '~/utils/tools-data';
import { getRelatedGuides } from '~/utils/related-guides';

const metadata = {
  title: 'QR Code Generator - Free Online Tool',
  description:
    'Generate QR codes instantly for URLs, text, email, phone numbers, and more. Free, fast, and runs entirely in your browser.',
};

const related = ['password-generator', 'uuid-generator', 'text-to-slug', 'url-encoder'];
const relatedTools = tools.filter((t) => related.includes(t.slug));

const relatedGuides = getRelatedGuides('qr-code-generator');
---

<Layout metadata={metadata}>
  <section class="px-4 py-12 mx-auto max-w-7xl sm:px-6 lg:px-8">
    <Breadcrumb
      items={[{ name: 'Home', href: '/' }, { name: 'Tools', href: '/tools/' }, { name: 'QR Code Generator' }]}
    />

    <header class="mb-8">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-5xl">QR Code Generator</h1>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400 max-w-3xl">
        Generate QR codes instantly for URLs, text, email, phone numbers, and more. Customize size and download as PNG.
        Runs entirely in your browser: no uploads, no sign-ups.
      </p>
    </header>

    <div class="max-w-3xl mx-auto space-y-6">
      <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-6 shadow-sm">
        <label for="qr-input" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
          >Enter text or URL</label
        >
        <textarea
          id="qr-input"
          rows="3"
          placeholder="https://example.com or any text..."
          class="w-full p-3 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-900 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 outline-none resize-none font-mono text-sm"
        ></textarea>

        <div class="flex flex-wrap gap-4 mt-4">
          <div>
            <label for="qr-size" class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1"
              >Size (px)</label
            >
            <select
              id="qr-size"
              class="p-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-900 text-gray-900 dark:text-white text-sm"
            >
              <option value="128">128</option>
              <option value="256" selected>256</option>
              <option value="512">512</option>
              <option value="1024">1024</option>
            </select>
          </div>
          <div>
            <label for="qr-fg" class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Foreground</label
            >
            <input
              type="color"
              id="qr-fg"
              value="#000000"
              class="w-10 h-10 rounded cursor-pointer border border-gray-300 dark:border-gray-600"
            />
          </div>
          <div>
            <label for="qr-bg" class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Background</label
            >
            <input
              type="color"
              id="qr-bg"
              value="#ffffff"
              class="w-10 h-10 rounded cursor-pointer border border-gray-300 dark:border-gray-600"
            />
          </div>
        </div>

        <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
          <ToolActionButton id="qr-sample" icon="tabler:file-code" class="w-full py-3">Load Sample</ToolActionButton>
          <ToolActionButton id="qr-generate" variant="primary" icon="tabler:qrcode" class="w-full py-3">
            Generate QR Code
          </ToolActionButton>
        </div>
        <div id="qr-status" class="hidden mt-4 rounded-lg px-4 py-3 text-sm font-medium"></div>
      </div>

      <div
        id="qr-result"
        class="hidden bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-6 shadow-sm text-center"
      >
        <div id="qr-wrapper" class="mx-auto mb-4 inline-block"></div>
        <ToolActionButton id="qr-download" variant="primary" icon="tabler:download">Download PNG</ToolActionButton>
      </div>
    </div>

    <div class="max-w-4xl mx-auto mt-8"><AdBanner placement="toolMiddle" format="horizontal" /></div>

    <div class="max-w-4xl mx-auto mt-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">How to Use</h2>
      <ol class="list-decimal list-inside space-y-2 text-gray-600 dark:text-gray-400">
        <li>Enter any URL, text, email, phone number, or WiFi credentials in the input field.</li>
        <li>Customize the size and colors if needed.</li>
        <li>Click <strong>Generate QR Code</strong>.</li>
        <li>Click <strong>Download PNG</strong> to save the image.</li>
      </ol>
    </div>

    <div class="max-w-4xl mx-auto mt-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Features</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Instant Generation</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            QR codes are generated instantly on the client side with no server processing.
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Customizable</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Adjust size, foreground color, and background color to match your branding.
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Download as PNG</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Save your QR code as a high-quality PNG image ready for print or digital use.
          </p>
        </div>
      </div>
    </div>

    <div class="max-w-4xl mx-auto mt-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Useful QR Code Formats</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Website URL</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Paste a full URL such as <code>https://quicktoolflow.com</code>. This is the most reliable format for menus,
            flyers, posters, and product packaging.
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Email or phone</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Use <code>mailto:name@example.com</code> for email links or <code>tel:+15551234567</code> for phone links.
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">WiFi credentials</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Many camera apps support WiFi strings like <code>WIFI:T:WPA;S:NetworkName;P:Password;;</code>.
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Plain text</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Plain text works for short notes, serial numbers, event codes, or internal labels.
          </p>
        </div>
      </div>
    </div>

    <div class="max-w-4xl mx-auto mt-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Practical QR Code Workflows</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Campaign tracking</h3>
          <p class="text-sm leading-6 text-gray-600 dark:text-gray-400">
            Build a UTM-tagged URL first, then generate a QR code from the final campaign link. This keeps offline
            posters, flyers, packaging, and event signs measurable in analytics.
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Operations and support</h3>
          <p class="text-sm leading-6 text-gray-600 dark:text-gray-400">
            Use QR codes for equipment labels, setup instructions, return forms, onboarding checklists, or support
            intake pages. Short destination URLs scan more reliably on small labels.
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Print review checklist</h3>
          <p class="text-sm leading-6 text-gray-600 dark:text-gray-400">
            Test the downloaded PNG at final print size, confirm contrast under real lighting, and scan from the
            expected distance before ordering a full batch.
          </p>
        </div>
      </div>
    </div>

    <div class="max-w-4xl mx-auto mt-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Scanning Reliability Tips</h2>
      <ul class="space-y-3 text-gray-600 dark:text-gray-400">
        <li>Keep strong contrast between the foreground and background colors.</li>
        <li>Avoid very long text when the QR code will be printed small.</li>
        <li>Leave quiet space around the QR code so scanners can detect its edges.</li>
        <li>Test the downloaded PNG on multiple phones before printing it in bulk.</li>
      </ul>
    </div>

    <div class="max-w-4xl mx-auto mt-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">What data can I encode in a QR code?</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            URLs, plain text, email addresses, phone numbers, SMS messages, WiFi credentials, and more. QR codes can
            hold up to about 4,296 alphanumeric characters.
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Is there a size limit?</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            The more data you encode, the denser the QR code becomes. Very long URLs or text may require a larger size
            for reliable scanning.
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Is my data sent to a server?</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            No. Everything runs entirely in your browser. Your text is never uploaded anywhere.
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Can I use custom colors?</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Yes, but keep the foreground much darker than the background. Low-contrast QR codes are harder for cameras
            to scan.
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">What size should I download?</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Use 256 px or 512 px for most digital uses. For print, choose a larger size and test the final physical
            output before distribution.
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Should I use a short URL?</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Shorter URLs usually create less dense QR codes, which can improve scanning on small labels or low-quality
            print materials. Make sure the short URL is stable before printing.
          </p>
        </div>
        <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="font-semibold text-gray-900 dark:text-white mb-2">Can I track QR code performance?</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">
            Yes. Generate the QR code from a tagged URL, such as a URL with UTM parameters, so analytics tools can
            separate scans by campaign, medium, source, or placement.
          </p>
        </div>
      </div>
    </div>

    <div class="max-w-4xl mx-auto mt-12"><AdBanner placement="toolBottom" format="horizontal" /></div>

    <div class="max-w-4xl mx-auto">
      <RelatedGuides guides={relatedGuides} />
    </div>

    {
      relatedTools.length > 0 && (
        <div class="max-w-4xl mx-auto mt-12">
          <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Related Tools</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            {relatedTools.slice(0, 4).map((tool) => (
              <ToolCard
                slug={tool.slug}
                name={tool.name}
                description={tool.description}
                icon={tool.icon}
                gradient={tool.gradient}
              />
            ))}
          </div>
        </div>
      )
    }

    <div
      class="max-w-3xl mx-auto mt-16 text-center bg-gradient-to-r from-blue-600 to-indigo-600 rounded-2xl p-8 text-white"
    >
      <h2 class="text-2xl font-bold mb-3">Generate QR Codes for Free</h2>
      <p class="mb-5 opacity-90">
        Create QR codes instantly for any purpose. No sign-up, no limits, no data collection.
      </p>
      <a
        href="/tools/"
        class="inline-block px-6 py-3 bg-white text-blue-600 font-semibold rounded-lg hover:bg-gray-100 transition"
        >Explore All Tools</a
      >
    </div>
  </section>

  <script is:inline>
    (function () {
      function loadScript(url, callback) {
        const s = document.createElement('script');
        s.src = url;
        s.onload = callback;
        s.onerror = function () {
          alert('Failed to load QRCode library. Please check your network.');
        };
        document.head.appendChild(s);
      }

      loadScript('https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js', function () {
        const input = document.getElementById('qr-input');
        const sizeEl = document.getElementById('qr-size');
        const fgEl = document.getElementById('qr-fg');
        const bgEl = document.getElementById('qr-bg');
        const btn = document.getElementById('qr-generate');
        const result = document.getElementById('qr-result');
        const dlBtn = document.getElementById('qr-download');
        const qrWrap = document.getElementById('qr-wrapper');
        const sampleBtn = document.getElementById('qr-sample');
        const statusEl = document.getElementById('qr-status');

        function showStatus(message, type) {
          const styles = {
            success:
              'mt-4 rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm font-medium text-green-800 dark:border-green-800 dark:bg-green-900/20 dark:text-green-200',
            error:
              'mt-4 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm font-medium text-red-800 dark:border-red-800 dark:bg-red-900/20 dark:text-red-200',
            info: 'mt-4 rounded-lg border border-blue-200 bg-blue-50 px-4 py-3 text-sm font-medium text-blue-800 dark:border-blue-800 dark:bg-blue-900/20 dark:text-blue-200',
          };
          statusEl.className = styles[type || 'success'];
          statusEl.textContent = message;
        }

        sampleBtn.addEventListener('click', function () {
          input.value = 'https://quicktoolflow.com/tools/';
          showStatus('Sample URL loaded. Generate it to preview the QR code.', 'info');
        });

        btn.addEventListener('click', function () {
          const text = input.value.trim();
          if (!text) {
            showStatus('Enter text, a URL, or load the sample before generating a QR code.', 'error');
            return;
          }
          const size = parseInt(sizeEl.value);
          qrWrap.innerHTML = '';
          new QRCode(qrWrap, {
            text: text,
            width: size,
            height: size,
            colorDark: fgEl.value,
            colorLight: bgEl.value,
            correctLevel: QRCode.CorrectLevel.H,
          });
          result.classList.remove('hidden');
          showStatus('QR code generated. Test it with a phone before printing or sharing.');
          result.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });

        dlBtn.addEventListener('click', function () {
          const img = qrWrap.querySelector('img') || qrWrap.querySelector('canvas');
          if (!img) {
            showStatus('Generate a QR code before downloading.', 'error');
            return;
          }
          const link = document.createElement('a');
          link.download = 'qrcode.png';
          if (img.tagName === 'CANVAS') {
            link.href = img.toDataURL('image/png');
          } else {
            link.href = img.src;
          }
          link.click();
          showStatus('QR code downloaded as PNG.');
        });
      });
    })();
  </script>
</Layout>
