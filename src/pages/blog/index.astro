---
import Layout from '~/layouts/PageLayout.astro';
import Breadcrumb from '~/components/ui/Breadcrumb.astro';
import { fetchPosts } from '~/utils/blog';
import { getPermalink } from '~/utils/permalinks';

const posts = await fetchPosts();
const categoryCounts = posts.reduce<Record<string, { title: string; count: number }>>((acc, post) => {
  if (!post.category) return acc;

  acc[post.category.slug] ??= { title: post.category.title, count: 0 };
  acc[post.category.slug].count += 1;

  return acc;
}, {});

const categories = Object.entries(categoryCounts).sort(
  ([, a], [, b]) => b.count - a.count || a.title.localeCompare(b.title)
);

const contentClusters = [
  {
    title: 'Structured Data',
    href: '/tools/structured-data/',
    description: 'JSON, CSV, YAML, XML, schema validation, data cleanup, and format conversion workflows.',
    links: [
      { title: 'JSON vs YAML vs XML', href: '/blog/json-vs-yaml-vs-xml/' },
      { title: 'CSV vs JSON', href: '/blog/csv-vs-json-for-developers/' },
      { title: 'JSON troubleshooting', href: '/blog/why-is-my-json-invalid/' },
    ],
  },
  {
    title: 'Security & Encoding',
    href: '/tools/security-encoding/',
    description: 'Base64, URL encoding, hashes, JWT inspection, password strength, and escaping workflows.',
    links: [
      { title: 'Base64 vs URL Encoding', href: '/blog/base64-vs-url-encoding-guide/' },
      { title: 'JWT Security Best Practices', href: '/blog/jwt-security-best-practices/' },
      { title: 'SHA-256 vs SHA-512', href: '/blog/sha-256-vs-sha-512-guide/' },
    ],
  },
  {
    title: 'Generators & Converters',
    href: '/tools/converters/',
    description: 'QR codes, UUIDs, timestamps, number bases, CSS units, random data, and practical conversions.',
    links: [
      { title: 'Random Test Data', href: '/blog/random-test-data-generation-guide/' },
      { title: 'Unix Seconds vs Milliseconds', href: '/blog/unix-seconds-vs-milliseconds/' },
      { title: 'CSS Unit Conversion', href: '/blog/css-unit-conversion-responsive-design/' },
    ],
  },
  {
    title: 'SEO & Web Publishing',
    href: '/tools/web-publishing/',
    description: 'SERP snippets, Open Graph previews, robots.txt, UTM links, QR campaigns, and metadata.',
    links: [
      { title: 'SERP Snippet Preview', href: '/blog/serp-snippet-preview-guide/' },
      { title: 'Open Graph Preview', href: '/blog/open-graph-preview-guide/' },
      { title: 'UTM Parameters', href: '/blog/utm-parameters-vs-query-parameters/' },
    ],
  },
];

const metadata = {
  title: 'Blog - Developer Tips, Tutorials & Tool Guides',
  description:
    'Read tutorials, tips, and guides about online tools, web development, security, and productivity. Learn best practices for developers.',
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-12 mx-auto max-w-7xl sm:px-6 lg:px-8">
    <Breadcrumb items={[{ name: 'Home', href: '/' }, { name: 'Blog' }]} />

    <header class="mb-12">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-5xl">Blog</h1>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400 max-w-2xl">
        Tutorials, guides, and tips about online tools, web development, and productivity.
      </p>
    </header>

    {
      categories.length > 0 && (
        <nav class="mb-8" aria-label="Blog categories">
          <div class="flex flex-wrap items-center gap-2">
            <a
              href="/blog/category/"
              class="inline-flex items-center rounded-full border border-gray-200 dark:border-slate-700 px-3 py-1.5 text-sm font-medium text-gray-700 dark:text-gray-200 hover:border-blue-300 hover:text-blue-700 dark:hover:border-blue-500 dark:hover:text-blue-300 transition-colors"
            >
              Browse categories
            </a>
            {categories.map(([slug, category]) => (
              <a
                href={getPermalink(slug, 'category')}
                class="inline-flex items-center gap-1.5 rounded-full bg-gray-100 dark:bg-slate-800 px-3 py-1.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-blue-50 hover:text-blue-700 dark:hover:bg-blue-900/30 dark:hover:text-blue-300 transition-colors"
              >
                <span>{category.title}</span>
                <span class="text-xs text-gray-500 dark:text-gray-400">{category.count}</span>
              </a>
            ))}
          </div>
        </nav>
      )
    }

    <section class="mb-12" aria-labelledby="content-clusters-title">
      <div class="mb-5 flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="text-sm font-semibold uppercase tracking-wide text-blue-700 dark:text-blue-300">Content clusters</p>
          <h2 id="content-clusters-title" class="mt-1 text-2xl font-bold text-gray-900 dark:text-white">
            Browse guides by workflow
          </h2>
        </div>
        <a
          href="/blog/category/"
          class="inline-flex text-sm font-semibold text-blue-700 hover:text-blue-800 dark:text-blue-300 dark:hover:text-blue-200"
        >
          View all categories
        </a>
      </div>

      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
        {
          contentClusters.map((cluster) => (
            <section class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm dark:border-slate-700 dark:bg-slate-800">
              <a href={cluster.href} class="group block">
                <h3 class="text-base font-bold text-gray-900 transition-colors group-hover:text-blue-700 dark:text-white dark:group-hover:text-blue-300">
                  {cluster.title}
                </h3>
                <p class="mt-2 text-sm leading-6 text-gray-600 dark:text-gray-400">{cluster.description}</p>
              </a>
              <div class="mt-4 space-y-2">
                {cluster.links.map((link) => (
                  <a
                    href={link.href}
                    class="block text-sm font-medium text-gray-700 transition-colors hover:text-blue-700 dark:text-gray-300 dark:hover:text-blue-300"
                  >
                    {link.title}
                  </a>
                ))}
              </div>
            </section>
          ))
        }
      </div>
    </section>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        posts.map((post) => (
          <a
            href={getPermalink(post.permalink, 'post')}
            class="group block rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
          >
            <div class="p-6">
              {post.category && (
                <span class="inline-block text-xs font-medium tracking-wider uppercase text-blue-700 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30 rounded-full px-2.5 py-0.5 mb-3">
                  {post.category.title}
                </span>
              )}
              <h2 class="text-lg font-bold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors mb-2 line-clamp-2">
                {post.title}
              </h2>
              <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-3 mb-4">{post.excerpt}</p>
              <div class="flex items-center gap-2 text-xs text-gray-400">
                {post.publishDate && (
                  <time datetime={String(post.publishDate)}>
                    {post.publishDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                )}
                {post.author && (
                  <>
                    <span>&middot;</span>
                    <span>{post.author}</span>
                  </>
                )}
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
