---
import Layout from '~/layouts/PageLayout.astro';
import Breadcrumb from '~/components/ui/Breadcrumb.astro';
import { fetchPosts } from '~/utils/blog';
import { getPermalink } from '~/utils/permalinks';

const posts = await fetchPosts();
const categoryCounts = posts.reduce<Record<string, { title: string; count: number }>>((acc, post) => {
  if (!post.category) return acc;

  acc[post.category.slug] ??= { title: post.category.title, count: 0 };
  acc[post.category.slug].count += 1;

  return acc;
}, {});

const categories = Object.entries(categoryCounts).sort(
  ([, a], [, b]) => b.count - a.count || a.title.localeCompare(b.title)
);

const metadata = {
  title: 'Blog - Developer Tips, Tutorials & Tool Guides',
  description:
    'Read tutorials, tips, and guides about online tools, web development, security, and productivity. Learn best practices for developers.',
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-12 mx-auto max-w-7xl sm:px-6 lg:px-8">
    <Breadcrumb items={[{ name: 'Home', href: '/' }, { name: 'Blog' }]} />

    <header class="mb-12">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-5xl">Blog</h1>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400 max-w-2xl">
        Tutorials, guides, and tips about online tools, web development, and productivity.
      </p>
    </header>

    {
      categories.length > 0 && (
        <nav class="mb-10" aria-label="Blog categories">
          <div class="flex flex-wrap items-center gap-2">
            <a
              href="/blog/category/"
              class="inline-flex items-center rounded-full border border-gray-200 dark:border-slate-700 px-3 py-1.5 text-sm font-medium text-gray-700 dark:text-gray-200 hover:border-blue-300 hover:text-blue-700 dark:hover:border-blue-500 dark:hover:text-blue-300 transition-colors"
            >
              Browse categories
            </a>
            {categories.map(([slug, category]) => (
              <a
                href={getPermalink(slug, 'category')}
                class="inline-flex items-center gap-1.5 rounded-full bg-gray-100 dark:bg-slate-800 px-3 py-1.5 text-sm text-gray-700 dark:text-gray-300 hover:bg-blue-50 hover:text-blue-700 dark:hover:bg-blue-900/30 dark:hover:text-blue-300 transition-colors"
              >
                <span>{category.title}</span>
                <span class="text-xs text-gray-500 dark:text-gray-400">{category.count}</span>
              </a>
            ))}
          </div>
        </nav>
      )
    }

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        posts.map((post) => (
          <a
            href={getPermalink(post.permalink, 'post')}
            class="group block rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 overflow-hidden hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
          >
            <div class="p-6">
              {post.category && (
                <span class="inline-block text-xs font-medium tracking-wider uppercase text-blue-700 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30 rounded-full px-2.5 py-0.5 mb-3">
                  {post.category.title}
                </span>
              )}
              <h2 class="text-lg font-bold text-gray-900 dark:text-white group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors mb-2 line-clamp-2">
                {post.title}
              </h2>
              <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-3 mb-4">{post.excerpt}</p>
              <div class="flex items-center gap-2 text-xs text-gray-400">
                {post.publishDate && (
                  <time datetime={String(post.publishDate)}>
                    {post.publishDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                )}
                {post.author && (
                  <>
                    <span>&middot;</span>
                    <span>{post.author}</span>
                  </>
                )}
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
