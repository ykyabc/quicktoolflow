---
import Layout from '~/layouts/PageLayout.astro';
import Breadcrumb from '~/components/ui/Breadcrumb.astro';
import { fetchPosts } from '~/utils/blog';
import { getPermalink } from '~/utils/permalinks';

const posts = await fetchPosts();
const categoryCounts = posts.reduce<Record<string, { title: string; count: number }>>((acc, post) => {
  if (!post.category) return acc;

  acc[post.category.slug] ??= { title: post.category.title, count: 0 };
  acc[post.category.slug].count += 1;

  return acc;
}, {});

const categories = Object.entries(categoryCounts).sort(
  ([, a], [, b]) => b.count - a.count || a.title.localeCompare(b.title)
);

const metadata = {
  title: 'Blog Categories',
  description:
    'Browse QuickToolFlow blog articles by category, including developer tools, SEO, generators, security, and practical workflow guides.',
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-12 mx-auto max-w-7xl sm:px-6 lg:px-8">
    <Breadcrumb items={[{ name: 'Home', href: '/' }, { name: 'Blog', href: '/blog/' }, { name: 'Categories' }]} />

    <header class="mb-10">
      <h1 class="text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-5xl">Blog Categories</h1>
      <p class="mt-4 text-lg text-gray-600 dark:text-gray-400 max-w-2xl">
        Find tutorials and tool guides grouped by topic.
      </p>
    </header>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        categories.map(([slug, category]) => (
          <a
            href={getPermalink(slug, 'category')}
            class="group rounded-lg border border-gray-200 bg-white p-6 transition-all duration-300 hover:-translate-y-0.5 hover:border-blue-300 hover:shadow-md dark:border-slate-700 dark:bg-slate-800 dark:hover:border-blue-500"
          >
            <div class="flex items-start justify-between gap-4">
              <div>
                <h2 class="text-xl font-bold text-gray-900 transition-colors group-hover:text-blue-700 dark:text-white dark:group-hover:text-blue-300">
                  {category.title}
                </h2>
                <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
                  {category.count} {category.count === 1 ? 'article' : 'articles'}
                </p>
              </div>
              <span class="rounded-full bg-blue-50 px-2.5 py-1 text-sm font-semibold text-blue-700 dark:bg-blue-900/30 dark:text-blue-300">
                {category.count}
              </span>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
