---
import Layout from '~/layouts/PageLayout.astro';
import Breadcrumb from '~/components/ui/Breadcrumb.astro';

const metadata = {
  title: 'About QuickToolFlow',
  description: 'Learn about QuickToolFlow — our mission to provide fast, free, and privacy-first online tools.',
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-12 mx-auto max-w-4xl sm:px-6 lg:px-8">
    <Breadcrumb items={[{ name: 'Home', href: '/' }, { name: 'About' }]} />

    <article class="prose prose-lg dark:prose-invert max-w-none prose-headings:font-bold prose-a:text-blue-600 hover:prose-a:underline">
      <h1>About QuickToolFlow</h1>
      <p class="text-xl text-gray-600 dark:text-gray-400 lead">
        QuickToolFlow is a collection of free online tools designed for developers and productivity enthusiasts.
        Every tool runs entirely in your browser — no data is ever sent to our servers.
      </p>

      <h2>Our Mission</h2>
      <p>We believe essential developer and productivity tools should be freely accessible, blazingly fast, and respectful of your privacy. Too many tool sites bombard users with ads, require sign-ups, or harvest personal data. We're building the opposite.</p>

      <h2>Privacy First</h2>
      <p>Every tool on QuickToolFlow processes data locally in your browser using JavaScript. Your text, passwords, code, and other inputs never leave your device. We don't use analytics that track individual users, and we don't store any of your input data.</p>

      <h2>Open &amp; Free</h2>
      <p>All tools are free to use with no limits. No premium tiers, no hidden fees, and no sign-up walls. Our tools are supported by non-intrusive advertising that doesn't interfere with your workflow.</p>

      <h2>Our Tools</h2>
      <ul>
        <li><strong>Text Tools</strong> — Word counter, text diff checker</li>
        <li><strong>Developer Tools</strong> — JSON formatter, Base64 encoder, hash generator, URL encoder</li>
        <li><strong>Generators</strong> — Password generator, Lorem Ipsum generator</li>
        <li><strong>Converters</strong> — Color converter (HEX ↔ RGB ↔ HSL)</li>
      </ul>

      <h2>Contact</h2>
      <p>Have questions, feedback, or partnership inquiries? Visit our <a href="/contact/">Contact page</a> or email <a href="mailto:hello@quicktoolflow.com">hello@quicktoolflow.com</a>.</p>
    </article>
  </section>
</Layout>
