---
import Layout from '~/layouts/Layout.astro';
import Breadcrumb from '~/components/ui/Breadcrumb.astro';
import AdBanner from '~/components/ui/AdBanner.astro';
import ToolCard from '~/components/ui/ToolCard.astro';
import { tools } from '~/utils/tools-data';

export interface Props {
  title: string;
  description: string;
  slug: string;
  category: string;
  faq?: Array<{ question: string; answer: string }>;
  features?: string[];
  useCases?: string[];
}

const { title, description, slug, category, faq, features, useCases } = Astro.props;
const canonical = `https://quicktoolflow.com/tools/${slug}`;

const autoFaq = faq || [
  {
    question: `What is the ${title}?`,
    answer: `The ${title} on QuickToolFlow is a free online tool that lets you ${description.toLowerCase().replace(/\.$/, '')}. All processing happens directly in your browser for complete privacy.`,
  },
  {
    question: `Is the ${title} free to use?`,
    answer: `Yes, completely free with no limits, no sign-up required, and no hidden fees. Use it as much as you need.`,
  },
  {
    question: `Is my data safe when using the ${title}?`,
    answer: `Absolutely. All data processing happens locally in your browser using JavaScript. No data is transmitted to or stored on any server. Your privacy is fully protected.`,
  },
  {
    question: `Do I need to install anything?`,
    answer: `No installation required. The ${title} works directly in your web browser on any device — desktop, tablet, or mobile.`,
  },
];

const autoFeatures = features || [
  'Runs 100% in your browser — complete privacy',
  'No sign-up or registration required',
  'Works on all devices and browsers',
  'Instant results with no server latency',
  'Completely free with no usage limits',
  'Clean, distraction-free interface',
];

const autoUseCases = useCases || [
  `${category.replace(' Tools', '').replace('s', '')} workflows and projects`,
  'Quick everyday tasks',
  'Learning and education',
  'Professional development',
];

const toolSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: `${title} — QuickToolFlow`,
  description,
  url: canonical,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  publisher: { '@type': 'Organization', name: 'QuickToolFlow', url: 'https://quicktoolflow.com' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: autoFaq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};


const currentTool = tools.find((t) => t.slug === slug);

const categoryPageMap: Record<string, string> = {
  text: 'text',
  developer: 'developer',
  generator: 'generators',
  converter: 'converters',
  seo: 'seo',
};

const categoryUrl = currentTool
  ? `/tools/${categoryPageMap[currentTool.categorySlug] || currentTool.categorySlug}/`
  : '/tools/';

const otherTools = tools
  .filter((tool) => tool.slug !== slug && tool.categorySlug === currentTool?.categorySlug)
  .slice(0, 6);

const metadata = { title, description, canonical, robots: { index: true, follow: true } };
---

<Layout metadata={metadata}>
  <section class="px-4 py-10 mx-auto max-w-4xl sm:px-6 lg:px-8">
    <Breadcrumb items={[
      { name: 'Home', href: '/' },
      { name: 'Tools', href: '/tools/' },
      { name: title },
    ]} />

    <header class="mb-8">
      <span class="inline-block text-xs font-medium tracking-wider uppercase text-blue-700 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30 rounded-full px-3 py-1 mb-3">
        {category}
      </span>
      <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-gray-900 dark:text-white mb-3">
        {title}
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed max-w-2xl">
        {description}
      </p>
      {currentTool && (
        <a
          href={categoryUrl}
          class="mt-4 inline-flex text-sm font-medium text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300"
        >
          View all {currentTool.category} →
       </a>
      )}
    </header>

    <AdBanner slot="1234567890" format="horizontal" />

    {/* TOOL BODY */}
    <div class="rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 p-6 sm:p-8 shadow-sm mb-8">
      <slot />
    </div>

    <AdBanner slot="0987654321" format="auto" />

    {/* HOW TO USE */}
    <section class="mt-12 mb-10">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">How to Use</h2>
      <ol class="space-y-3 text-gray-600 dark:text-gray-400">
        <li class="flex gap-3"><span class="font-bold text-blue-600 shrink-0">1.</span> Enter or paste your content into the input field above.</li>
        <li class="flex gap-3"><span class="font-bold text-blue-600 shrink-0">2.</span> Click the action button to process your data.</li>
        <li class="flex gap-3"><span class="font-bold text-blue-600 shrink-0">3.</span> View results instantly in the output area.</li>
        <li class="flex gap-3"><span class="font-bold text-blue-600 shrink-0">4.</span> Copy the output to your clipboard with one click.</li>
      </ol>
    </section>

    {/* FEATURES */}
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Features</h2>
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {autoFeatures.map((f) => (
          <li class="flex items-start gap-2 text-gray-600 dark:text-gray-400">
            <astro-icon name="tabler:check" class="w-5 h-5 text-green-500 shrink-0 mt-0.5" />
            <span>{f}</span>
          </li>
        ))}
      </ul>
    </section>

    {/* USE CASES */}
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Use Cases</h2>
      <ul class="space-y-2 text-gray-600 dark:text-gray-400">
        {autoUseCases.map((uc) => (
          <li class="flex items-start gap-2">
            <astro-icon name="tabler:arrow-right" class="w-4 h-4 text-blue-500 shrink-0 mt-1" />
            <span>{uc}</span>
          </li>
        ))}
      </ul>
    </section>

    {/* FAQ */}
    <section class="mb-10">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {autoFaq.map((item) => (
          <details class="group rounded-lg border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800">
            <summary class="flex items-center justify-between p-4 cursor-pointer text-gray-900 dark:text-white font-medium hover:text-blue-600 dark:hover:text-blue-400 transition-colors list-none">
              <span>{item.question}</span>
              <astro-icon name="tabler:chevron-down" class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform shrink-0 ml-2" />
            </summary>
            <div class="px-4 pb-4 text-gray-600 dark:text-gray-400 leading-relaxed">
              {item.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    {/* RELATED TOOLS */}
    <section class="mt-12">
      <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">
         Related {currentTool?.category || 'Tools'}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {otherTools.map((tool) => (
          <ToolCard slug={tool.slug} name={tool.name} description={tool.description} icon={tool.icon} gradient={tool.gradient} />
        ))}
      </div>
    </section>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(toolSchema)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />
</Layout>
