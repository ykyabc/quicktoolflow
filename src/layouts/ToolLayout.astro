---
import Layout from '~/layouts/Layout.astro';
import Breadcrumb from '~/components/ui/Breadcrumb.astro';
import AdBanner from '~/components/ui/AdBanner.astro';
import { getRelatedTools, tools } from '~/utils/tools-data';
import { getRelatedGuides } from '~/utils/related-guides';

export interface Props {
  title: string;
  description: string;
  slug: string;
  category: string;
  faq?: Array<{ question: string; answer: string }>;
  features?: string[];
  useCases?: string[];
  howToSteps?: string[];
  examples?: Array<{ title: string; input?: string; output?: string; note?: string }>;
  tips?: string[];
}

const {
  title,
  description,
  slug,
  category,
  faq,
  features,
  useCases,
  howToSteps,
  examples = [],
  tips = [],
} = Astro.props;
const canonical = `https://quicktoolflow.com/tools/${slug}/`;

const autoFaq = faq || [
  {
    question: `What is the ${title}?`,
    answer: `The ${title} on QuickToolFlow is a free online tool that lets you ${description.toLowerCase().replace(/\.$/, '')}. All processing happens directly in your browser for complete privacy.`,
  },
  {
    question: `Is the ${title} free to use?`,
    answer: `Yes, completely free with no limits, no sign-up required, and no hidden fees. Use it as much as you need.`,
  },
  {
    question: `Is my data safe when using the ${title}?`,
    answer: `Absolutely. All data processing happens locally in your browser using JavaScript. No data is transmitted to or stored on any server. Your privacy is fully protected.`,
  },
  {
    question: `Do I need to install anything?`,
    answer: `No installation required. The ${title} works directly in your web browser on any device: desktop, tablet, or mobile.`,
  },
];

const autoFeatures = features || [
  'Runs 100% in your browser with complete privacy',
  'No sign-up or registration required',
  'Works on all devices and browsers',
  'Instant results with no server latency',
  'Completely free with no usage limits',
  'Clean, distraction-free interface',
];

const autoUseCases = useCases || [
  `${category.replace(' Tools', '').replace('s', '')} workflows and projects`,
  'Quick everyday tasks',
  'Learning and education',
  'Professional development',
];

const autoHowToSteps = howToSteps || [
  'Enter or paste your content into the input field above.',
  'Click the action button to process your data.',
  'View results instantly in the output area.',
  'Copy the output to your clipboard with one click.',
];

const toolSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: `${title} - QuickToolFlow`,
  description,
  url: canonical,
  applicationCategory: 'DeveloperApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  publisher: { '@type': 'Organization', name: 'QuickToolFlow', url: 'https://quicktoolflow.com' },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: autoFaq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};

const currentTool = tools.find((t) => t.slug === slug);

const categoryPageMap: Record<string, string> = {
  text: 'text',
  developer: 'developer',
  generator: 'generators',
  converter: 'converters',
  seo: 'seo',
};

const categoryUrl = currentTool
  ? `/tools/${categoryPageMap[currentTool.categorySlug] || currentTool.categorySlug}/`
  : '/tools/';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://quicktoolflow.com/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Tools',
      item: 'https://quicktoolflow.com/tools/',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: category,
      item: currentTool ? `https://quicktoolflow.com${categoryUrl}` : 'https://quicktoolflow.com/tools/',
    },
    {
      '@type': 'ListItem',
      position: 4,
      name: title,
      item: canonical,
    },
  ],
};

const relatedTools = getRelatedTools(slug, 7);
const nextTools = relatedTools.slice(0, 3);
const moreRelatedTools = relatedTools.slice(3, 7);
const relatedGuides = getRelatedGuides(slug).slice(0, 4);
const quickLinks = [
  { text: 'Tool', href: '#tool-workspace', show: true },
  { text: 'Next Tools', href: '#next-tools', show: nextTools.length > 0 },
  { text: 'Example', href: '#example', show: examples.length > 0 },
  { text: 'Notes', href: '#practical-notes', show: tips.length > 0 },
  { text: 'How to Use', href: '#how-to-use', show: autoHowToSteps.length > 0 },
  { text: 'Features', href: '#features', show: autoFeatures.length > 0 },
  { text: 'FAQ', href: '#faq', show: autoFaq.length > 0 },
  { text: 'Guides', href: '#related-guides', show: relatedGuides.length > 0 },
  { text: 'More Tools', href: '#related-tools', show: moreRelatedTools.length > 0 },
].filter((link) => link.show);

const metadata = { title, description, canonical, robots: { index: true, follow: true } };
---

<Layout metadata={metadata}>
  <section class="px-3 py-4 mx-auto max-w-4xl sm:px-6 sm:py-10 lg:px-8">
    <Breadcrumb items={[{ name: 'Home', href: '/' }, { name: 'Tools', href: '/tools/' }, { name: title }]} />

    <header class="mb-4 sm:mb-8">
      <span
        class="inline-block text-[11px] font-medium tracking-wider uppercase text-blue-700 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/30 rounded-full px-3 py-1 mb-2 sm:mb-3"
      >
        {category}
      </span>
      <h1 class="text-2xl sm:text-4xl font-bold tracking-tight text-gray-900 dark:text-white mb-2 sm:mb-3">
        {title}
      </h1>
      <p class="text-sm sm:text-lg text-gray-600 dark:text-gray-400 leading-6 sm:leading-relaxed max-w-2xl">
        {description}
      </p>
      <div class="mt-5 hidden gap-3 lg:grid lg:grid-cols-3">
        <div class="rounded-lg border border-gray-200 bg-white p-3 dark:border-slate-700 dark:bg-slate-800">
          <div class="flex items-center gap-2 text-sm font-semibold text-gray-900 dark:text-white">
            <astro-icon name="tabler:device-laptop" class="h-4 w-4 text-blue-600 dark:text-blue-400"></astro-icon>
            Browser-based
          </div>
          <p class="mt-1 text-xs leading-5 text-gray-500 dark:text-gray-400">Use it instantly with no installation.</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-white p-3 dark:border-slate-700 dark:bg-slate-800">
          <div class="flex items-center gap-2 text-sm font-semibold text-gray-900 dark:text-white">
            <astro-icon name="tabler:shield-lock" class="h-4 w-4 text-blue-600 dark:text-blue-400"></astro-icon>
            Local processing
          </div>
          <p class="mt-1 text-xs leading-5 text-gray-500 dark:text-gray-400">Your input stays in your browser.</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-white p-3 dark:border-slate-700 dark:bg-slate-800">
          <div class="flex items-center gap-2 text-sm font-semibold text-gray-900 dark:text-white">
            <astro-icon name="tabler:user-off" class="h-4 w-4 text-blue-600 dark:text-blue-400"></astro-icon>
            No sign-up
          </div>
          <p class="mt-1 text-xs leading-5 text-gray-500 dark:text-gray-400">Open the tool and get results.</p>
        </div>
      </div>
      {
        currentTool && (
          <a
            href={categoryUrl}
            class="mt-3 sm:mt-4 inline-flex text-sm font-medium text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300"
          >
            View all {currentTool.category}
          </a>
        )
      }
    </header>

    {
      quickLinks.length > 0 && (
        <>
          <nav
            aria-label="Tool page sections"
            class="sticky top-[57px] z-30 -mx-3 mb-4 flex gap-2 overflow-x-auto border-y border-gray-200 bg-white/95 px-3 py-2 shadow-sm backdrop-blur dark:border-slate-700 dark:bg-slate-900/95 sm:-mx-6 sm:px-6 lg:hidden"
          >
            {quickLinks.slice(0, 6).map((link) => (
              <a
                href={link.href}
                class="shrink-0 rounded-full bg-gray-100 px-3 py-1.5 text-xs font-semibold text-gray-700 transition hover:bg-blue-50 hover:text-blue-700 dark:bg-slate-800 dark:text-gray-200 dark:hover:bg-slate-700 dark:hover:text-blue-300"
              >
                {link.text}
              </a>
            ))}
          </nav>

          <nav
            aria-label="Tool page sections"
            class="mb-6 hidden gap-2 overflow-x-auto rounded-xl border border-gray-200 bg-white p-2 dark:border-slate-700 dark:bg-slate-800 lg:flex"
          >
            {quickLinks.map((link) => (
              <a
                href={link.href}
                class="shrink-0 rounded-lg px-3 py-2 text-sm font-medium text-gray-600 transition hover:bg-blue-50 hover:text-blue-700 dark:text-gray-300 dark:hover:bg-slate-700 dark:hover:text-blue-300"
              >
                {link.text}
              </a>
            ))}
          </nav>
        </>
      )
    }

    {/* TOOL BODY */}
    <div
      id="tool-workspace"
      class="rounded-xl border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 p-3 sm:p-8 shadow-sm mb-6 sm:mb-8 scroll-mt-28"
    >
      <slot />
    </div>

    {
      nextTools.length > 0 && (
        <section id="next-tools" class="mb-6 sm:mb-8 scroll-mt-24">
          <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
            <div>
              <p class="text-xs font-semibold uppercase tracking-wide text-blue-600 dark:text-blue-400">
                Continue Workflow
              </p>
              <h2 class="mt-1 text-lg font-bold text-gray-900 dark:text-white sm:text-xl">Related tools to try next</h2>
            </div>
            <a
              href="/tools/"
              class="text-sm font-semibold text-blue-600 transition hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300"
            >
              All tools
            </a>
          </div>

          <div class="-mx-3 flex gap-3 overflow-x-auto px-3 pb-2 sm:mx-0 sm:grid sm:grid-cols-3 sm:overflow-visible sm:px-0 sm:pb-0">
            {nextTools.map((tool) => (
              <a
                href={`/tools/${tool.slug}/`}
                class="group w-[78vw] max-w-72 shrink-0 rounded-xl border border-gray-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:border-blue-200 hover:shadow-md dark:border-slate-700 dark:bg-slate-800 dark:hover:border-slate-600 sm:w-auto sm:max-w-none"
              >
                <div
                  class:list={[
                    'mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-gradient-to-br text-white shadow-sm',
                    tool.gradient,
                  ]}
                >
                  <astro-icon name={tool.icon} class="h-5 w-5" />
                </div>
                <h3 class="text-sm font-semibold leading-5 text-gray-900 transition group-hover:text-blue-600 dark:text-white dark:group-hover:text-blue-400">
                  {tool.name}
                </h3>
                <p class="mt-1.5 line-clamp-2 text-xs leading-5 text-gray-500 dark:text-gray-400">{tool.description}</p>
              </a>
            ))}
          </div>
        </section>
      )
    }

    <div
      class="mb-6 flex items-center justify-center gap-3 rounded-full border border-gray-200 bg-white px-3 py-2 text-[11px] font-semibold text-gray-700 shadow-sm dark:border-slate-700 dark:bg-slate-800 dark:text-gray-200 sm:hidden"
      aria-label="Tool privacy notes"
    >
      <span class="inline-flex items-center gap-1">
        <astro-icon name="tabler:device-laptop" class="h-3.5 w-3.5 text-blue-600 dark:text-blue-400"></astro-icon>
        Browser
      </span>
      <span class="h-1 w-1 rounded-full bg-gray-300 dark:bg-slate-600"></span>
      <span class="inline-flex items-center gap-1">
        <astro-icon name="tabler:shield-lock" class="h-3.5 w-3.5 text-blue-600 dark:text-blue-400"></astro-icon>
        Local
      </span>
      <span class="h-1 w-1 rounded-full bg-gray-300 dark:bg-slate-600"></span>
      <span class="inline-flex items-center gap-1">
        <astro-icon name="tabler:user-off" class="h-3.5 w-3.5 text-blue-600 dark:text-blue-400"></astro-icon>
        No sign-up
      </span>
    </div>

    <AdBanner placement="toolBottom" format="auto" />

    {
      examples.length > 0 && (
        <section id="example" class="mt-10 sm:mt-12 mb-8 sm:mb-10 scroll-mt-24">
          <h2 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white mb-4">Example</h2>
          <div class="space-y-4">
            {examples.map((example) => (
              <article class="rounded-lg border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800 p-4">
                <h3 class="text-base font-semibold text-gray-900 dark:text-white">{example.title}</h3>
                {example.note && <p class="mt-2 text-sm leading-6 text-gray-600 dark:text-gray-400">{example.note}</p>}
                <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
                  {example.input && (
                    <div>
                      <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">
                        Input
                      </p>
                      <pre class="overflow-x-auto rounded-md bg-gray-50 p-3 text-xs leading-5 text-gray-800 dark:bg-slate-900 dark:text-gray-100">
                        <code>{example.input}</code>
                      </pre>
                    </div>
                  )}
                  {example.output && (
                    <div>
                      <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-gray-500 dark:text-gray-400">
                        Output
                      </p>
                      <pre class="overflow-x-auto rounded-md bg-gray-50 p-3 text-xs leading-5 text-gray-800 dark:bg-slate-900 dark:text-gray-100">
                        <code>{example.output}</code>
                      </pre>
                    </div>
                  )}
                </div>
              </article>
            ))}
          </div>
        </section>
      )
    }

    {
      tips.length > 0 && (
        <section id="practical-notes" class="mb-8 sm:mb-10 scroll-mt-24">
          <h2 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white mb-4">Practical Notes</h2>
          <ul class="space-y-3 text-gray-600 dark:text-gray-400">
            {tips.map((tip) => (
              <li class="flex items-start gap-2">
                <astro-icon name="tabler:info-circle" class="w-5 h-5 text-blue-500 shrink-0 mt-0.5" />
                <span>{tip}</span>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    {/* HOW TO USE */}
    <section id="how-to-use" class="mt-10 sm:mt-12 mb-8 sm:mb-10 scroll-mt-24">
      <h2 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white mb-4">How to Use</h2>
      <ol class="space-y-3 text-gray-600 dark:text-gray-400">
        {
          autoHowToSteps.map((step, index) => (
            <li class="flex gap-3">
              <span class="font-bold text-blue-600 shrink-0">{index + 1}.</span>
              <span>{step}</span>
            </li>
          ))
        }
      </ol>
    </section>

    {/* FEATURES */}
    <section id="features" class="mb-8 sm:mb-10 scroll-mt-24">
      <h2 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white mb-4">Features</h2>
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        {
          autoFeatures.map((f) => (
            <li class="flex items-start gap-2 text-gray-600 dark:text-gray-400">
              <astro-icon name="tabler:check" class="w-5 h-5 text-green-500 shrink-0 mt-0.5" />
              <span>{f}</span>
            </li>
          ))
        }
      </ul>
    </section>

    {/* USE CASES */}
    <section id="use-cases" class="mb-8 sm:mb-10 scroll-mt-24">
      <h2 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white mb-4">Use Cases</h2>
      <ul class="space-y-2 text-gray-600 dark:text-gray-400">
        {
          autoUseCases.map((uc) => (
            <li class="flex items-start gap-2">
              <astro-icon name="tabler:arrow-right" class="w-4 h-4 text-blue-500 shrink-0 mt-1" />
              <span>{uc}</span>
            </li>
          ))
        }
      </ul>
    </section>

    {/* FAQ */}
    <section id="faq" class="mb-8 sm:mb-10 scroll-mt-24">
      <h2 class="text-xl sm:text-2xl font-bold text-gray-900 dark:text-white mb-4 sm:mb-6">
        Frequently Asked Questions
      </h2>
      <div class="space-y-4">
        {
          autoFaq.map((item) => (
            <details class="group rounded-lg border border-gray-200 dark:border-slate-700 bg-white dark:bg-slate-800">
              <summary class="flex items-center justify-between p-4 cursor-pointer text-gray-900 dark:text-white font-medium hover:text-blue-600 dark:hover:text-blue-400 transition-colors list-none">
                <span>{item.question}</span>
                <astro-icon
                  name="tabler:chevron-down"
                  class="w-5 h-5 text-gray-400 group-open:rotate-180 transition-transform shrink-0 ml-2"
                />
              </summary>
              <div class="px-4 pb-4 text-gray-600 dark:text-gray-400 leading-relaxed">{item.answer}</div>
            </details>
          ))
        }
      </div>
    </section>

    {
      relatedGuides.length > 0 && (
        <section id="related-guides" class="mt-8 sm:mt-10 scroll-mt-24">
          <div class="mb-4 flex items-center justify-between gap-3">
            <h2 class="text-xl font-bold text-gray-900 dark:text-white">Related Guides</h2>
            <a href="/blog/" class="text-sm font-semibold text-blue-600 hover:text-blue-700 dark:text-blue-400">
              More
            </a>
          </div>

          <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
            {relatedGuides.map((guide) => (
              <a
                href={guide.href}
                class="rounded-lg border border-gray-200 bg-white px-3 py-2.5 shadow-sm transition hover:border-blue-200 hover:bg-blue-50 dark:border-slate-700 dark:bg-slate-800 dark:hover:bg-slate-700"
              >
                <h3 class="text-sm font-semibold text-gray-900 dark:text-white">{guide.title}</h3>

                <p class="mt-1 hidden text-xs leading-5 text-gray-600 dark:text-gray-400 sm:block">
                  {guide.description}
                </p>
              </a>
            ))}
          </div>
        </section>
      )
    }

    {/* RELATED TOOLS */}
    {
      moreRelatedTools.length > 0 && (
        <section id="related-tools" class="mt-8 sm:mt-10 scroll-mt-24">
          <div class="mb-4 flex items-center justify-between gap-3">
            <h2 class="text-xl font-bold text-gray-900 dark:text-white">More Related Tools</h2>
            <a href="/tools/" class="text-sm font-semibold text-blue-600 hover:text-blue-700 dark:text-blue-400">
              All tools
            </a>
          </div>
          <div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
            {moreRelatedTools.map((tool) => (
              <a
                href={`/tools/${tool.slug}/`}
                class="flex items-start gap-3 rounded-lg border border-gray-200 bg-white px-3 py-2.5 shadow-sm transition hover:border-blue-200 hover:bg-blue-50 dark:border-slate-700 dark:bg-slate-800 dark:hover:bg-slate-700"
              >
                <span
                  class:list={[
                    'flex h-9 w-9 shrink-0 items-center justify-center rounded-lg bg-gradient-to-br text-white shadow-sm',
                    tool.gradient,
                  ]}
                >
                  <astro-icon name={tool.icon} class="h-4 w-4" />
                </span>
                <span>
                  <span class="block text-sm font-semibold text-gray-900 dark:text-white">{tool.name}</span>
                  <span class="mt-1 hidden text-xs leading-5 text-gray-600 dark:text-gray-400 sm:block">
                    {tool.description}
                  </span>
                </span>
              </a>
            ))}
          </div>
        </section>
      )
    }
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(toolSchema)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} is:inline />
  <style is:global>
    @media (max-width: 640px) {
      #tool-workspace input,
      #tool-workspace select,
      #tool-workspace textarea {
        font-size: 16px;
      }

      #tool-workspace textarea {
        min-height: 9rem;
      }

      #tool-workspace pre,
      #tool-workspace textarea,
      #tool-workspace input {
        max-width: 100%;
      }

      #tool-workspace button,
      #tool-workspace a[role='button'] {
        min-height: 44px;
        touch-action: manipulation;
      }
    }
  </style>
  <script is:inline>
    function initCopyFeedback() {
      document.querySelectorAll('[data-copy-feedback="true"]').forEach((button) => {
        if (button.dataset.copyFeedbackReady === 'true') return;
        button.dataset.copyFeedbackReady = 'true';
        button.addEventListener('click', () => {
          const label = button.querySelector('span:last-child');
          if (!label || button.dataset.copyFeedbackActive === 'true') return;

          const original = label.textContent;
          button.dataset.copyFeedbackActive = 'true';
          window.setTimeout(() => {
            label.textContent = 'Copied';
            window.setTimeout(() => {
              label.textContent = original;
              button.dataset.copyFeedbackActive = 'false';
            }, 1200);
          }, 80);
        });
      });
    }

    initCopyFeedback();
    document.addEventListener('astro:page-load', initCopyFeedback);
  </script>
</Layout>
